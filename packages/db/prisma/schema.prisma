// ─── Saved Commission Tariffs (campaign price-band tariff) ─────────────
// The seller uploads Trendyol's weekly "Ürün Komisyon Tarifesi" Excel (we can't
// auto-fetch it — Trendyol has no API for it). Each upload is kept as a
// store-private, editable, deletable tariff. A tariff has one or more periods
// (the date-range split, e.g. 3-day + 4-day — count/labels are data-driven, NOT
// a fixed enum) and each period has product rows. Each row carries 4 price bands
// (threshold + commission, parsed from the Excel) as JSON; profit per band is
// COMPUTED on read via @pazarsync/profit (never stored — cost/fees can change).
// The seller's chosen band + custom price are persisted on the item.
model CommissionTariff {
  id             String    @id @default(uuid()) @db.Uuid
  organizationId String    @map("organization_id") @db.Uuid
  storeId        String    @map("store_id") @db.Uuid
  name           String
  sourceFilename String?   @map("source_filename")
  // The raw uploaded .xlsx bytes, kept so export can patch the seller's chosen
  // price + tariff selection back into Trendyol's EXACT file (re-uploaded verbatim).
  sourceFile     Bytes?    @map("source_file")
  // The tariff's overall week window = min(period.startsAt) … max(period.endsAt),
  // full datetime (consecutive weeks touch at a 1-minute gap, e.g. 07.59 → 08.00,
  // so DATE alone is not unique — the time matters). Enforces ONE tariff per week
  // per store: `@@unique([storeId, weekStartsAt])`. Postgres treats NULLs as
  // DISTINCT, so unparseable-date uploads (null) are not blocked. Import rejects a
  // duplicate week with DUPLICATE_COMMISSION_TARIFF_WEEK; the Advantage upload
  // picks a tariff BY this week.
  weekStartsAt   DateTime? @map("week_starts_at")
  weekEndsAt     DateTime? @map("week_ends_at")
  exportedAt     DateTime? @map("exported_at")
  createdBy      String?   @map("created_by") @db.Uuid
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  store   Store                    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  periods CommissionTariffPeriod[]
  // Advantage-label tariffs that read their commission from this record (§ advantage-labels design).
  advantageTariffSources AdvantageTariff[] @relation("AdvantageCommissionSource")

  @@unique([storeId, weekStartsAt])
  @@index([organizationId])
  @@index([storeId])
  @@map("commission_tariffs")
}

model CommissionTariffPeriod {
  id             String    @id @default(uuid()) @db.Uuid
  organizationId String    @map("organization_id") @db.Uuid
  storeId        String    @map("store_id") @db.Uuid
  tariffId       String    @map("tariff_id") @db.Uuid
  // Raw human label straight from the Excel, e.g. "23 Haz 08.00 – 26 Haz 07.59".
  dateRangeLabel String    @map("date_range_label")
  // The N from "Tarih aralığı (N Gün)" — drives the export's "{N} Günlük Fiyat"
  // value written into the Tarife Seçimi column. Null if the header was unusual.
  dayCount       Int?      @map("day_count")
  // Best-effort parsed bounds (for active/upcoming/past validity); null if unparseable.
  startsAt       DateTime? @map("starts_at")
  endsAt         DateTime? @map("ends_at")
  sortOrder      Int       @map("sort_order")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  tariff CommissionTariff       @relation(fields: [tariffId], references: [id], onDelete: Cascade)
  items  CommissionTariffItem[]

  @@unique([tariffId, sortOrder])
  @@index([organizationId])
  @@index([tariffId])
  @@map("commission_tariff_periods")
}

model CommissionTariffItem {
  id             String  @id @default(uuid()) @db.Uuid
  organizationId String  @map("organization_id") @db.Uuid
  storeId        String  @map("store_id") @db.Uuid
  periodId       String  @map("period_id") @db.Uuid
  // Matched seller variant (by barcode/stockCode at import); null = no catalog
  // match → profit shown as "no cost". No FK: a deleted variant must not drop the
  // tariff row (the seller still wants the tariff line).
  productVariantId String?  @map("product_variant_id") @db.Uuid
  barcode          String
  stockCode        String?  @map("stock_code")
  productTitle     String   @map("product_title")
  category         String?
  brand            String?
  stock            Int?
  // 0-based Excel row order within the period. The detail screen lists products in
  // this order so it matches the uploaded file (and Trendyol's screen), and stays
  // identical across sub-period tabs (same product → same sortOrder in every period).
  sortOrder        Int      @default(0) @map("sort_order")
  currentPrice     Decimal  @map("current_price") @db.Decimal(12, 2)
  // "KOMİSYONA ESAS FİYAT" from the Excel — the customer-seen price commission is
  // charged on (differs from currentPrice when the product is discounted). The
  // current-scenario profit is computed on THIS price. Null for tariffs imported
  // before the column was read (compute falls back to currentPrice; a re-import
  // backfills it).
  commissionBasePrice Decimal? @map("commission_base_price") @db.Decimal(12, 2)
  // Current (band1) commission as a PERCENT (19 = %19), Excel-sourced.
  currentCommissionPct Decimal @map("current_commission_pct") @db.Decimal(6, 4)
  // The 4 price bands: [{ key, threshold, commissionPct }] (commissionPct fraction).
  bands            Json
  // The seller's chosen band (band1..band4) and optional custom price.
  selectedBand     String?  @map("selected_band")
  customPrice      Decimal? @map("custom_price") @db.Decimal(12, 2)
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  period CommissionTariffPeriod @relation(fields: [periodId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([periodId])
  @@index([storeId, barcode])
  @@map("commission_tariff_items")
}

// ─── Saved Plus Commission Tariffs (Trendyol "Plus" commission offer) ───
// Sibling of CommissionTariff and now sharing its exact three-level shape
// (tariff → period → item) for multi-period parity. The Trendyol "Plus Komisyon"
// Excel offers a SINGLE reduced commission per product (e.g. 15.4% vs the current
// 19%) if the seller opts the product into Plus — no 4-band price ladder. A single
// upload can carry MULTIPLE date-range periods (the count/labels are data-driven,
// NOT a fixed enum), so periods live in their own table and each period owns its
// product rows. Each item holds flat current-vs-Plus columns instead of a bands
// JSON. Profit under Plus is COMPUTED on read via @pazarsync/profit (never
// stored). The seller's per-product opt-in (+ optional custom price) is persisted
// on the item. `source_file` keeps the raw .xlsx so export can patch the seller's
// opt-in back into Trendyol's exact file (re-uploaded verbatim).
model PlusCommissionTariff {
  id             String    @id @default(uuid()) @db.Uuid
  organizationId String    @map("organization_id") @db.Uuid
  storeId        String    @map("store_id") @db.Uuid
  name           String
  sourceFilename String?   @map("source_filename")
  sourceFile     Bytes?    @map("source_file")
  // The tariff's overall week window = min(period.startsAt) … max(period.endsAt),
  // full datetime (consecutive weeks touch at a 1-minute gap, e.g. 07.59 → 08.00,
  // so DATE alone is not unique — the time matters). Enforces ONE Plus tariff per
  // week per store: `@@unique([storeId, weekStartsAt])`. Postgres treats NULLs as
  // DISTINCT, so unparseable-date uploads (null) are not blocked.
  weekStartsAt   DateTime? @map("week_starts_at")
  weekEndsAt     DateTime? @map("week_ends_at")
  exportedAt     DateTime? @map("exported_at")
  createdBy      String?   @map("created_by") @db.Uuid
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  store   Store                        @relation(fields: [storeId], references: [id], onDelete: Cascade)
  periods PlusCommissionTariffPeriod[]

  @@unique([storeId, weekStartsAt])
  @@index([organizationId])
  @@index([storeId])
  @@map("plus_commission_tariffs")
}

model PlusCommissionTariffPeriod {
  id             String    @id @default(uuid()) @db.Uuid
  organizationId String    @map("organization_id") @db.Uuid
  storeId        String    @map("store_id") @db.Uuid
  tariffId       String    @map("tariff_id") @db.Uuid
  // Raw human label straight from the Excel, e.g. "23 Haz 08.00 – 30 Haz 07.59".
  dateRangeLabel String    @map("date_range_label")
  // The N from "Tarih Aralığı (N Gün)" — drives the export's "{N} Günlük Fiyat"
  // value written into the Tarife Seçimi column. Null if the header was unusual.
  dayCount       Int?      @map("day_count")
  // Best-effort parsed bounds (for active/upcoming/past validity); null if unparseable.
  startsAt       DateTime? @map("starts_at")
  endsAt         DateTime? @map("ends_at")
  sortOrder      Int       @map("sort_order")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  tariff PlusCommissionTariff       @relation(fields: [tariffId], references: [id], onDelete: Cascade)
  items  PlusCommissionTariffItem[]

  @@unique([tariffId, sortOrder])
  @@index([organizationId])
  @@index([tariffId])
  @@map("plus_commission_tariff_periods")
}

model PlusCommissionTariffItem {
  id             String @id @default(uuid()) @db.Uuid
  organizationId String @map("organization_id") @db.Uuid
  storeId        String @map("store_id") @db.Uuid
  periodId       String @map("period_id") @db.Uuid
  // Matched seller variant (by barcode/stockCode at import); null = no catalog
  // match → profit shown as "no cost". No FK: a deleted variant must not drop
  // the tariff row.
  productVariantId String? @map("product_variant_id") @db.Uuid
  barcode          String
  stockCode        String? @map("stock_code")
  productTitle     String  @map("product_title")
  category         String?
  brand            String?
  size             String?
  modelCode        String? @map("model_code")
  stock            Int?
  // Güncel TSF (current sale price) + Komisyona Esas Fiyat (commission base).
  currentPrice         Decimal @map("current_price") @db.Decimal(12, 2)
  commissionBasePrice  Decimal @map("commission_base_price") @db.Decimal(12, 2)
  // Güncel Komisyon as a PERCENT ("19" = %19), stored verbatim from the Excel —
  // the profit engine's commission rate IS a percent (assembleUnitEconomics
  // divides by 100), so no conversion. Decimal(6,4) holds 19.0000 fine.
  currentCommissionPct Decimal @map("current_commission_pct") @db.Decimal(6, 4)
  // Plus Fiyat Üst Limiti (price ceiling to qualify for Plus).
  plusPriceUpperLimit  Decimal @map("plus_price_upper_limit") @db.Decimal(12, 2)
  // Plus Komisyon Teklifi as a PERCENT ("15.4" = %15.4), the reduced offer.
  plusCommissionPct    Decimal @map("plus_commission_pct") @db.Decimal(6, 4)
  // Plus Komisyona Esas Fiyatı (commission base under Plus).
  plusCommissionBasePrice Decimal @map("plus_commission_base_price") @db.Decimal(12, 2)
  // Passthrough Trendyol identifiers kept for export fidelity / grouping.
  externalId  String?  @map("external_id")
  tariffGroup String?  @map("tariff_group")
  cancelled   Boolean  @default(false)
  // The seller's opt-in (Plus Fiyat Seçimi / Tarife Seçimi = join Plus yes/no)
  // and an optional custom price for the what-if preview.
  plusSelected Boolean  @default(false) @map("plus_selected")
  customPrice  Decimal? @map("custom_price") @db.Decimal(12, 2)
  // 0-based Excel row order within the period — repeated per period (the same
  // product keeps its sortOrder in every period). Export patches the right rows.
  sortOrder Int      @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  period PlusCommissionTariffPeriod @relation(fields: [periodId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([periodId])
  @@index([storeId, barcode])
  @@map("plus_commission_tariff_items")
}

// ─── Advantage Product Labels ("Avantajlı/Yıldızlı Ürün Etiketleri") ──────────
// Trendyol's "Advantage Product Labels" campaign: pricing a product at/below a
// tier threshold earns an Avantaj / Çok Avantaj / Süper Avantaj badge. UNLIKE the
// other two tariff verticals, the reduced commission is NOT in this Excel — the
// price a seller sets here lands the product into a band of their COMMISSION
// TARIFF, and that band's rate is the commission. So compute READS the store's
// active-period CommissionTariff bands (via bandForPrice), falling back to the
// category rate. Profit is COMPUTED on read (never stored). 2-level (tariff →
// item), no periods (this Excel carries no dates). See
// docs/plans/2026-07-03-advantage-labels-design.md.
model AdvantageTariff {
  id             String    @id @default(uuid()) @db.Uuid
  organizationId String    @map("organization_id") @db.Uuid
  storeId        String    @map("store_id") @db.Uuid
  name           String
  sourceFilename String?   @map("source_filename")
  // Raw uploaded .xlsx bytes, kept so export byte-patches Trendyol's EXACT file.
  sourceFile     Bytes?    @map("source_file")
  // Commission source override: null = auto (the store's active-period commission
  // tariff at read time); set = the seller pinned a specific CommissionTariff.
  // SetNull so deleting the commission tariff falls back to auto, never orphans.
  commissionSourceTariffId String? @map("commission_source_tariff_id") @db.Uuid
  exportedAt     DateTime? @map("exported_at")
  createdBy      String?   @map("created_by") @db.Uuid
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  store            Store             @relation(fields: [storeId], references: [id], onDelete: Cascade)
  commissionSource CommissionTariff? @relation("AdvantageCommissionSource", fields: [commissionSourceTariffId], references: [id], onDelete: SetNull)
  items            AdvantageTariffItem[]

  @@index([organizationId])
  @@index([storeId])
  @@index([commissionSourceTariffId])
  @@map("advantage_tariffs")
}

model AdvantageTariffItem {
  id             String @id @default(uuid()) @db.Uuid
  organizationId String @map("organization_id") @db.Uuid
  storeId        String @map("store_id") @db.Uuid
  tariffId       String @map("tariff_id") @db.Uuid
  // Matched seller variant (by barcode at import); null = no catalog match →
  // profit shown as "no product". No FK: a deleted variant must not drop the row.
  productVariantId String? @map("product_variant_id") @db.Uuid
  barcode          String
  stockCode        String? @map("stock_code")
  productTitle     String  @map("product_title")
  category         String?
  brand            String?
  size             String?
  modelCode        String? @map("model_code")
  stock            Int?
  // Trendyol Satış Fiyatı (current sale price) + Müşterinin Gördüğü Fiyat (info).
  currentPrice  Decimal @map("current_price") @db.Decimal(12, 2)
  customerPrice Decimal @map("customer_price") @db.Decimal(12, 2)
  // KOMİSYON TARİFESİ column ("Var" ⇒ true): does the product have a commission
  // tariff? Drives whether compute looks up a band vs. uses the category rate.
  hasCommissionTariff Boolean @map("has_commission_tariff")
  // The three star tiers as JSON: [{ key:'tier1', upperLimit, lowerLimit },
  // { key:'tier2', upperLimit, lowerLimit }, { key:'tier3', upperLimit, lowerLimit:null }].
  // Decimal STRINGS; NO commission (looked up from the commission tariff on read).
  starTiers Json @map("star_tiers")
  // "Tarife Sonuna Kadar Uygula" column (Evet ⇒ true).
  applyUntilEnd Boolean @map("apply_until_end")
  // Passthrough Trendyol identifiers kept for export fidelity / grouping.
  externalId  String? @map("external_id")
  tariffGroup String? @map("tariff_group")
  // The seller's chosen badge tier (tier1|tier2|tier3) or null, + optional custom
  // price for the what-if preview.
  selectedTier String?  @map("selected_tier")
  customPrice  Decimal? @map("custom_price") @db.Decimal(12, 2)
  // Preserves the Excel row order so export patches the right rows.
  sortOrder Int      @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tariff AdvantageTariff @relation(fields: [tariffId], references: [id], onDelete: Cascade)

  @@unique([tariffId, sortOrder])
  @@index([organizationId])
  @@index([tariffId])
  @@index([storeId, barcode])
  @@map("advantage_tariff_items")
}

// ─── Flash Products ("Flaş Ürünler") ──────────────────────────────────────────
// Trendyol's "Flaş Ürünler" campaign: a product can join a flash slot — five
// 3-hour windows between 09:00–00:00, or a 24-hour 00:00–23:59 window — at a
// reduced price. UNLIKE the tariff verticals the offers arrive as ONE rolling
// list covering multiple dates (no per-week file, no periods): one row = one
// product × one offer bundle, and the same product recurs on rows for different
// dates. Commission is NOT in this Excel — compute resolves it per row from the
// store's covering commission_tariffs band (by the window start), falling back
// to the row's flat currentCommissionPct (the "I" column). `source_file` keeps
// the raw .xlsx so export byte-patches Trendyol's exact file. Profit is COMPUTED
// on read (never stored). 2-level (list → item), no periods.
// See docs/plans/2026-07-07-flash-products-design.md.
model FlashProductList {
  id             String    @id @default(uuid()) @db.Uuid
  organizationId String    @map("organization_id") @db.Uuid
  storeId        String    @map("store_id") @db.Uuid
  name           String
  sourceFilename String?   @map("source_filename")
  // Raw uploaded .xlsx bytes, kept so export byte-patches Trendyol's EXACT file.
  sourceFile     Bytes?    @map("source_file")
  exportedAt     DateTime? @map("exported_at")
  createdBy      String?   @map("created_by") @db.Uuid
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  // NO week-uniqueness: offers arrive as one rolling list, so duplicate uploads
  // are the seller's call (unlike the tariff verticals' per-week @@unique).
  store Store              @relation(fields: [storeId], references: [id], onDelete: Cascade)
  items FlashProductItem[]

  @@index([organizationId])
  @@index([storeId])
  @@map("flash_product_lists")
}

model FlashProductItem {
  id             String @id @default(uuid()) @db.Uuid
  organizationId String @map("organization_id") @db.Uuid
  storeId        String @map("store_id") @db.Uuid
  listId         String @map("list_id") @db.Uuid
  // Matched seller variant (by barcode at import); null = no catalog match →
  // profit shown as "no product". No FK: a deleted variant must not drop the row.
  productVariantId String? @map("product_variant_id") @db.Uuid
  modelCode        String? @map("model_code")
  barcode          String
  productTitle     String  @map("product_title")
  category         String?
  brand            String?
  stock            Int?
  // Passthrough Trendyol "Ürün Id" (column T) kept for export fidelity / grouping.
  externalId       String? @map("external_id")
  // Mevcut Fiyat / TSF (G) + Müşterinin Gördüğü Fiyat (H). The current scenario
  // baseline is customerPrice @ currentCommissionPct (advantage's customer-price model).
  currentPrice  Decimal @map("current_price") @db.Decimal(12, 2)
  customerPrice Decimal @map("customer_price") @db.Decimal(12, 2)
  // Mevcut Komisyon (I) as a PERCENT ("19" = %19), stored verbatim. Used as the
  // flat fallback commission when no covering tariff band resolves.
  currentCommissionPct Decimal @map("current_commission_pct") @db.Decimal(6, 4)
  // "Ürün Komisyon Tarife Seçeneği" column (R == "Var" ⇒ true): does the product
  // have a commission tariff? Drives whether compute looks up a band vs. the flat rate.
  hasCommissionTariff Boolean @map("has_commission_tariff")
  // "Kampanyalı Ürün" (S) kept verbatim for display / export fidelity.
  campaignedProduct String? @map("campaigned_product")
  // 24-hour offer (K + N/O window). Null price ⇒ this row has no 24h offer.
  offer24Price    Decimal?  @map("offer_24_price") @db.Decimal(12, 2)
  offer24StartsAt DateTime? @map("offer_24_starts_at")
  offer24EndsAt   DateTime? @map("offer_24_ends_at")
  // 3-hour offer (L + P/Q window). Null price ⇒ this row has no 3h offer.
  offer3Price    Decimal?  @map("offer_3_price") @db.Decimal(12, 2)
  offer3StartsAt DateTime? @map("offer_3_starts_at")
  offer3EndsAt   DateTime? @map("offer_3_ends_at")
  // The seller's chosen offer (H24|H3) XOR a custom price for the what-if preview
  // (max = the row's lowest present offer price). Both null ⇒ not joined.
  selectedOffer FlashOfferType? @map("selected_offer")
  customPrice   Decimal?        @map("custom_price") @db.Decimal(12, 2)
  // Preserves the Excel row order so export patches the right rows.
  sortOrder Int      @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  list FlashProductList @relation(fields: [listId], references: [id], onDelete: Cascade)

  @@unique([listId, sortOrder])
  @@index([organizationId])
  @@index([listId])
  @@index([storeId, barcode])
  @@map("flash_product_items")
}

// ─── Profit Calculation V1 — Schema Foundation (PR-1) ──────────────────
// design: docs/plans/2026-05-18-profit-calculation-design.md
// guide:  docs/plans/2026-05-19-profit-calc-implementation-guide.md

// Sistem-düzeyi ücret tanımı — pazaryeri × ücret tipi başına 1 satır,
// effectiveFrom ile zaman bazlı sürümleme (design §3.4). V1'de organizasyon
// override'ı yok; tüm seller'lara aynı kural. Read-only global tablo:
// RLS authenticated SELECT açık (USING true), yazma postgres rolünde.
// Seed PR-2'de Trendyol için 4 satır: PSF 10.99 / PSF_FAST 6.99 / Stopaj %1 /
// Return shipping. effectiveFrom: 2026-05-18 (Trendyol PSF doc okuma tarihi).
model FeeDefinition {
  id          String       @id @default(uuid()) @db.Uuid
  platform    FeeScope
  feeType     OrderFeeType @map("fee_type")
  displayName String       @map("display_name")

  calculationKind FeeCalculationKind @map("calculation_kind")
  fixedAmountNet  Decimal?           @map("fixed_amount_net") @db.Decimal(12, 2)
  rateOfSale      Decimal?           @map("rate_of_sale") @db.Decimal(7, 4)

  defaultVatRate Decimal @map("default_vat_rate") @db.Decimal(5, 2)

  effectiveFrom DateTime  @map("effective_from")
  effectiveTo   DateTime? @map("effective_to")
  isRequired    Boolean   @default(false) @map("is_required")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  fees OrderFee[]

  @@unique([platform, feeType, effectiveFrom])
  @@index([platform, effectiveFrom])
  @@map("fee_definitions")
}

// Mikro ihracat "Yurt Dışı İade Operasyon Bedeli" kademe tablosu (data-driven).
// İadeye dönen mikro ihracat ürününde hakediş (KDV-dahil satış − komisyon) üzerinden
// kademeli oran kesilir: ürünün KDV-dahil satış fiyatı ≤2000₺ → %35, >2000₺ → %30
// (Trendyol 16.07.2024 duyurusu). Oran/eşik DB'de (Trendyol değişirse SQL UPDATE).
// ShippingBaremTariff deseni (min/max tutar aralığı + effectiveFrom). Global referans:
// her satıcı aynı satırları okur; RLS authenticated SELECT açık (USING true), yazım
// postgres rolünde. truncateAll() dokunmaz (tenant tablosu değil).
model MicroExportReturnFeeTier {
  id           String  @id @default(uuid()) @db.Uuid
  // Ürünün KDV-dahil satış fiyatı bandı (kademe eşikleri). min ≤ saleGross ≤ max.
  minSaleGross Decimal @map("min_sale_gross") @db.Decimal(12, 2)
  maxSaleGross Decimal @map("max_sale_gross") @db.Decimal(12, 2)
  // Hakediş (satış − komisyon) üzerine uygulanan oran (kesir: 0.3500 = %35).
  rate         Decimal @db.Decimal(7, 4)

  effectiveFrom DateTime @default(now()) @map("effective_from") @db.Date
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@unique([minSaleGross, maxSaleGross, effectiveFrom])
  @@index([minSaleGross, maxSaleGross])
  @@map("micro_export_return_fee_tiers")
}

// Sipariş paket-düzeyi ücret satırı — tüm pazaryeri ücretleri (komisyon hariç,
// o OrderItem'da) burada (design §3.3). source ESTIMATE/SETTLEMENT/CARGO_INVOICE
// karışık yaşar, recomputeSettledProfit filtreyle toplar. PSF/Stopaj ESTIMATE
// satırları PaymentOrder geldiğinde SETTLEMENT'a confirm edilir (§3.7 — confirmedAt
// + confirmedBy bunu izler). organizationId denormalize: insert sırasında stamp.
//
// Idempotency (#297): kaynak-bazlı kimlik kolonlarda yaşar, externalRef JSONB
// AUDIT-ONLY'dir — hiçbir okuma yolu JSONB path filtresi kullanamaz.
//   SETTLEMENT     → trendyolTransactionId (Return üçlüsü aynı id'yi paylaşır,
//                    bacaklar feeType ile ayrışır)
//   CARGO_INVOICE  → invoiceSerialNumber + parcelUniqueId (fatura satırı kimliği)
//   derived        → derivedFrom marker ('fast-delivery' — Trendyol satırı yok,
//                    client-side türetilen düzeltme)
// Partial unique indexler Prisma'da ifade edilemez; check-constraints.sql'de
// (governance) + tanıtan migration'da aynalanmış halde yaşar.
model OrderFee {
  id              String  @id @default(uuid()) @db.Uuid
  orderId         String  @map("order_id") @db.Uuid
  organizationId  String  @map("organization_id") @db.Uuid
  feeDefinitionId String? @map("fee_definition_id") @db.Uuid

  feeType   OrderFeeType      @map("fee_type")
  source    OrderFeeSource
  direction OrderFeeDirection

  // GROSS konvansiyon (2026-06-16): amountNet + vatAmount → amountGross + vatRate.
  // net/vat API katmanında türetilir (amountGross × vatRate / (100+vatRate)).
  // source (ESTIMATE/SETTLEMENT/CARGO_INVOICE) → isEstimate API'de türetilir.
  amountGross Decimal @default(0) @map("amount_gross") @db.Decimal(12, 2)
  vatRate     Decimal @default(0) @map("vat_rate") @db.Decimal(5, 2)

  displayName String? @map("display_name")
  externalRef Json?   @map("external_ref")

  trendyolTransactionId String? @map("trendyol_transaction_id")
  invoiceSerialNumber   String? @map("invoice_serial_number")
  parcelUniqueId        String? @map("parcel_unique_id")
  derivedFrom           String? @map("derived_from")

  // #299: which returned UNIT this settlement fee belongs to. Nullable —
  // populated only for the Return trio when the claim row is already
  // synced; the unconditional backfill in return.ts heals the
  // settlements-before-claims cron ordering (:30 vs :45). UI in V2.
  orderClaimItemId String? @map("order_claim_item_id") @db.Uuid

  capturedAt  DateTime  @default(now()) @map("captured_at")
  // confirmedAt + confirmedBy: PSF/Stopaj ESTIMATE → SETTLEMENT confirmation
  // PaymentOrder ('Ödeme') entry geldiğinde set'lenir (§3.7). Amount comparison
  // yapılmaz — presence check yeterli (deterministic Trendyol kuralı T+0'da
  // hesaplandı).
  confirmedAt DateTime? @map("confirmed_at")
  confirmedBy String?   @map("confirmed_by")

  updatedAt DateTime @updatedAt @map("updated_at")

  order          Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  definition     FeeDefinition?  @relation(fields: [feeDefinitionId], references: [id], onDelete: SetNull)
  orderClaimItem OrderClaimItem? @relation(fields: [orderClaimItemId], references: [id], onDelete: SetNull)

  @@index([organizationId, feeType])
  @@index([orderId, feeType, source])
  @@index([orderClaimItemId])
  @@map("order_fees")
}

// İade talep görünürlüğü — Trendyol getclaims endpoint Settlement Return'den
// ÖNCE iade talebini gösteriyor (design §3.6). Kar hesabını DOĞRUDAN etkilemez;
// UI'da "iade riski" badge için kullanılır. Settlement Return geldiğinde resolved
// set edilir + REFUND_DEDUCTION / COMMISSION_REFUND / RETURN_SHIPPING OrderFee
// satırları yazılır. trendyolClaimId order başına unique.
//
// #298: storeId denormalize (insert sırasında parent order'dan stamp) — tenant
// filtreleme artık `order: { storeId }` parent-walk'u değil doğrudan kolon;
// RLS de can_access_store(store_id) (sync_logs pattern). Paket id'leri kolonda:
// orderShipmentPackageId İADE kolisinin id'si — settlement Return → sipariş
// köprüsünün (return.ts katman-2) indexli anahtarı. orderOutboundPackageId
// orijinal sevkiyat (== Order.platformOrderId). externalRef audit-only.
model OrderClaim {
  id                  String   @id @default(uuid()) @db.Uuid
  organizationId      String   @map("organization_id") @db.Uuid
  storeId             String   @map("store_id") @db.Uuid
  orderId             String   @map("order_id") @db.Uuid
  trendyolClaimId     String   @map("trendyol_claim_id")
  claimDate           DateTime @map("claim_date")
  cargoProviderName   String?  @map("cargo_provider_name")
  cargoTrackingNumber BigInt?  @map("cargo_tracking_number")
  resolved            Boolean

  orderShipmentPackageId String? @map("order_shipment_package_id")
  orderOutboundPackageId String? @map("order_outbound_package_id")

  externalRef Json? @map("external_ref")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  store Store            @relation(fields: [storeId], references: [id], onDelete: Cascade)
  order Order            @relation(fields: [orderId], references: [id], onDelete: Cascade)
  items OrderClaimItem[]

  @@unique([orderId, trendyolClaimId])
  @@index([organizationId, resolved])
  @@index([storeId, orderShipmentPackageId])
  @@index([storeId, resolved])
  @@map("order_claims")
}

// OrderClaim satırlarındaki ürün-bazlı iade sebebi (design §3.6).
// organizationId YOK — RLS parent OrderClaim üzerinden EXISTS walk (order_items
// pattern). reasonCode "DAMAGEDITEM" / "WRONGITEM" gibi enum-benzeri string;
// reasonName Türkçe label (Trendyol'dan direkt). orderItemId nullable çünkü
// match her zaman olmayabilir (item-level eşleme PR-13 sync worker'ında).
model OrderClaimItem {
  id                  String    @id @default(uuid()) @db.Uuid
  claimId             String    @map("claim_id") @db.Uuid
  orderItemId         String?   @map("order_item_id") @db.Uuid
  trendyolClaimItemId String    @map("trendyol_claim_item_id")
  reasonCode          String    @map("reason_code")
  reasonName          String    @map("reason_name")
  status              String
  acceptedBySeller    Boolean   @map("accepted_by_seller")
  autoApproveDate     DateTime? @map("auto_approve_date")
  resolved            Boolean

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  claim     OrderClaim @relation(fields: [claimId], references: [id], onDelete: Cascade)
  orderItem OrderItem? @relation(fields: [orderItemId], references: [id], onDelete: SetNull)
  fees      OrderFee[]

  // trendyolClaimItemId is Trendyol's per-UNIT claimLineItem UUID (a 3-unit
  // return produces 3 rows) — the upsert idempotency anchor for the CLAIMS
  // sync worker. Covers the old claim_id lookup index too.
  @@unique([claimId, trendyolClaimItemId])
  @@index([orderItemId])
  @@map("order_claim_items")
}

// Katalog barkod eksiği — sipariş bir barkodla geldiğinde ama bu barkod
// satıcının kataloğunda yoksa eager katalog-onarımı barkodu Trendyol'dan
// tek-tek çeker ve upsert eder. Trendyol gerçekten bu barkod için bir ürün
// dönmüyorsa (404/boş) satır "eşleşme bekliyor" kalır ve sonsuza dek yeniden
// sorgulanır. Bu tablo onaylı katalog-boşluğu barkodlarını mağaza başına kaydeder
// → yeniden deneme seyrek (vendorMissing=true için ~24sa) yapılabilir ve UI
// "Trendyol kataloğunda yok" gösterebilir. store_id taşır → RLS
// can_access_store(store_id) (orders / sync_logs / live_performance_buffer ile
// aynı pattern, #218). organization_id de denormalize → düz RLS gate + index.
// INSERT/UPDATE/DELETE yalnız service role (sync-worker / catalog-sync postgres
// role kullanır, RLS bypass). Barkod sonradan katalogda çözülünce satır SİLİNİR.
model CatalogBarcodeMiss {
  id             String    @id @default(uuid()) @db.Uuid
  organizationId String    @map("organization_id") @db.Uuid
  storeId        String    @map("store_id") @db.Uuid
  barcode        String
  // true = product genuinely absent from Trendyol approved catalog (sparse ~24h
  // retry). false = transient fetch error (503/network/cap/credentials) → existing
  // exponential curve. Row is DELETED when the barcode later resolves into the catalog.
  vendorMissing  Boolean   @default(false) @map("vendor_missing")
  attempts       Int       @default(0)
  firstSeenAt    DateTime  @default(now()) @map("first_seen_at")
  lastCheckedAt  DateTime  @default(now()) @map("last_checked_at")
  nextRetryAt    DateTime? @map("next_retry_at")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  store        Store        @relation(fields: [storeId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([storeId, barcode])
  @@index([organizationId])
  @@index([storeId, nextRetryAt])
  @@map("catalog_barcode_miss")
}

// Organizasyon-düzeyi ücretler — sipariş'e attribute EDİLEMEYEN faturalar
// (design §3.7). Reklam Bedeli (org-wide Roboost), Penalty/Notification fee'leri
// (KDV=0), PSF/Stopaj audit kayıtları (period-level invoice scope ≠ cycle scope).
// Kar hesabını ETKİLEMEZ — yalnız audit/transparency için. paymentOrderId hangi
// PaymentOrder cycle'ında basıldığını tutar (V2 monthly aggregate variance audit
// bu kayıtları kullanır).
model OrgPeriodFee {
  id             String   @id @default(uuid()) @db.Uuid
  organizationId String   @map("organization_id") @db.Uuid
  storeId        String   @map("store_id") @db.Uuid
  paymentOrderId BigInt   @map("payment_order_id")
  paymentDate    DateTime @map("payment_date")

  feeType OrderFeeType   @map("fee_type")
  source  OrderFeeSource

  // GROSS konvansiyon (2026-06-16, Bölüm E Task 20): amountNet + vatAmount → amountGross + vatRate.
  // Net türetilir: amountGross × 100 / (100 + vatRate). PSF vatRate=20; Stoppage vatRate=0.
  amountGross Decimal @map("amount_gross") @db.Decimal(12, 2)
  vatRate     Decimal @map("vat_rate") @db.Decimal(5, 2)

  invoiceSerialNumber String? @map("invoice_serial_number")
  description         String?
  externalRef         Json?   @map("external_ref")

  // #297: settlement satırı kimliği — idempotency okuması bu kolondan,
  // externalRef audit-only. Partial unique (organization_id, fee_type,
  // trendyol_transaction_id) check-constraints.sql'de yaşar.
  trendyolTransactionId String? @map("trendyol_transaction_id")

  capturedAt DateTime @default(now()) @map("captured_at")

  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@index([organizationId, paymentOrderId])
  @@index([organizationId, feeType, paymentDate])
  @@index([storeId, paymentDate])
  @@map("org_period_fees")
}

// Haftalık komisyon faturası aggregate (design §3.8). Trendyol Sale satırlarındaki
// commissionInvoiceSerialNumber (DCF...) bu tabloya bağlanır. İki aşamalı populate:
// (1) T+~5 Sale satırı OrderItem.commissionInvoiceSerialNumber'a string yazar,
// (2) T+~7 'Komisyon Faturası' otherfinancials kaydı geldiğinde CommissionInvoice
// row'u upsert edilir + OrderItem.commissionInvoiceId backfill (PR-3'te).
// orderItems back-relation PR-3'te eklenir (OrderItem.commissionInvoiceId FK
// ile birlikte).
model CommissionInvoice {
  id                   String    @id @default(uuid()) @db.Uuid
  organizationId       String    @map("organization_id") @db.Uuid
  storeId              String    @map("store_id") @db.Uuid
  trendyolSerialNumber String    @map("trendyol_serial_number")
  periodStart          DateTime  @map("period_start")
  periodEnd            DateTime  @map("period_end")
  totalNet             Decimal   @map("total_net") @db.Decimal(14, 2)
  totalVat             Decimal   @map("total_vat") @db.Decimal(14, 2)
  paymentOrderId       BigInt?   @map("payment_order_id")
  paymentDate          DateTime? @map("payment_date")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  store      Store       @relation(fields: [storeId], references: [id], onDelete: Cascade)
  // PR-3'te eklendi: OrderItem.commissionInvoiceId FK ile birlikte iki yönlü relation.
  orderItems OrderItem[]

  @@unique([storeId, trendyolSerialNumber])
  @@index([organizationId, periodStart])
  @@map("commission_invoices")
}

// PR-C1: Trendyol webhook event idempotency log + raw audit trail.
//
// Trendyol payload'da explicit event ID yok (webhook-model.md). Idempotency key
// = composite (storeId, platformOrderId, platformStatus, platformLastModifiedDate).
// Re-delivery (5dk Trendyol retry) aynı timestamp ile gelir; INSERT P2002 →
// 200 OK return, no downstream call.
//
// `rawPayload` jsonb full audit trail — Trendyol payload yapısı değişirse veya
// edge case debugging gerekirse log'tan inceleyebiliriz. 90 gün retention
// (env-configurable WEBHOOK_EVENT_RETENTION_DAYS), enforced by the daily
// webhook-event-cleanup tick in apps/sync-worker.
//
// RLS: org-scoped SELECT (admin/owner debugging için). INSERT/UPDATE/DELETE
// yalnız service role (webhook handler postgres role kullanır).
model WebhookEvent {
  id                       String    @id @default(uuid()) @db.Uuid
  organizationId           String    @map("organization_id") @db.Uuid
  storeId                  String    @map("store_id") @db.Uuid
  platform                 Platform
  // Composite idempotency components
  platformOrderId          String    @map("platform_order_id")
  platformStatus           String    @map("platform_status") // raw Trendyol status (mapping öncesi)
  platformLastModifiedDate DateTime  @map("platform_last_modified_date")
  // Processing meta
  receivedAt               DateTime  @default(now()) @map("received_at")
  processedAt              DateTime? @map("processed_at")
  processingError          String?   @map("processing_error")
  // Queue fields (Paket D): the route lease and the sync-worker consumer tick
  // coordinate through these to make concurrent double-processing structurally
  // impossible. `processAttempts` counts lease attempts so the consumer can give
  // up after a cap (terminal → stamp processedAt). `nextProcessAt` gates
  // eligibility: null = processable now; a future timestamp = a held lease or a
  // backoff delay before the next retry, so a scanner skips the row until then.
  processAttempts          Int       @default(0) @map("process_attempts")
  nextProcessAt            DateTime? @map("next_process_at")
  // Full payload (jsonb) — debugging + forward-compat
  rawPayload               Json      @map("raw_payload")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  store        Store        @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@unique([storeId, platformOrderId, platformStatus, platformLastModifiedDate], name: "webhook_event_idempotency_key")
  @@index([organizationId, receivedAt(sort: Desc)])
  @@index([storeId, receivedAt(sort: Desc)])
  @@map("webhook_events")
}

// ─── Live Performance buffer (Spec 2 PR-A) ─────────────────────────────
// Cost-eksik bugünkü siparişlerin grace-period buffer'ı (cost-driven storage
// discipline'ın yumuşatıcısı — bkz docs/superpowers/specs/2026-05-27-...).
// Webhook receiver (PR-B) buraya yazar; cost-attach (PR-D) cost geldiğinde
// PROMOTING'e çevirir; promote worker (PR-C) orders'a taşıyıp satırı siler.
// store_id taşır → RLS can_access_store(store_id) (orders / sync_logs ile
// aynı, #218). rawPayload + mappedOrder: promote anında orders INSERT'i için
// webhook payload'u + mapper çıktısı saklanır (yeniden fetch gerekmez).
model LivePerformanceBuffer {
  id                  String            @id @default(uuid()) @db.Uuid
  organizationId      String            @map("organization_id") @db.Uuid
  storeId             String            @map("store_id") @db.Uuid
  orderDate           DateTime          @map("order_date") @db.Date
  platformOrderId     String            @map("platform_order_id")
  platformOrderNumber String            @map("platform_order_number")
  rawPayload          Json              @map("raw_payload")
  mappedOrder         Json              @map("mapped_order")
  status              BufferEntryStatus @default(PENDING)
  attempts            Int               @default(0)
  lastError           String?           @map("last_error")
  lastFailedAt        DateTime?         @map("last_failed_at")
  createdAt           DateTime          @default(now()) @map("created_at")
  updatedAt           DateTime          @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  store        Store        @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@unique([storeId, platformOrderId])
  @@index([storeId, orderDate])
  @@index([status, lastFailedAt])
  @@index([organizationId])
  @@map("live_performance_buffer")
}

// ─── Fiyat Yazma Denetim Kaydı (trendyol-price-write) ─────────────────
// Trendyol'a yazılan her fiyat değişikliği için audit trail.
// organizationId denormalize edilir — RLS'in is_org_member() çağrısıyla
// parent join olmadan doğrudan filtre yapabilmesi için (42P17 döngüsünü önler).
// userId: aksiyonu tetikleyen kullanıcının auth.users UUID'si (sadece referans,
// FK kısıtı yok — UserProfile silindi→log kaybolmasın).
// Writes yalnız service role (backend postgres bağlantısıyla); authenticated
// INSERT/UPDATE/DELETE policy YOK → default-deny.
model PriceChangeLog {
  id               String            @id @default(uuid()) @db.Uuid
  organizationId   String            @map("organization_id") @db.Uuid
  storeId          String            @map("store_id") @db.Uuid
  variantId        String            @map("variant_id") @db.Uuid
  userId           String            @map("user_id") @db.Uuid
  platform         Platform
  barcode          String
  oldSalePrice     Decimal           @map("old_sale_price") @db.Decimal(12, 2)
  newSalePrice     Decimal           @map("new_sale_price") @db.Decimal(12, 2)
  listPrice        Decimal?          @map("list_price") @db.Decimal(12, 2)
  trendyolBatchId  String?           @map("trendyol_batch_id")
  status           PriceChangeStatus @default(PENDING)
  errorCode        String?           @map("error_code")
  createdAt        DateTime          @default(now()) @map("created_at")
  updatedAt        DateTime          @updatedAt @map("updated_at")

  organization Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  store        Store           @relation(fields: [storeId], references: [id], onDelete: Cascade)
  variant      ProductVariant  @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([storeId, createdAt(sort: Desc)])
  @@index([variantId, createdAt(sort: Desc)])
  @@map("price_change_logs")
}
