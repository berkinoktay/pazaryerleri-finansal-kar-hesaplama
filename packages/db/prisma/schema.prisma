// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ───────────────────────────────────────────

enum MemberRole {
  OWNER
  ADMIN
  MEMBER
  VIEWER
}

enum Platform {
  TRENDYOL
  HEPSIBURADA
}

// FeeDefinition kapsamı — `Platform`'tan AYRI tutulur (denetim A, 2026-06-14).
// Stores/Orders gerçek bir pazaryerine bağlıdır (TRENDYOL | HEPSIBURADA) ve bu
// alanları `z.enum(Platform)` doğrular. Ücret tanımları ise pazaryeri-bağımsız
// olabilir: e-ticaret stopajı ve komisyon KDV oranı TÜM pazaryerlerinde aynıdır
// → `ALL`. `ALL`'ı `Platform`'a eklemek stores/orders/adapter/UI switcher'a
// sızar (platform='ALL' bir mağaza kabul edilirdi). Bu yüzden ayrı enum.
enum FeeScope {
  TRENDYOL
  HEPSIBURADA
  ALL
}

enum StoreEnvironment {
  PRODUCTION
  SANDBOX
}

enum StoreStatus {
  ACTIVE
  CONNECTION_ERROR
  DISABLED
}

enum OrderStatus {
  PENDING
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
  RETURNED
}

enum SettlementStatus {
  PENDING
  VERIFIED
  DISCREPANCY
}

enum SettlementItemType {
  SALE
  RETURN
  COMMISSION
  SHIPPING
  SERVICE_FEE
  PROMOTION
  OTHER
}

enum ExpenseCategory {
  PRODUCT_COST
  ADVERTISING
  PACKAGING
  SHIPPING_SUPPLY
  SOFTWARE
  PERSONNEL
  RENT
  OTHER
}

enum SyncType {
  ORDERS
  PRODUCTS
  // Hourly lightweight stock+price walk via Trendyol inventory-and-price; full PRODUCTS scan remains the daily metadata reconciliation.
  PRODUCTS_DELTA
  SETTLEMENTS
  CLAIMS
}

enum SyncStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
  FAILED_RETRYABLE
}

enum SyncErrorCode {
  MARKETPLACE_AUTH_FAILED
  MARKETPLACE_ACCESS_DENIED
  MARKETPLACE_UNREACHABLE
  SYNC_IN_PROGRESS
  RATE_LIMITED
  VALIDATION_ERROR
  INTERNAL_ERROR
}

// Who initiated a SyncLog run. MANUAL = a user clicked "senkronize et";
// CRON = a scheduled pg_cron fan-out; BOOTSTRAP = the store-connect initial
// sync chain. Only MANUAL rows count toward the per-store manual-trigger
// cooldown — scheduled/bootstrap fan-outs must never block a user's refresh.
enum SyncTriggerSource {
  MANUAL
  CRON
  BOOTSTRAP
}

enum CostProfileType {
  COGS
  PACKAGING
  SHIPPING
  SOFTWARE
  MARKETING
  OTHER
}

enum Currency {
  TRY
  USD
  EUR
}

enum FxRateMode {
  AUTO
  MANUAL
}

enum ShippingTariffSource {
  TRENDYOL_CONTRACT
  OWN_CONTRACT
}

// Marketplace komisyon tarifesi kuralı türü. CATEGORY yalnız kategori bazlı;
// CATEGORY_BRAND ek olarak marka kırılımı içerir. Trendyol'un "matching rules
// → en düşüğü uygulanır" mantığı için iki türü tek tabloda toplayıp app-layer'da
// MIN() üzerinden resolve ediyoruz.
enum CommissionRuleKind {
  CATEGORY
  CATEGORY_BRAND
}

// Sipariş mutabakat durumu — kar hesaplama V1 (docs/plans/2026-05-18-profit-calculation-design.md §3.1).
// NOT_SETTLED: ESTIMATE OrderFee'ler yazılı, henüz SETTLEMENT yok.
// PARTIALLY_SETTLED: Bazı SETTLEMENT/CARGO_INVOICE OrderFee'ler var, Sale.paymentOrderId henüz null.
// FULLY_SETTLED: Sale paymentOrderId dolu, settledNetProfit yazıldı.
enum ReconciliationStatus {
  NOT_SETTLED
  PARTIALLY_SETTLED
  FULLY_SETTLED
}

// Kâr-dışı bırakma gerekçesi (spec 2026-06-12 cost-deadline-profit-freeze §5).
// Order.profitExclusionReason ile birlikte yaşar — bkz. Order modelindeki blok.
enum ProfitExclusionReason {
  COST_DEADLINE_MISSED // gece-yarısı flush'ı — pencere kaçtı
  LATE_UNCOSTED_ARRIVAL // geçmiş-gün gelen maliyetsiz sipariş (karar K3)
  LEGACY_BACKFILL // spec öncesi null-kârla yazılmış mevcut satırlar (migration)
}

// OrderFee tipi — pazaryeri ücretlerinin tek kaynağı (design §3.3).
// İki kategori: sipariş-düzeyi (OrderFee tablosuna yazılır) ve org-düzeyi
// (OrgPeriodFee tablosuna yazılır — Reklam, Penalty, Notification, COMMISSION_INVOICE).
// PLATFORM_SERVICE + PLATFORM_SERVICE_FAST ayrı FeeDefinition row'larıyla seçilir;
// FAST yalnızca fastDelivery=true + deliveredOnTime=true durumda uygulanır (§3.4).
enum OrderFeeType {
  SHIPPING
  PLATFORM_SERVICE
  PLATFORM_SERVICE_FAST
  STOPPAGE
  RETURN_SHIPPING
  REFUND_DEDUCTION
  COMMISSION_REFUND
  COST_RETURN
  STOPPAGE_REFUND
  PROVISION_ADJUSTMENT
  MANUAL_REFUND
  REVENUE_ADJUSTMENT
  COMMISSION_ADJUSTMENT
  CUSTOM
  ADVERTISING
  PENALTY_DEFECTIVE
  PENALTY_WRONG_PRODUCT
  PENALTY_MISSING_PRODUCT
  PENALTY_LATE_DELIVERY
  PENALTY_SUPPLY_FAILURE
  NOTIFICATION_FEE
  COMMISSION_INVOICE
  // Mikro ihracat (Order.micro=true) — marketplace ihracat siparişlerine özgü iki ücret:
  // INTERNATIONAL_SERVICE: ürün satışı üzerinden %6 KDV-dahil "Uluslararası Hizmet Bedeli"
  //   (PSF mikro ihracatta uygulanmaz; bunun yerine bu ücret kesilir). Tahmin yolunda yazılır.
  // OVERSEAS_RETURN_OPERATION: iadede satış reverse edilmez, ayrıca (satış−komisyon)×%35/%30
  //   "Yurt Dışı İade Operasyon Bedeli" kesilir (iade yolunda yazılır).
  INTERNATIONAL_SERVICE
  OVERSEAS_RETURN_OPERATION
}

// OrderFee'nin kaynağı — audit + reconciliation algoritması için kritik (§3.3).
// ESTIMATE: applyEstimateOnOrderCreate (T+0 deterministic).
// SETTLEMENT: settlements/otherfinancials API'sinden.
// CARGO_INVOICE: cargo-invoice/{serial}/items per-order match.
// USER_OVERRIDE: kullanıcı düzeltti. MANUAL_ENTRY: kullanıcı ekledi (reklam vs.).
enum OrderFeeSource {
  ESTIMATE
  SETTLEMENT
  CARGO_INVOICE
  USER_OVERRIDE
  MANUAL_ENTRY
}

enum OrderFeeDirection {
  DEBIT
  CREDIT
}

// FeeDefinition hesap türü — sistem-düzeyi ücret tanımları (§3.4).
// FIXED: sabit tutar (PSF ₺10.99). RATE_OF_SALE: satışın yüzdesi (Stopaj %1).
// FORMULA: V2'ye ertelendi (karmaşık formüller).
enum FeeCalculationKind {
  FIXED
  RATE_OF_SALE
  FORMULA
}

// Live Performance buffer entry durum makinesi (Spec 2 PR-A).
// PENDING (cost yok) → PROMOTING (cost geldi, promote worker bekliyor) →
// orders'a yazılıp buffer'dan DELETE (success) ya da FAILED → PERMANENT_FAILED.
enum BufferEntryStatus {
  PENDING
  PROMOTING
  FAILED
  PERMANENT_FAILED

  @@map("buffer_entry_status")
}

// Trendyol fiyat yazma denetim kaydı durumu (Task 1 — trendyol-price-write).
// PENDING: istek gönderildi, batchId alındı, yoklama bekleniyor.
// SUCCESS: yoklama COMPLETED + item status SUCCESS → DB write-back yapıldı.
// FAILED: yoklama FAILED veya timeout → DB write-back yapılmadı.
enum PriceChangeStatus {
  PENDING
  SUCCESS
  FAILED
}

// Flash Products (Flaş Ürünler) join type per item. A row offers up to two
// windows — H24 (24-hour slot) and H3 (3-hour slot). The seller picks one, or
// sets a custom price instead (customPrice, mutually exclusive). Emitted as a
// domain enum for the frontend column language ("24 Saatlik" / "3 Saatlik").
enum FlashOfferType {
  H24
  H3
}

// ─── Models ──────────────────────────────────────────

model UserProfile {
  id                String   @id @db.Uuid
  email             String   @unique
  fullName          String?  @map("full_name")
  avatarUrl         String?  @map("avatar_url")
  timezone          String   @default("Europe/Istanbul")
  preferredLanguage String   @default("tr") @map("preferred_language")
  preferences       Json     @default("{}") @map("preferences")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  memberships OrganizationMember[]

  @@map("user_profiles")
}

model Organization {
  id        String   @id @default(uuid()) @db.Uuid
  name      String
  slug      String   @unique
  currency  String   @default("TRY")
  timezone  String   @default("Europe/Istanbul")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  members               OrganizationMember[]
  stores                Store[]
  expenses              Expense[]
  syncLogs              SyncLog[]
  costProfiles          CostProfile[]
  webhookEvents         WebhookEvent[]
  memberStoreAccess     MemberStoreAccess[]
  livePerformanceBuffer LivePerformanceBuffer[]
  catalogBarcodeMisses  CatalogBarcodeMiss[]
  priceChangeLogs       PriceChangeLog[]

  @@map("organizations")
}

model OrganizationMember {
  id             String     @id @default(uuid()) @db.Uuid
  organizationId String     @map("organization_id") @db.Uuid
  userId         String     @map("user_id") @db.Uuid
  role           MemberRole @default(MEMBER)
  lastAccessedAt DateTime?  @map("last_accessed_at")
  createdAt      DateTime   @default(now()) @map("created_at")
  updatedAt      DateTime   @updatedAt @map("updated_at")

  organization Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         UserProfile         @relation(fields: [userId], references: [id], onDelete: Cascade)
  storeAccess  MemberStoreAccess[]

  @@unique([organizationId, userId])
  @@index([userId, lastAccessedAt(sort: Desc)], map: "idx_org_members_user_last_accessed")
  @@map("organization_members")
}

model Store {
  id                       String               @id @default(uuid()) @db.Uuid
  organizationId           String               @map("organization_id") @db.Uuid
  name                     String
  platform                 Platform
  environment              StoreEnvironment     @default(PRODUCTION)
  externalAccountId        String               @map("external_account_id")
  credentials              Json
  status                   StoreStatus          @default(ACTIVE)
  isActive                 Boolean              @default(true) @map("is_active")
  lastConnectedAt          DateTime?            @map("last_connected_at")
  lastSyncAt               DateTime?            @map("last_sync_at")
  shippingTariffSource     ShippingTariffSource @default(TRENDYOL_CONTRACT) @map("shipping_tariff_source")
  defaultShippingCarrierId String?              @map("default_shipping_carrier_id") @db.Uuid
  // Mağaza-bazlı kâr formülü ayarları (JSONB, genişletilebilir — UserProfile.preferences deseni).
  // Şekil: { includeStopaj?: boolean, includeNegativeNetVat?: boolean }. Boş {} = varsayılanlar
  // (@pazarsync/utils resolveProfitSettings ile çözülür: includeStopaj=true, includeNegativeNetVat=false).
  // SNAPSHOT-AT-CREATE: bu CANLI ayardır; sipariş ilk hesaplanırken Order.snapshot* kolonlarına
  // snapshot'lanır, sonraki hesaplar snapshot'ı okur (bu kolonu DEĞİL). Geçmiş sipariş asla
  // yeniden hesaplanmaz — ayar değişimi yalnız BUNDAN SONRA oluşan siparişleri etkiler.
  profitSettings           Json                 @default("{}") @map("profit_settings")
  // ─── PR-C1: Trendyol webhook subscription ───────────────────────────
  // webhookId: Trendyol'un atadığı subscription UUID (POST /webhooks response.id).
  //   PUT/DELETE call'larında kullanılır. Register fail'de null kalır.
  // webhookSecret: AES-256-GCM ciphertext (base64) of JSON.stringify({username, password}).
  //   Random generated at register; decrypt only inside verify middleware.
  // webhookActiveAt: son register/rotate timestamp. UI badge "webhook bağlı" göstergesi.
  // Üçü de nullable: mevcut store'lar geriye dönük register zorunda değil; failed
  // register transient olabilir; non-TRENDYOL platformlarda da null kalır.
  webhookId                String?              @map("webhook_id")
  webhookSecret            String?              @map("webhook_secret")
  webhookActiveAt          DateTime?            @map("webhook_active_at")
  createdAt                DateTime             @default(now()) @map("created_at")
  updatedAt                DateTime             @updatedAt @map("updated_at")

  organization           Organization            @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  products               Product[]
  productVariants        ProductVariant[]
  orders                 Order[]
  expenses               Expense[]
  costProfiles           CostProfile[]
  settlements            Settlement[]
  syncLogs               SyncLog[]
  webhookEvents          WebhookEvent[]
  defaultShippingCarrier ShippingCarrier?        @relation(fields: [defaultShippingCarrierId], references: [id], onDelete: SetNull)
  ownShippingTariffs     OwnShippingTariff[]
  commissionTariffs      CommissionTariff[]
  plusCommissionTariffs  PlusCommissionTariff[]
  advantageTariffs       AdvantageTariff[]
  flashProductLists      FlashProductList[]
  orgPeriodFees          OrgPeriodFee[]
  commissionInvoices     CommissionInvoice[]
  memberAccess           MemberStoreAccess[]
  livePerformanceBuffer  LivePerformanceBuffer[]
  orderClaims            OrderClaim[]
  catalogBarcodeMisses   CatalogBarcodeMiss[]
  priceChangeLogs        PriceChangeLog[]

  @@unique([organizationId, platform, externalAccountId])
  @@index([organizationId])
  @@map("stores")
}

// ─── Member ↔ Store access grants ──────────────────────────────────────
// Which stores a MEMBER/VIEWER may see. OWNER/ADMIN see every store in their
// org by role and need NO rows here (enforced in can_access_store + services).
// A grant is scoped to a membership: deleting the member cascades its grants.
// organization_id is denormalized for flat RLS + indexing (same pattern as
// products / sync_logs). granted_by is an audit pointer to the granting
// OrganizationMember.id (plain uuid, no FK — avoids a second self-relation).
model MemberStoreAccess {
  id             String   @id @default(uuid()) @db.Uuid
  organizationId String   @map("organization_id") @db.Uuid
  memberId       String   @map("member_id") @db.Uuid
  storeId        String   @map("store_id") @db.Uuid
  grantedBy      String?  @map("granted_by") @db.Uuid
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  member       OrganizationMember @relation(fields: [memberId], references: [id], onDelete: Cascade)
  store        Store              @relation(fields: [storeId], references: [id], onDelete: Cascade)
  organization Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([memberId, storeId])
  @@index([storeId])
  @@index([organizationId])
  @@map("member_store_access")
}

// Parent — one row per Trendyol contentId. Shared content fields
// (title, description, brand, category, color, images) live here. SKU-level
// fields (barcode, stockCode, price, stock, delivery, size) live on
// ProductVariant. The split mirrors how the marketplace itself models
// products and avoids lossy denormalization across N variants.
model Product {
  id                 String    @id @default(uuid()) @db.Uuid
  organizationId     String    @map("organization_id") @db.Uuid
  storeId            String    @map("store_id") @db.Uuid
  platformContentId  BigInt    @map("platform_content_id")
  productMainId      String    @map("product_main_id")
  title              String
  description        String?   @db.Text
  brandId            BigInt?   @map("brand_id")
  brandName          String?   @map("brand_name")
  categoryId         BigInt?   @map("category_id")
  categoryName       String?   @map("category_name")
  color              String?
  attributes         Json      @default("[]")
  approved           Boolean   @default(true)
  platformCreatedAt  DateTime? @map("platform_created_at")
  platformModifiedAt DateTime? @map("platform_modified_at")
  lastSyncedAt       DateTime  @default(now()) @map("last_synced_at")
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")

  // Denormalized SUM(variants[*].quantity) for the store. Updated
  // transactionally inside upsertBatch in the sync worker — see
  // apps/sync-worker/src/handlers/products.ts. Indexed for the
  // products-list sort=totalStock workflow (pricing + restock review).
  totalStock Int @default(0) @map("total_stock")

  // Denormalized MIN/MAX(variants[*].salePrice) for the store, updated in the
  // same upsertBatch transaction as totalStock (NOT a trigger — the sync worker
  // stays the single writer). Prisma 7 cannot MAX() over a Decimal child
  // relation in orderBy, so products-list sort=salePrice reads these columns,
  // and the salePrice range filter (PR-B2) tests overlap against both bounds.
  // NULL only for a product with zero variants. No @updatedAt (data columns).
  minSalePrice Decimal? @map("min_sale_price") @db.Decimal(12, 2)
  maxSalePrice Decimal? @map("max_sale_price") @db.Decimal(12, 2)

  store    Store            @relation(fields: [storeId], references: [id], onDelete: Cascade)
  variants ProductVariant[]
  images   ProductImage[]

  @@unique([storeId, platformContentId])
  @@index([organizationId])
  @@index([storeId, productMainId])
  @@index([storeId, brandId])
  @@index([storeId, totalStock])
  @@index([storeId, minSalePrice, maxSalePrice])
  @@index([storeId, categoryId])
  @@map("products")
}

// Child — one row per Trendyol variantId (SKU). organizationId is denormalized
// here so the RLS policy can be a flat `is_org_member(organization_id)` USING
// clause without recursing through Product (avoids the 42P17 trap, see
// supabase/sql/rls-policies.sql for the full rationale).
model ProductVariant {
  id                      String   @id @default(uuid()) @db.Uuid
  organizationId          String   @map("organization_id") @db.Uuid
  storeId                 String   @map("store_id") @db.Uuid
  productId               String   @map("product_id") @db.Uuid
  platformVariantId       BigInt   @map("platform_variant_id")
  barcode                 String
  stockCode               String   @map("stock_code")
  salePrice               Decimal  @map("sale_price") @db.Decimal(12, 2)
  listPrice               Decimal  @map("list_price") @db.Decimal(12, 2)
  vatRate                 Int?     @map("vat_rate")
  costPrice               Decimal? @map("cost_price") @db.Decimal(12, 2)
  // PSF muafiyet kuralı: tüm OrderItem'larda isDigital=true → PSF=0 (design §3.7).
  // V1: kullanıcı UI'dan işaretler (variant settings toggle). V2: Trendyol kategori
  // lookup ile otomatik tahmin.
  isDigital               Boolean  @default(false) @map("is_digital")
  // Two-column sync-protection pair (see docs/plans/archive/... for rationale):
  // syncedDimensionalWeight is the marketplace's value, refreshed every sync.
  // dimensionalWeight is the user's manual override; null = no override, fall
  // back to synced at read time. The sync worker writes ONLY to the synced
  // column — never to dimensionalWeight — so the "user value is sacred"
  // invariant is structural, not just enforced in code.
  //
  // Desi floor = 0: the synced column is NON-NULL with default 0. Trendyol
  // omits desi on most products; the mapper stores 0 (not null) so the
  // products page shows 0 and the data has no nulls. Desi 0 is a VALID tariff
  // tier — cargo fee is matched from the tariff table (carrier + ceil(desi)),
  // which covers desi 0 onward, so a 0-desi variant still gets a real cargo
  // cost. The override stays nullable (null = "no override"). A CHECK
  // constraint forbids any value below 0 on either column (see migration
  // dimensional_weight_zero_floor).
  syncedDimensionalWeight Decimal  @default(0) @map("synced_dimensional_weight") @db.Decimal(6, 2)
  dimensionalWeight       Decimal? @map("dimensional_weight") @db.Decimal(6, 2)
  quantity                Int      @default(0)
  deliveryDuration        Int?     @map("delivery_duration")
  isRushDelivery          Boolean  @default(false) @map("is_rush_delivery")
  fastDeliveryOptions     Json     @default("[]") @map("fast_delivery_options")
  productUrl              String?  @map("product_url") @db.Text
  locationBasedDelivery   String?  @map("location_based_delivery")
  onSale                  Boolean  @default(true) @map("on_sale")
  archived                Boolean  @default(false)
  // Stamped when a COMPLETE full catalog scan no longer returns this variant
  // (absence-from-feed), cleared on reappearance; never hard-delete because
  // order history references variants.
  delistedAt              DateTime? @map("delisted_at")
  blacklisted             Boolean  @default(false)
  locked                  Boolean  @default(false)
  size                    String?
  attributes              Json     @default("[]")
  lastSyncedAt            DateTime @default(now()) @map("last_synced_at")
  createdAt               DateTime @default(now()) @map("created_at")
  updatedAt               DateTime @updatedAt @map("updated_at")

  product          Product                     @relation(fields: [productId], references: [id], onDelete: Cascade)
  store            Store                       @relation(fields: [storeId], references: [id], onDelete: Cascade)
  orderItems       OrderItem[]
  costProfileLinks ProductVariantCostProfile[]
  priceChangeLogs  PriceChangeLog[]

  @@unique([storeId, platformVariantId])
  // Intentionally NOT unique on (storeId, barcode): marketplaces enforce
  // barcode uniqueness on their side at listing time, but their sandbox
  // and certain real-world catalogs ship variants with duplicate
  // barcodes (different platformVariantId, same printed barcode — e.g.
  // multi-pack vs single-unit variants of the same SKU). Treating
  // barcode as unique at our layer caused 3 product upserts to fail per
  // sync against the dev/sandbox account; the products were silently
  // dropped via skip-on-error in apps/sync-worker/src/handlers/products.ts.
  // Lookups by barcode (e.g. order item resolution) are non-unique in
  // principle anyway — we resolve via platformVariantId.
  @@index([storeId, barcode])
  @@index([organizationId])
  @@index([productId])
  @@index([storeId, stockCode])
  @@index([storeId, onSale, archived])
  @@index([storeId, delistedAt])
  @@map("product_variants")
}

model ProductImage {
  id             String   @id @default(uuid()) @db.Uuid
  organizationId String   @map("organization_id") @db.Uuid
  productId      String   @map("product_id") @db.Uuid
  url            String   @db.Text
  position       Int      @default(0)
  createdAt      DateTime @default(now()) @map("created_at")

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId, position])
  @@map("product_images")
}

model Order {
  id              String      @id @default(uuid()) @db.Uuid
  organizationId  String      @map("organization_id") @db.Uuid
  storeId         String      @map("store_id") @db.Uuid
  platformOrderId String      @map("platform_order_id")
  orderDate       DateTime    @map("order_date")
  status          OrderStatus
  // ESKİ ÜCRET KOLONLARI (totalAmount, commissionAmount, shippingCost, platformFee,
  // vatAmount, netProfit) PR-5c'de SİLİNDİ (2026-05-19). Yeni convention için:
  // - Satış: saleSubtotalNet + saleVatTotal (aşağıda PR-5a)
  // - Komisyon: OrderItem.grossCommissionAmountNet/VatAmount (PR-3)
  // - Kargo/PSF/Stopaj: OrderFee tablosunda (PR-1)
  // - Kar: estimatedNetProfit / settledNetProfit (PR-5a, write-once + mutable)

  // Trendyol data-input alanları (sync handler PR-6'da set eder, design §3.1).
  // agreedDeliveryDate: getShipmentPackages endpoint direkt field.
  // actualDeliveryDate: packageHistories[status='Delivered'].createdAt'den türetilir;
  //   Delivered status webhook'unda set'lenir. Order endpoint'te direkt field YOK.
  agreedDeliveryDate DateTime? @map("agreed_delivery_date")
  actualDeliveryDate DateTime? @map("actual_delivery_date")
  // actualShipDate: packageHistories[status='Shipped'].createdDate — "taşıma durumuna
  //   geçiş" anı (RAW GMT). SameDayShipping PSF kriterinin (aynı-gün sevk, 2026-06-14)
  //   tabanı. NOT: originShipmentDate = kargoya-hazır anı (≈ sipariş) → gerçek sevk DEĞİL.
  actualShipDate     DateTime? @map("actual_ship_date")
  // estimatedDelivery{Start,End}Date: getShipmentPackages tahmini teslim penceresi.
  //   PROD'da dolu (2026-06-14 gözlem 11314118846); stage test siparişlerinde 0 → null.
  estimatedDeliveryStartDate DateTime? @map("estimated_delivery_start_date")
  estimatedDeliveryEndDate   DateTime? @map("estimated_delivery_end_date")
  // fastDelivery: getShipmentPackages direkt boolean (Bugün Kargoda indikatörü).
  // fastDeliveryType: "TodayDelivery"|"SameDayShipping"|"FastDelivery" — sipariş
  //   seviyesinde yalnız PROD'da dolar (stage "" → null). Per-tip kriterin kaynağı
  //   (hibrit tasarım 2026-06-14): "fast mı + tip" siparişten, cutoff üründen.
  // micro: getShipmentPackages direkt boolean (mikro ihracat) — PSF muafiyeti.
  fastDelivery       Boolean   @default(false) @map("fast_delivery")
  fastDeliveryType   String?   @map("fast_delivery_type")
  micro              Boolean   @default(false) @map("micro")

  // ─── GROSS konvansiyon: sipariş-seviyesi agregat alanlar (2026-06-16) ──────
  // Paket toplamları mapper'dan doğrudan gelir (Trendyol packageGrossAmount/
  // packageTotalPrice/packageSellerDiscount). saleVat satır-bazlı hesaplanır
  // (Σ lineSaleGross × saleVatRate / (100+rate)). sellerDiscountVat aynı pattern.
  // listGross = saleGross + sellerDiscountGross. Eski saleSubtotalNet/saleVatTotal
  // GROSS refactor kapsamında kaldırıldı (2026-06-16).
  saleGross              Decimal? @map("sale_gross") @db.Decimal(12, 2)
  saleVat                Decimal? @map("sale_vat") @db.Decimal(12, 2)
  listGross              Decimal? @map("list_gross") @db.Decimal(12, 2)
  sellerDiscountGross    Decimal? @map("seller_discount_gross") @db.Decimal(12, 2)
  sellerDiscountVat      Decimal? @map("seller_discount_vat") @db.Decimal(12, 2)

  // Marj yüzdeleri — backend hesaplanıp persist edilir (sıralanabilir + kayıtlı).
  // estimatedSaleMarginPct = estimatedNetProfit / saleGross × 100 (saleGross=0→null).
  // settledSaleMarginPct   = settledNetProfit  / saleGross × 100.
  // estimatedCostMarkupPct = estimatedNetProfit / Σ costGross × 100.
  // settledCostMarkupPct   = settledNetProfit  / Σ costGross × 100.
  estimatedSaleMarginPct Decimal? @map("estimated_sale_margin_pct") @db.Decimal(8, 4)
  settledSaleMarginPct   Decimal? @map("settled_sale_margin_pct") @db.Decimal(8, 4)
  estimatedCostMarkupPct Decimal? @map("estimated_cost_markup_pct") @db.Decimal(8, 4)
  settledCostMarkupPct   Decimal? @map("settled_cost_markup_pct") @db.Decimal(8, 4)

  // Promosyon gösterimi (YAGNI — spec ekleme #3). Opsiyonel JSON dizisi:
  // [{ "displayName": "Satıcı İndirimi", "amountGross": "48.01" }, ...].
  // Mapper null döner indirim yoksa; upsert null'a dokunmaz.
  promotionDisplays      Json?    @map("promotion_displays")

  // İki aşamalı kar (design §4.1):
  // - estimatedNetProfit: T+0 applyEstimateOnOrderCreate yazar, write-once (PR-9 trigger).
  // - settledNetProfit:   T+~5+ recomputeSettledProfit yazar, mutable (iade güncellemeleri).
  //
  // INVARIANT (2026-06-14 karar — Hakediş Kontrolü temeli): İKİSİ DE satıcının
  // HAK ETTİĞİ net kârdır (effectiveSale + Trendyol'un yetkili komisyon/kargosu,
  // doğru oranlarla). Trendyol'un GERÇEKTE ÖDEDİĞİ tutar DEĞİLDİR. Bu kolonlar
  // ASLA underpaid bir actual-payout'a sessizce ÇEKİLMEZ. Beklenen (bu kolonlar)
  // vs gerçek-yatan (Trendyol payout) farkı = gelecek "Hakediş Kontrolü" epiği;
  // farkı itiraz-edilebilir kalem olarak gösterir, satıcı İtiraz/Göz ardı seçer.
  // "Çek" kararı satıcınındır, sistemin değil. (OrderItem.settledSaleAmount =
  // mutabakatın actual-satış çıpası.)
  estimatedNetProfit   Decimal?             @map("estimated_net_profit") @db.Decimal(12, 2)
  settledNetProfit     Decimal?             @map("settled_net_profit") @db.Decimal(12, 2)

  // Net KDV (output − input KDV) — computeProfit'in ürettiği netVat. estimatedNetProfit /
  // settledNetProfit ile AYNI yaşam döngüsü (estimate refinable, settled mutable; ikisi de
  // profit-excluded'da yazılmaz → null kalır). Frontend kâr dökümünde "Net KDV" satırını
  // backend-hesaplı gösterir (frontend ASLA türetmez). Net KDV negatif olabilir → CHECK yok.
  estimatedNetVat      Decimal?             @map("estimated_net_vat") @db.Decimal(12, 2)
  settledNetVat        Decimal?             @map("settled_net_vat") @db.Decimal(12, 2)

  // ─── Kâr formülü ayar snapshot'ı (snapshot-at-create, forward-only) ──────
  // applyEstimateOnOrderCreate sipariş İLK hesaplanırken mağazanın o anki
  // Store.profitSettings'ini çözüp buraya YAZAR (write-once). Sonraki TÜM hesaplar
  // (kargo rafinesi re-entry + settlement recompute) bu snapshot'ı okur, canlı ayarı
  // DEĞİL. Mağaza ayarı değişince yalnız BUNDAN SONRA yaratılan siparişler etkilenir;
  // geçmiş sipariş asla yeniden hesaplanmaz (maliyet snapshot'ıyla aynı felsefe).
  // Nullable: snapshot henüz yazılmamış / kâr-dışı sipariş = null; okurken null →
  // @pazarsync/utils DEFAULT_PROFIT_SETTINGS (resolveSnapshotProfitSettings).
  snapshotIncludeStopaj         Boolean?            @map("snapshot_include_stopaj")
  snapshotIncludeNegativeNetVat Boolean?            @map("snapshot_include_negative_net_vat")

  // ─── Kâr dondurma (spec 2026-06-12 cost-deadline-profit-freeze) ──────
  // Maliyet penceresi (sipariş gününün sonu, İstanbul) kaçırıldıysa sipariş
  // KALICI olarak kâr evreninin dışında: estimatedNetProfit sonsuza dek null,
  // settledNetProfit hesaplanmaz (karar K1); ciro raporlanır. Geri dönüş yok —
  // reject_profit_freeze_breach trigger'ı + CHECK her yolu kapatır.
  profitExcludedAt      DateTime?              @map("profit_excluded_at")
  profitExclusionReason ProfitExclusionReason? @map("profit_exclusion_reason")

  // Durum makinesi: NOT_SETTLED → PARTIALLY_SETTLED → FULLY_SETTLED (design §6.1).
  // İlk SETTLEMENT/CARGO_INVOICE OrderFee yazıldığında PARTIALLY_SETTLED, Sale
  // satırının paymentOrderId'si dolu görüldüğünde FULLY_SETTLED.
  reconciliationStatus ReconciliationStatus @default(NOT_SETTLED) @map("reconciliation_status")

  // PaymentOrder bağlantısı — mutabakat sinyali (§3.7). Sale.paymentOrderId dolu
  // görüldüğünde Order'a yansıtılır → handlePaymentOrderEntry tetiklenir →
  // cycle'daki PSF/Stopaj ESTIMATE'leri SETTLEMENT'a confirm + recomputeSettledProfit.
  paymentOrderId BigInt?   @map("payment_order_id")
  paymentDate    DateTime? @map("payment_date")

  // Türetilmiş: actualDeliveryDate <= agreedDeliveryDate → true (Bugün Kargoda PSF).
  // applyEstimate hesaplaması: inferDeliveredOnTime(order) — null = henüz delivered değil.
  deliveredOnTime Boolean? @map("delivered_on_time")

  // Trendyol orderNumber (üst sipariş, paket-üstü). platformOrderId = shipmentPackageId
  // (paket-seviyesi); platformOrderNumber = orderNumber (split shipment'ta N pakete
  // referans verir). PR-5b veri taşıma mevcut yanlış dolu rows'u doğrultur (§9 PR-5b).
  platformOrderNumber String? @map("platform_order_number")

  // ─── PR-8: Kargo alanları (research 2026-06-09) ─────────────────────
  // cargoTrackingNumber: paket OLUŞURKEN atanır (kargoya verilmeden); kargo
  //   faturası satırındaki parcelUniqueId ile BİREBİR AYNI (prod kanıtlı) —
  //   fatura→sipariş eşleştirmesinin birincil anahtarı. İlk 3 hane kargocu
  //   önekidir (733 TEX, 725 Yurtiçi, 734 PTT, 884 Horoz, 732 Alternatif).
  // cargoDeci: Trendyol'un ÖLÇTÜĞÜ desi — tahmin-vs-fatura karşılaştırmasının
  //   zemini. Stage'de hiç gelmez, prod'da kargo ölçümünden sonra dolar →
  //   upsert UPDATE'i gelen null ile dolu değeri EZMEZ.
  // usesSellerCargoAgreement: Trendyol whoPays==1 → satıcının KENDİ kargo
  //   anlaşması: Trendyol kargo faturası KESMEZ, maliyet bizim satıcı-anlaşma
  //   tarifemizden gelir. Alan yoksa Trendyol anlaşması (fatura bekleriz).
  // platformCreatedBy: paket kaynağı ("order-creation" | "split" | "transfer"
  //   | ...) — split soy ağacı görünürlüğü.
  // originShipmentDate: kargoya-hazır anı (true UTC, RAW) — ship-time KPI.
  cargoProviderName        String?   @map("cargo_provider_name")
  cargoTrackingNumber      BigInt?   @map("cargo_tracking_number")
  cargoDeci                Decimal?  @map("cargo_deci") @db.Decimal(8, 2)
  usesSellerCargoAgreement Boolean   @default(false) @map("uses_seller_cargo_agreement")
  platformCreatedBy        String?   @map("platform_created_by")
  originShipmentDate       DateTime? @map("origin_shipment_date")

  // Marketplace-side lastModifiedDate of the most recent event / sync page applied
  // to this row. Used by the order upsert as an out-of-order guard: a stale webhook
  // re-delivery or a racing hourly-sync page must never regress status/fields already
  // written by a newer event. Nullable: legacy rows and buffer-JSONB replays without
  // the field skip the guard.
  platformLastModifiedAt DateTime? @map("platform_last_modified_at")

  // Set ONCE when the buffer-promote worker graduates a cost-missing buffer entry into
  // this orders row. Consumed by the live-performance notification summary so the frontend
  // can distinguish a promotion INSERT (an order the merchant already saw hours ago) from
  // a genuinely new order and suppress the duplicate "new order" toast. Null for orders
  // written directly by the webhook receiver or polling sync.
  promotedFromBufferAt DateTime? @map("promoted_from_buffer_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  store  Store        @relation(fields: [storeId], references: [id], onDelete: Cascade)
  items  OrderItem[]
  fees   OrderFee[]
  claims OrderClaim[]

  @@unique([storeId, platformOrderId])
  @@index([organizationId])
  @@index([organizationId, reconciliationStatus])
  @@index([orderDate])
  @@index([platformOrderNumber])
  @@index([storeId, paymentOrderId])
  // Kargo faturası eşleştirmesi: parcelUniqueId == cargoTrackingNumber lookup.
  @@index([storeId, cargoTrackingNumber])
  @@map("orders")
}

model OrderItem {
  id               String    @id @default(uuid()) @db.Uuid
  orderId          String    @map("order_id") @db.Uuid
  productVariantId String?   @map("product_variant_id") @db.Uuid
  organizationId   String?   @map("organization_id") @db.Uuid
  quantity         Int
  // PR-8: Trendyol satır kimliği (lines[].lineId) + ham barkod. platformLineId
  // platform-taraflı satır izi (aynı varianttan 2 ayrı satır ayrımı); barcode
  // variant eşleşmediğinde elde kalan tek ürün izi ("variant bulunamadı" UI'ı).
  platformLineId BigInt?   @map("platform_line_id")
  barcode        String?
  // Variant-resolution kuyruğu (spec 2026-06-11 §5): productVariantId NULL
  // satırlar için deneme sayacı + backoff vadesi. Tick yalnız vadesi gelmiş
  // satırları tarar; bağlanınca alanlar anlamını yitirir (sıfırlanmaz).
  variantResolutionAttempts Int       @default(0) @map("variant_resolution_attempts")
  nextResolutionAt          DateTime? @map("next_resolution_at")

  // ─── GROSS konvansiyon (2026-06-16) ────────────────────────────────────
  // Tüm para değerleri GROSS (KDV-dahil) olarak tutulur; net = gross × 100/(100+rate).
  // Trendyol paket toplamları gross olarak gelir → mapper artık bölüp çarpmaz.

  // Satış (gross + KDV oranı)
  // lineListGross: Trendyol lineListPrice × quantity — liste fiyatı toplamı.
  // lineSaleGross: Trendyol lineGrossAmount — satış toplamı (indirimler sonrası).
  // lineSellerDiscountGross: Trendyol lineSellerDiscount — satıcı indirimi (gross).
  // saleVatRate: ürün KDV oranı (varianttan veya kategori lookup'tan).
  lineListGross           Decimal @default(0) @map("line_list_gross") @db.Decimal(12, 2)
  lineSaleGross           Decimal @default(0) @map("line_sale_gross") @db.Decimal(12, 2)
  lineSellerDiscountGross Decimal @default(0) @map("line_seller_discount_gross") @db.Decimal(12, 2)
  saleVatRate             Decimal @default(0) @map("sale_vat_rate") @db.Decimal(5, 2)

  // Komisyon (gross + oran)
  // commissionRate: Trendyol per-line commission rate (%).
  // commissionGross: hesaplanan gross komisyon tutarı (effectiveSale × rate).
  // refundedCommissionGross: iade edilen komisyon (gross). default(0) = iade yok.
  // commissionVatRate: komisyon KDV oranı (DB-driven, default %20 — denetim A #331).
  // estimatedCommissionGross (write-once): T+0 tahmin — settlement gelince korunur.
  // settledCommissionGross (mutable): Trendyol'un Settlement'ta yazdığı gerçek değer.
  commissionRate           Decimal  @map("commission_rate") @db.Decimal(5, 2)
  commissionGross          Decimal  @default(0) @map("commission_gross") @db.Decimal(12, 2)
  refundedCommissionGross  Decimal  @default(0) @map("refunded_commission_gross") @db.Decimal(12, 2)
  commissionVatRate        Decimal  @default(20) @map("commission_vat_rate") @db.Decimal(5, 2)
  estimatedCommissionGross Decimal? @map("estimated_commission_gross") @db.Decimal(12, 2)
  settledCommissionGross   Decimal? @map("settled_commission_gross") @db.Decimal(12, 2)

  // Settlement ACTUAL çıpası — Trendyol'un Sale settlement'ta kredilediği GERÇEK
  // satış tutarı (KDV-dahil ham `credit`; handleSale yazar, T+~5). KÂRA GİRMEZ:
  // estimated/settled kâr HAK EDİLEN'den (effectiveSale) hesaplanır, bu kolondan
  // DEĞİL. Yalnız gelecek "Hakediş Kontrolü" mutabakatının çıpası — beklenen
  // (effectiveSale) vs gerçek (bu kolon) karşılaştırıp "eksik satış bedeli"
  // tespit edecek. Null: settlement gelmeden önce (2026-06-14 temel atımı).
  settledSaleAmount Decimal? @map("settled_sale_amount") @db.Decimal(12, 2)

  // Maliyet anlık kopyası (gross + KDV oranı).
  // Tümü nullable: maliyet snapshot eksik durumda kar hesabı null kalır.
  unitCostSnapshotGross   Decimal? @map("unit_cost_snapshot_gross") @db.Decimal(12, 2)
  unitCostSnapshotVatRate Decimal? @map("unit_cost_snapshot_vat_rate") @db.Decimal(5, 2)

  // Maliyet snapshot zamanı — write-once, variant bağlanınca set edilir.
  snapshotCapturedAt DateTime? @map("snapshot_captured_at")

  // Komisyon faturası referansı (design §3.8 iki aşamalı populate):
  // - serialNumber: Sale satırı T+~5'te direkt yazar (raw "DCF...").
  // - id: T+~7 Komisyon Faturası otherfinancials kaydı geldiğinde backfill FK.
  commissionInvoiceSerialNumber String? @map("commission_invoice_serial_number")
  commissionInvoiceId           String? @map("commission_invoice_id") @db.Uuid

  costSnapshotComponents OrderItemCostSnapshotComponent[]
  claimItems             OrderClaimItem[]

  order             Order              @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productVariant    ProductVariant?    @relation(fields: [productVariantId], references: [id], onDelete: SetNull)
  commissionInvoice CommissionInvoice? @relation(fields: [commissionInvoiceId], references: [id], onDelete: SetNull)

  @@index([organizationId, snapshotCapturedAt])
  @@index([commissionInvoiceId])
  // Resolution kuyruğu index'i PARTIAL (WHERE product_variant_id IS NULL) —
  // Prisma kısmi index yazamadığı için check-constraints.sql + migration
  // aynasında yaşar (order_items_resolution_due_idx).
  @@map("order_items")
}

model Settlement {
  id                   String           @id @default(uuid()) @db.Uuid
  organizationId       String           @map("organization_id") @db.Uuid
  storeId              String           @map("store_id") @db.Uuid
  platformSettlementId String?          @map("platform_settlement_id")
  periodStart          DateTime         @map("period_start")
  periodEnd            DateTime         @map("period_end")
  grossAmount          Decimal          @map("gross_amount") @db.Decimal(12, 2)
  netAmount            Decimal          @map("net_amount") @db.Decimal(12, 2)
  status               SettlementStatus @default(PENDING)
  createdAt            DateTime         @default(now()) @map("created_at")
  updatedAt            DateTime         @updatedAt @map("updated_at")

  store Store            @relation(fields: [storeId], references: [id], onDelete: Cascade)
  items SettlementItem[]

  @@index([organizationId])
  @@map("settlements")
}

model SettlementItem {
  id           String             @id @default(uuid()) @db.Uuid
  settlementId String             @map("settlement_id") @db.Uuid
  orderId      String?            @map("order_id") @db.Uuid
  amount       Decimal            @db.Decimal(12, 2)
  type         SettlementItemType

  settlement Settlement @relation(fields: [settlementId], references: [id], onDelete: Cascade)

  @@map("settlement_items")
}

model CostProfile {
  id             String          @id @default(uuid()) @db.Uuid
  organizationId String          @map("organization_id") @db.Uuid
  // Store = operational boundary: a cost profile belongs to exactly ONE store,
  // is listed only under that store, and attaches only to that store's variants.
  // organizationId is kept for the org-boundary RLS check (is_org_member); store
  // isolation is enforced in the backend service (store-access + attach guard).
  storeId        String          @map("store_id") @db.Uuid
  name           String
  type           CostProfileType
  // GROSS konvansiyon (2026-06-16): maliyet artık GROSS (KDV-dahil) girilir ve saklanır.
  // Eski amount(net) + vatAmount → amountGross + vatRate. Net = amountGross × 100/(100+vatRate).
  // KDV oranı satış KDV'sinden bağımsız olabilir (tedarikçi %20 / satış %10).
  // KDV'siz maliyet → vatRate=0. @default(0): dev truncate+re-sync için (pre-launch).
  amountGross    Decimal         @default(0) @map("amount_gross") @db.Decimal(12, 2)
  currency       Currency        @default(TRY)
  vatRate        Decimal         @default(0) @map("vat_rate") @db.Decimal(5, 2)
  fxRateMode     FxRateMode      @default(AUTO) @map("fx_rate_mode")
  manualFxRate   Decimal?        @map("manual_fx_rate") @db.Decimal(14, 6)
  note           String?
  archivedAt     DateTime?       @map("archived_at")
  createdBy      String?         @map("created_by") @db.Uuid
  updatedBy      String?         @map("updated_by") @db.Uuid
  createdAt      DateTime        @default(now()) @map("created_at")
  updatedAt      DateTime        @updatedAt @map("updated_at")

  organization       Organization                     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  store              Store                            @relation(fields: [storeId], references: [id], onDelete: Cascade)
  versions           CostProfileVersion[]
  variantLinks       ProductVariantCostProfile[]
  snapshotComponents OrderItemCostSnapshotComponent[]

  // Names are unique PER STORE (not per org): two stores may each have a "Kargo
  // Kutusu" profile. Deleting a store cascades its profiles.
  @@unique([storeId, name])
  @@index([storeId, archivedAt])
  @@index([storeId, type])
  @@map("cost_profiles")
}

model CostProfileVersion {
  id             String          @id @default(uuid()) @db.Uuid
  profileId      String          @map("profile_id") @db.Uuid
  organizationId String          @map("organization_id") @db.Uuid
  version        Int
  name           String
  type           CostProfileType
  // GROSS konvansiyon (2026-06-16): CostProfile mirror — versiyonlar da GROSS saklar.
  // @default(0): dev truncate+re-sync için (pre-launch).
  amountGross    Decimal         @default(0) @map("amount_gross") @db.Decimal(12, 2)
  currency       Currency
  vatRate        Decimal         @map("vat_rate") @db.Decimal(5, 2)
  fxRateMode     FxRateMode      @map("fx_rate_mode")
  manualFxRate   Decimal?        @map("manual_fx_rate") @db.Decimal(14, 6)
  note           String?
  archivedAt     DateTime?       @map("archived_at")
  changedFields  String[]        @map("changed_fields")
  changedBy      String?         @map("changed_by") @db.Uuid
  changedAt      DateTime        @default(now()) @map("changed_at")
  changeReason   String?         @map("change_reason")

  profile CostProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@unique([profileId, version])
  @@index([profileId, changedAt(sort: Desc)])
  @@index([organizationId])
  @@map("cost_profile_versions")
}

model ProductVariantCostProfile {
  id               String   @id @default(uuid()) @db.Uuid
  productVariantId String   @map("product_variant_id") @db.Uuid
  profileId        String   @map("profile_id") @db.Uuid
  organizationId   String   @map("organization_id") @db.Uuid
  attachedAt       DateTime @default(now()) @map("attached_at")
  attachedBy       String?  @map("attached_by") @db.Uuid

  productVariant ProductVariant @relation(fields: [productVariantId], references: [id], onDelete: Cascade)
  // Cascade (not Restrict): a cost profile is store-scoped and only ever
  // hard-deleted when its store is disconnected — at which point this link's
  // variant is being deleted too (ProductVariant cascades from the same store).
  // Restrict here deadlocked the store-delete cascade (RESTRICT is checked
  // immediately, before the sibling variant-cascade can clear the link).
  profile        CostProfile    @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@unique([productVariantId, profileId])
  @@index([profileId])
  @@index([organizationId, productVariantId], map: "idx_pvcp_org_product_variant")
  @@map("product_variant_cost_profiles")
}

model OrderItemCostSnapshotComponent {
  id             String          @id @default(uuid()) @db.Uuid
  orderItemId    String          @map("order_item_id") @db.Uuid
  organizationId String          @map("organization_id") @db.Uuid
  profileId      String          @map("profile_id") @db.Uuid
  profileName    String          @map("profile_name")
  profileType    CostProfileType @map("profile_type")
  // GROSS konvansiyon (2026-06-16): amount(net)+vatAmount → amountGross+vatRate.
  // FX: amountInTryGross replaces amountInTry+vatAmountInTry.
  // Net türetilir: amountGross × 100/(100+vatRate).
  // @default(0): dev truncate+re-sync için (pre-launch); snapshot sync yazar.
  amountGross      Decimal    @default(0) @map("amount_gross") @db.Decimal(12, 2)
  currency         Currency
  vatRate          Decimal    @default(0) @map("vat_rate") @db.Decimal(5, 2)
  amountInTryGross Decimal    @default(0) @map("amount_in_try_gross") @db.Decimal(12, 2)
  fxRateMode       FxRateMode @map("fx_rate_mode")
  fxRateUsed     Decimal         @map("fx_rate_used") @db.Decimal(14, 6)
  fxRateSource   String          @map("fx_rate_source")

  orderItem OrderItem   @relation(fields: [orderItemId], references: [id], onDelete: Cascade)
  // Cascade (not Restrict): a cost profile is store-scoped and only ever
  // hard-deleted when its store is disconnected — at which point this snapshot
  // component's order item is being deleted too (OrderItem cascades from the
  // same store). Restrict here deadlocked the store-delete cascade. Historical
  // integrity is unaffected: this row carries denormalized profileName/amounts
  // and dies with its order regardless (disconnect wipes the whole store).
  profile   CostProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@index([orderItemId])
  @@index([organizationId, profileType], map: "idx_oi_cost_snapshot_org_profile_type")
  @@index([organizationId, profileId], map: "idx_oi_cost_snapshot_org_profile_id")
  @@map("order_item_cost_snapshot_components")
}

model FxRate {
  id        String   @id @default(uuid()) @db.Uuid
  currency  Currency
  rateDate  DateTime @map("rate_date") @db.Date
  rateToTry Decimal  @map("rate_to_try") @db.Decimal(14, 6)
  source    String
  fetchedAt DateTime @default(now()) @map("fetched_at")

  @@unique([currency, rateDate])
  // Note: no separate DESC index — Postgres B-tree is bidirectional; the unique
  // index above is used for "latest rate per currency" queries via backward scan.
  @@map("fx_rates")
}

model Expense {
  id             String          @id @default(uuid()) @db.Uuid
  organizationId String          @map("organization_id") @db.Uuid
  storeId        String?         @map("store_id") @db.Uuid
  category       ExpenseCategory
  description    String?
  amount         Decimal         @db.Decimal(12, 2)
  date           DateTime        @db.Date
  isRecurring    Boolean         @default(false) @map("is_recurring")
  createdAt      DateTime        @default(now()) @map("created_at")
  updatedAt      DateTime        @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  // store_id is a real FK now (was a bare uuid): the DB rejects a store id that
  // doesn't exist, and SetNull turns a store-attributed expense into an org-level
  // one when its store is deleted (rather than leaving a dangling pointer). The
  // (organizationId, storeId) index also serves store-scoped expense reports.
  // NOTE: a plain FK still allows a store from ANOTHER org to be referenced — the
  // cross-org read is blocked at the RLS layer (expenses policy requires
  // is_org_member(organization_id) on the store-attributed branch); a future
  // expense write endpoint MUST also verify store∈org before insert.
  store Store? @relation(fields: [storeId], references: [id], onDelete: SetNull)

  @@index([organizationId, storeId])
  @@map("expenses")
}

model SyncLog {
  id               String         @id @default(uuid()) @db.Uuid
  organizationId   String         @map("organization_id") @db.Uuid
  storeId          String         @map("store_id") @db.Uuid
  syncType         SyncType       @map("sync_type")
  status           SyncStatus
  // Provenance of this run. Defaults to CRON so the raw pg_cron INSERT
  // blocks (which never name the column) stay valid; the API sets MANUAL on
  // user-triggered syncs and BOOTSTRAP on the store-connect chain. Only
  // MANUAL rows are consulted by the manual-trigger cooldown check.
  triggerSource    SyncTriggerSource @default(CRON) @map("trigger_source")
  // Timestamp columns are @db.Timestamptz(3) so node-postgres reads
  // them as UTC instants (its default for plain TIMESTAMP is the
  // CLIENT'S local timezone, which silently shifted next_attempt_at
  // by the user's TZ offset and made the SyncCenter "Yeniden
  // denenecek" countdown lie by N hours). PG-internal SQL comparisons
  // worked either way (session TZ is UTC), but the wire shape is the
  // problem. timestamptz fixes both — see fix(sync) PR.
  startedAt        DateTime       @map("started_at") @db.Timestamptz(3)
  completedAt      DateTime?      @map("completed_at") @db.Timestamptz(3)
  recordsProcessed Int            @default(0) @map("records_processed")
  progressCurrent  Int            @default(0) @map("progress_current")
  progressTotal    Int?           @map("progress_total")
  progressStage    String?        @map("progress_stage")
  errorCode        SyncErrorCode? @map("error_code")
  errorMessage     String?        @map("error_message")
  // ─── New columns (PR 2) ────────────────────────────────────
  claimedAt        DateTime?      @map("claimed_at") @db.Timestamptz(3)
  claimedBy        String?        @map("claimed_by")
  lastTickAt       DateTime?      @map("last_tick_at") @db.Timestamptz(3)
  pageCursor       Json?          @map("page_cursor")
  attemptCount     Int            @default(0) @map("attempt_count")
  nextAttemptAt    DateTime?      @map("next_attempt_at") @db.Timestamptz(3)
  // Bozuk sayfalar (Trendyol upstream 5xx, MAX_ATTEMPTS dolan transient
  // hatalar). Worker bu durumda sync'i terminal FAIL etmek yerine cursor'u
  // bir ileri alır ve atlanan sayfayı buraya kaydeder. Şema:
  // Array<{ page, attemptedAt, errorCode, httpStatus, xRequestId?, responseBodySnippet? }>
  // UI bu array'i okuyup COMPLETED satırının yanında "X sayfa atlandı"
  // uyarısı gösterir.
  skippedPages     Json?          @map("skipped_pages")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  store        Store        @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([storeId, startedAt])
  @@index([status, nextAttemptAt])
  // Freshness feed (listLastSuccessfulPerType): DISTINCT ON (store_id,
  // sync_type) … WHERE organization_id = $1 AND status = 'COMPLETED' ORDER BY
  // store_id, sync_type, completed_at DESC. This composite lets Postgres scan
  // the org's COMPLETED rows already grouped/ordered per (store, syncType)
  // instead of a broad org scan + sort.
  @@index([organizationId, status, storeId, syncType, completedAt(sort: Desc)])
  @@map("sync_logs")
}

// Marketplace komisyon tarifesi. Trendyol partner panel BFF'inden
// (apigw.trendyol.com /partner/seller-allowance-sfjdomestic-santral/commercial-rules/*)
// veya gelecekte Hepsiburada panelinden çekilen platform genelinde **paylaşımlı**
// kategori (+ marka) bazlı komisyon oranı ve vade. Trendyol tarifesi tüm satıcılar
// için aynıdır — segment override'lar kavramsal olarak var ama Trendyol satıcının
// segment bilgisini API üzerinden vermediği için kâr hesaplamasında her zaman
// `base_rate` kullanılır. Bu yüzden tablo tenant-private değil, platform-bazlı
// tek paylaşımlı reference data: bütün authenticated user'lar aynı satırları okur.
//
// Order.commissionAmount'tan FARKLI — bu **gelecek komisyon tahmini** içindir
// (yeni ürün fiyatlandırma), sipariş satırının fiili komisyonu değil.
//
// REPLACE semantiği: her refresh `(platform, rule_kind)` çiftindeki tüm satırlar
// transaction içinde silinir ve yeniden yazılır. Historik tarife saklanmaz —
// geçmiş siparişler için OrderItem.commissionAmount/Rate authoritative.
model MarketplaceCommissionRate {
  id       String             @id @default(uuid()) @db.Uuid
  platform Platform
  ruleKind CommissionRuleKind @map("rule_kind")

  // External marketplace identity. BigInt çünkü Trendyol categoryId/brandId
  // alanları int64 (örn. brandId 977855).
  categoryId BigInt  @map("category_id")
  brandId    BigInt? @map("brand_id") // CATEGORY kuralları için NULL

  // Denormalize display alanları — reference tablo eklemeden import edebilelim
  // diye (CLAUDE.md WET+1 promotion trigger: ikinci feature isteyince normalize
  // ederiz). parentCategoryName sadece CATEGORY kurallarında dolu olur;
  // brandName sadece CATEGORY_BRAND'de.
  categoryName       String  @map("category_name")
  parentCategoryName String? @map("parent_category_name")
  brandName          String? @map("brand_name")

  // Tarife. Decimal(5,2) — stage'de 99.50, prod'da ≤30; (5,2) sınırı 999.99
  // ile güvenli pay bırakıyor. OrderItem.commissionRate ile aynı precision.
  baseRate        Decimal @map("base_rate") @db.Decimal(5, 2)
  paymentTermDays Int     @map("payment_term_days")

  // Platform-spesifik segment override'lar. Trendyol için key'ler:
  // {"ka1": "4.00", "ka2": "5.00", "na1": "...", "microSegment": "..."}.
  // Hepsiburada gelirse farklı key seti — JSONB sabit kolonu zorlamadığı için
  // şema migration'sız yeni platform kabul ediyor. Şu an üretim kâr hesabında
  // kullanılmıyor (Trendyol seller segment'i API'den dönmüyor), ama veriyi
  // import sırasında atıyoruz — Trendyol ileride segment paylaşırsa hazır.
  segmentOverrides Json @default("{}") @map("segment_overrides")

  // Audit
  fetchedAt    DateTime @map("fetched_at")
  sourceScreen String   @map("source_screen") // x-system-screen header değeri

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // NULL brandId (CATEGORY kuralları) durumunda PostgreSQL'in default
  // NULLS DISTINCT davranışı bu unique'i kısmen etkisiz bırakır — yani aynı
  // (platform, CATEGORY, categoryId) için teorik olarak birden fazla satır olabilir.
  // Defense-in-depth: import servisi her zaman transactional REPLACE yapar
  // (DELETE WHERE platform=$1 AND rule_kind=$2; sonra INSERT-many), bu yüzden
  // import path üzerinden duplicate giremez. Resolver findFirst kullanır.
  @@unique([platform, ruleKind, categoryId, brandId], map: "marketplace_commission_rate_dedup")
  @@index([platform, ruleKind, categoryId])
  @@map("marketplace_commission_rate")
}

model ShippingCarrier {
