// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ───────────────────────────────────────────

enum MemberRole {
  OWNER
  ADMIN
  MEMBER
  VIEWER
}

enum Platform {
  TRENDYOL
  HEPSIBURADA
}

enum StoreEnvironment {
  PRODUCTION
  SANDBOX
}

enum StoreStatus {
  ACTIVE
  CONNECTION_ERROR
  DISABLED
}

enum OrderStatus {
  PENDING
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
  RETURNED
}

enum SettlementStatus {
  PENDING
  VERIFIED
  DISCREPANCY
}

enum SettlementItemType {
  SALE
  RETURN
  COMMISSION
  SHIPPING
  SERVICE_FEE
  PROMOTION
  OTHER
}

enum ExpenseCategory {
  PRODUCT_COST
  ADVERTISING
  PACKAGING
  SHIPPING_SUPPLY
  SOFTWARE
  PERSONNEL
  RENT
  OTHER
}

enum SyncType {
  ORDERS
  PRODUCTS
  SETTLEMENTS
}

enum SyncStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
  FAILED_RETRYABLE
}

enum SyncErrorCode {
  MARKETPLACE_AUTH_FAILED
  MARKETPLACE_ACCESS_DENIED
  MARKETPLACE_UNREACHABLE
  SYNC_IN_PROGRESS
  RATE_LIMITED
  VALIDATION_ERROR
  INTERNAL_ERROR
}

enum CostProfileType {
  COGS
  PACKAGING
  SHIPPING
  SOFTWARE
  MARKETING
  OTHER
}

enum Currency {
  TRY
  USD
  EUR
}

enum FxRateMode {
  AUTO
  MANUAL
}

enum ShippingTariffSource {
  TRENDYOL_CONTRACT
  OWN_CONTRACT
}

// Marketplace komisyon tarifesi kuralı türü. CATEGORY yalnız kategori bazlı;
// CATEGORY_BRAND ek olarak marka kırılımı içerir. Trendyol'un "matching rules
// → en düşüğü uygulanır" mantığı için iki türü tek tabloda toplayıp app-layer'da
// MIN() üzerinden resolve ediyoruz.
enum CommissionRuleKind {
  CATEGORY
  CATEGORY_BRAND
}

// Sipariş mutabakat durumu — kar hesaplama V1 (docs/plans/2026-05-18-profit-calculation-design.md §3.1).
// NOT_SETTLED: ESTIMATE OrderFee'ler yazılı, henüz SETTLEMENT yok.
// PARTIALLY_SETTLED: Bazı SETTLEMENT/CARGO_INVOICE OrderFee'ler var, Sale.paymentOrderId henüz null.
// FULLY_SETTLED: Sale paymentOrderId dolu, settledNetProfit yazıldı.
enum ReconciliationStatus {
  NOT_SETTLED
  PARTIALLY_SETTLED
  FULLY_SETTLED
}

// OrderFee tipi — pazaryeri ücretlerinin tek kaynağı (design §3.3).
// İki kategori: sipariş-düzeyi (OrderFee tablosuna yazılır) ve org-düzeyi
// (OrgPeriodFee tablosuna yazılır — Reklam, Penalty, Notification, COMMISSION_INVOICE).
// PLATFORM_SERVICE + PLATFORM_SERVICE_FAST ayrı FeeDefinition row'larıyla seçilir;
// FAST yalnızca fastDelivery=true + deliveredOnTime=true durumda uygulanır (§3.4).
enum OrderFeeType {
  SHIPPING
  PLATFORM_SERVICE
  PLATFORM_SERVICE_FAST
  STOPPAGE
  RETURN_SHIPPING
  REFUND_DEDUCTION
  COMMISSION_REFUND
  PROVISION_ADJUSTMENT
  MANUAL_REFUND
  REVENUE_ADJUSTMENT
  COMMISSION_ADJUSTMENT
  CUSTOM
  ADVERTISING
  PENALTY_DEFECTIVE
  PENALTY_WRONG_PRODUCT
  PENALTY_MISSING_PRODUCT
  PENALTY_LATE_DELIVERY
  PENALTY_SUPPLY_FAILURE
  NOTIFICATION_FEE
  COMMISSION_INVOICE
}

// OrderFee'nin kaynağı — audit + reconciliation algoritması için kritik (§3.3).
// ESTIMATE: applyEstimateOnOrderCreate (T+0 deterministic).
// SETTLEMENT: settlements/otherfinancials API'sinden.
// CARGO_INVOICE: cargo-invoice/{serial}/items per-order match.
// USER_OVERRIDE: kullanıcı düzeltti. MANUAL_ENTRY: kullanıcı ekledi (reklam vs.).
enum OrderFeeSource {
  ESTIMATE
  SETTLEMENT
  CARGO_INVOICE
  USER_OVERRIDE
  MANUAL_ENTRY
}

enum OrderFeeDirection {
  DEBIT
  CREDIT
}

// FeeDefinition hesap türü — sistem-düzeyi ücret tanımları (§3.4).
// FIXED: sabit tutar (PSF ₺10.99). RATE_OF_SALE: satışın yüzdesi (Stopaj %1).
// FORMULA: V2'ye ertelendi (karmaşık formüller).
enum FeeCalculationKind {
  FIXED
  RATE_OF_SALE
  FORMULA
}

// ─── Models ──────────────────────────────────────────

model UserProfile {
  id                String   @id @db.Uuid
  email             String   @unique
  fullName          String?  @map("full_name")
  avatarUrl         String?  @map("avatar_url")
  timezone          String   @default("Europe/Istanbul")
  preferredLanguage String   @default("tr") @map("preferred_language")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  memberships OrganizationMember[]

  @@map("user_profiles")
}

model Organization {
  id        String   @id @default(uuid()) @db.Uuid
  name      String
  slug      String   @unique
  currency  String   @default("TRY")
  timezone  String   @default("Europe/Istanbul")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  members       OrganizationMember[]
  stores        Store[]
  expenses      Expense[]
  syncLogs      SyncLog[]
  costProfiles  CostProfile[]
  webhookEvents WebhookEvent[]

  @@map("organizations")
}

model OrganizationMember {
  id             String     @id @default(uuid()) @db.Uuid
  organizationId String     @map("organization_id") @db.Uuid
  userId         String     @map("user_id") @db.Uuid
  role           MemberRole @default(MEMBER)
  lastAccessedAt DateTime?  @map("last_accessed_at")
  createdAt      DateTime   @default(now()) @map("created_at")
  updatedAt      DateTime   @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         UserProfile  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([organizationId, userId])
  @@index([userId, lastAccessedAt(sort: Desc)], map: "idx_org_members_user_last_accessed")
  @@map("organization_members")
}

model Store {
  id                       String               @id @default(uuid()) @db.Uuid
  organizationId           String               @map("organization_id") @db.Uuid
  name                     String
  platform                 Platform
  environment              StoreEnvironment     @default(PRODUCTION)
  externalAccountId        String               @map("external_account_id")
  credentials              Json
  status                   StoreStatus          @default(ACTIVE)
  isActive                 Boolean              @default(true) @map("is_active")
  lastConnectedAt          DateTime?            @map("last_connected_at")
  lastSyncAt               DateTime?            @map("last_sync_at")
  shippingTariffSource     ShippingTariffSource @default(TRENDYOL_CONTRACT) @map("shipping_tariff_source")
  defaultShippingCarrierId String?              @map("default_shipping_carrier_id") @db.Uuid
  // ─── PR-C1: Trendyol webhook subscription ───────────────────────────
  // webhookId: Trendyol'un atadığı subscription UUID (POST /webhooks response.id).
  //   PUT/DELETE call'larında kullanılır. Register fail'de null kalır.
  // webhookSecret: AES-256-GCM ciphertext (base64) of JSON.stringify({username, password}).
  //   Random generated at register; decrypt only inside verify middleware.
  // webhookActiveAt: son register/rotate timestamp. UI badge "webhook bağlı" göstergesi.
  // Üçü de nullable: mevcut store'lar geriye dönük register zorunda değil; failed
  // register transient olabilir; non-TRENDYOL platformlarda da null kalır.
  webhookId                String?              @map("webhook_id")
  webhookSecret            String?              @map("webhook_secret")
  webhookActiveAt          DateTime?            @map("webhook_active_at")
  createdAt                DateTime             @default(now()) @map("created_at")
  updatedAt                DateTime             @updatedAt @map("updated_at")

  organization           Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  products               Product[]
  productVariants        ProductVariant[]
  orders                 Order[]
  settlements            Settlement[]
  syncLogs               SyncLog[]
  webhookEvents          WebhookEvent[]
  defaultShippingCarrier ShippingCarrier?    @relation(fields: [defaultShippingCarrierId], references: [id], onDelete: SetNull)
  ownShippingTariffs     OwnShippingTariff[]
  orgPeriodFees          OrgPeriodFee[]
  commissionInvoices     CommissionInvoice[]

  @@unique([organizationId, platform, externalAccountId])
  @@index([organizationId])
  @@map("stores")
}

// Parent — one row per Trendyol contentId. Shared content fields
// (title, description, brand, category, color, images) live here. SKU-level
// fields (barcode, stockCode, price, stock, delivery, size) live on
// ProductVariant. The split mirrors how the marketplace itself models
// products and avoids lossy denormalization across N variants.
model Product {
  id                 String    @id @default(uuid()) @db.Uuid
  organizationId     String    @map("organization_id") @db.Uuid
  storeId            String    @map("store_id") @db.Uuid
  platformContentId  BigInt    @map("platform_content_id")
  productMainId      String    @map("product_main_id")
  title              String
  description        String?   @db.Text
  brandId            BigInt?   @map("brand_id")
  brandName          String?   @map("brand_name")
  categoryId         BigInt?   @map("category_id")
  categoryName       String?   @map("category_name")
  color              String?
  attributes         Json      @default("[]")
  approved           Boolean   @default(true)
  platformCreatedAt  DateTime? @map("platform_created_at")
  platformModifiedAt DateTime? @map("platform_modified_at")
  lastSyncedAt       DateTime  @default(now()) @map("last_synced_at")
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")

  // Denormalized SUM(variants[*].quantity) for the store. Updated
  // transactionally inside upsertBatch in the sync worker — see
  // apps/sync-worker/src/handlers/products.ts. Indexed for the
  // products-list sort=totalStock workflow (pricing + restock review).
  totalStock Int @default(0) @map("total_stock")

  store    Store            @relation(fields: [storeId], references: [id], onDelete: Cascade)
  variants ProductVariant[]
  images   ProductImage[]

  @@unique([storeId, platformContentId])
  @@index([organizationId])
  @@index([storeId, productMainId])
  @@index([storeId, brandId])
  @@index([storeId, totalStock])
  @@index([storeId, categoryId])
  @@map("products")
}

// Child — one row per Trendyol variantId (SKU). organizationId is denormalized
// here so the RLS policy can be a flat `is_org_member(organization_id)` USING
// clause without recursing through Product (avoids the 42P17 trap, see
// supabase/sql/rls-policies.sql for the full rationale).
model ProductVariant {
  id                      String   @id @default(uuid()) @db.Uuid
  organizationId          String   @map("organization_id") @db.Uuid
  storeId                 String   @map("store_id") @db.Uuid
  productId               String   @map("product_id") @db.Uuid
  platformVariantId       BigInt   @map("platform_variant_id")
  barcode                 String
  stockCode               String   @map("stock_code")
  salePrice               Decimal  @map("sale_price") @db.Decimal(12, 2)
  listPrice               Decimal  @map("list_price") @db.Decimal(12, 2)
  vatRate                 Int?     @map("vat_rate")
  costPrice               Decimal? @map("cost_price") @db.Decimal(12, 2)
  // PSF muafiyet kuralı: tüm OrderItem'larda isDigital=true → PSF=0 (design §3.7).
  // V1: kullanıcı UI'dan işaretler (variant settings toggle). V2: Trendyol kategori
  // lookup ile otomatik tahmin.
  isDigital               Boolean  @default(false) @map("is_digital")
  // Two-column sync-protection pair (see docs/plans/archive/... for rationale):
  // syncedDimensionalWeight is the marketplace's value, refreshed every sync.
  // dimensionalWeight is the user's manual override; null = no override, fall
  // back to synced at read time. The sync worker writes ONLY to the synced
  // column — never to dimensionalWeight — so the "user value is sacred"
  // invariant is structural, not just enforced in code.
  syncedDimensionalWeight Decimal? @map("synced_dimensional_weight") @db.Decimal(6, 2)
  dimensionalWeight       Decimal? @map("dimensional_weight") @db.Decimal(6, 2)
  quantity                Int      @default(0)
  deliveryDuration        Int?     @map("delivery_duration")
  isRushDelivery          Boolean  @default(false) @map("is_rush_delivery")
  fastDeliveryOptions     Json     @default("[]") @map("fast_delivery_options")
  productUrl              String?  @map("product_url") @db.Text
  locationBasedDelivery   String?  @map("location_based_delivery")
  onSale                  Boolean  @default(true) @map("on_sale")
  archived                Boolean  @default(false)
  blacklisted             Boolean  @default(false)
  locked                  Boolean  @default(false)
  size                    String?
  attributes              Json     @default("[]")
  lastSyncedAt            DateTime @default(now()) @map("last_synced_at")
  createdAt               DateTime @default(now()) @map("created_at")
  updatedAt               DateTime @updatedAt @map("updated_at")

  product          Product                     @relation(fields: [productId], references: [id], onDelete: Cascade)
  store            Store                       @relation(fields: [storeId], references: [id], onDelete: Cascade)
  orderItems       OrderItem[]
  costProfileLinks ProductVariantCostProfile[]

  @@unique([storeId, platformVariantId])
  // Intentionally NOT unique on (storeId, barcode): marketplaces enforce
  // barcode uniqueness on their side at listing time, but their sandbox
  // and certain real-world catalogs ship variants with duplicate
  // barcodes (different platformVariantId, same printed barcode — e.g.
  // multi-pack vs single-unit variants of the same SKU). Treating
  // barcode as unique at our layer caused 3 product upserts to fail per
  // sync against the dev/sandbox account; the products were silently
  // dropped via skip-on-error in apps/sync-worker/src/handlers/products.ts.
  // Lookups by barcode (e.g. order item resolution) are non-unique in
  // principle anyway — we resolve via platformVariantId.
  @@index([storeId, barcode])
  @@index([organizationId])
  @@index([productId])
  @@index([storeId, stockCode])
  @@index([storeId, onSale, archived])
  @@map("product_variants")
}

model ProductImage {
  id             String   @id @default(uuid()) @db.Uuid
  organizationId String   @map("organization_id") @db.Uuid
  productId      String   @map("product_id") @db.Uuid
  url            String   @db.Text
  position       Int      @default(0)
  createdAt      DateTime @default(now()) @map("created_at")

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId, position])
  @@map("product_images")
}

model Order {
  id              String      @id @default(uuid()) @db.Uuid
  organizationId  String      @map("organization_id") @db.Uuid
  storeId         String      @map("store_id") @db.Uuid
  platformOrderId String      @map("platform_order_id")
  orderDate       DateTime    @map("order_date")
  status          OrderStatus
  // ESKİ ÜCRET KOLONLARI (totalAmount, commissionAmount, shippingCost, platformFee,
  // vatAmount, netProfit) PR-5c'de SİLİNDİ (2026-05-19). Yeni convention için:
  // - Satış: saleSubtotalNet + saleVatTotal (aşağıda PR-5a)
  // - Komisyon: OrderItem.grossCommissionAmountNet/VatAmount (PR-3)
  // - Kargo/PSF/Stopaj: OrderFee tablosunda (PR-1)
  // - Kar: estimatedNetProfit / settledNetProfit (PR-5a, write-once + mutable)

  // Trendyol data-input alanları (sync handler PR-6'da set eder, design §3.1).
  // agreedDeliveryDate: getShipmentPackages endpoint direkt field.
  // actualDeliveryDate: packageHistories[status='Delivered'].createdAt'den türetilir;
  //   Delivered status webhook'unda set'lenir. Order endpoint'te direkt field YOK.
  agreedDeliveryDate DateTime? @map("agreed_delivery_date")
  actualDeliveryDate DateTime? @map("actual_delivery_date")
  // fastDelivery: getShipmentPackages direkt boolean (Bugün Kargoda indikatörü).
  // micro: getShipmentPackages direkt boolean (mikro ihracat) — PSF muafiyeti.
  fastDelivery       Boolean   @default(false) @map("fast_delivery")
  micro              Boolean   @default(false) @map("micro")

  // ─── PR-5a: Kar V1 state/derived kolonları (design §3.1) ────────────
  // saleSubtotalNet + saleVatTotal: OrderItem'lardan agregat (sync handler PR-6'da
  // set eder). PR-5b veri taşıma mevcut Order.totalAmount'tan backfill yapacak.
  saleSubtotalNet Decimal? @map("sale_subtotal_net") @db.Decimal(12, 2)
  saleVatTotal    Decimal? @map("sale_vat_total") @db.Decimal(12, 2)

  // İki aşamalı kar (design §4.1):
  // - estimatedNetProfit: T+0 applyEstimateOnOrderCreate yazar, write-once (PR-9 trigger).
  // - settledNetProfit:   T+~5+ recomputeSettledProfit yazar, mutable (iade güncellemeleri).
  estimatedNetProfit   Decimal?             @map("estimated_net_profit") @db.Decimal(12, 2)
  settledNetProfit     Decimal?             @map("settled_net_profit") @db.Decimal(12, 2)
  // Durum makinesi: NOT_SETTLED → PARTIALLY_SETTLED → FULLY_SETTLED (design §6.1).
  // İlk SETTLEMENT/CARGO_INVOICE OrderFee yazıldığında PARTIALLY_SETTLED, Sale
  // satırının paymentOrderId'si dolu görüldüğünde FULLY_SETTLED.
  reconciliationStatus ReconciliationStatus @default(NOT_SETTLED) @map("reconciliation_status")

  // PaymentOrder bağlantısı — mutabakat sinyali (§3.7). Sale.paymentOrderId dolu
  // görüldüğünde Order'a yansıtılır → handlePaymentOrderEntry tetiklenir →
  // cycle'daki PSF/Stopaj ESTIMATE'leri SETTLEMENT'a confirm + recomputeSettledProfit.
  paymentOrderId BigInt?   @map("payment_order_id")
  paymentDate    DateTime? @map("payment_date")

  // Türetilmiş: actualDeliveryDate <= agreedDeliveryDate → true (Bugün Kargoda PSF).
  // applyEstimate hesaplaması: inferDeliveredOnTime(order) — null = henüz delivered değil.
  deliveredOnTime Boolean? @map("delivered_on_time")

  // Trendyol orderNumber (üst sipariş, paket-üstü). platformOrderId = shipmentPackageId
  // (paket-seviyesi); platformOrderNumber = orderNumber (split shipment'ta N pakete
  // referans verir). PR-5b veri taşıma mevcut yanlış dolu rows'u doğrultur (§9 PR-5b).
  platformOrderNumber String? @map("platform_order_number")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  store  Store        @relation(fields: [storeId], references: [id], onDelete: Cascade)
  items  OrderItem[]
  fees   OrderFee[]
  claims OrderClaim[]

  @@unique([storeId, platformOrderId])
  @@index([organizationId])
  @@index([organizationId, reconciliationStatus])
  @@index([orderDate])
  @@index([platformOrderNumber])
  @@index([storeId, paymentOrderId])
  @@map("orders")
}

model OrderItem {
  id                 String    @id @default(uuid()) @db.Uuid
  orderId            String    @map("order_id") @db.Uuid
  productVariantId   String?   @map("product_variant_id") @db.Uuid
  quantity           Int
  // Eski (KDV-dahil) kolonlar — PR-5c'de silinir, PR-5b veri taşıma sonrası.
  unitPrice          Decimal   @map("unit_price") @db.Decimal(12, 2)
  commissionRate     Decimal   @map("commission_rate") @db.Decimal(5, 2)
  commissionAmount   Decimal   @map("commission_amount") @db.Decimal(12, 2)
  organizationId     String?   @map("organization_id") @db.Uuid
  unitCostSnapshot   Decimal?  @map("unit_cost_snapshot") @db.Decimal(12, 2)
  snapshotCapturedAt DateTime? @map("snapshot_captured_at")

  // ─── PR-3: KDV ayrıştırması + commission split (design §3.2) ────────
  // unitPriceNet = lineUnitPrice / (1 + unitVatRate/100); unitVatAmount = brüt − net.
  // Nullable çünkü mevcut satırlar PR-5b veri taşıma'sı bunları doldurana kadar boş.
  unitPriceNet  Decimal? @map("unit_price_net") @db.Decimal(12, 2)
  unitVatRate   Decimal? @map("unit_vat_rate") @db.Decimal(5, 2)
  unitVatAmount Decimal? @map("unit_vat_amount") @db.Decimal(12, 2)

  // Komisyon — Trendyol her satır için ayrı oran verdiği için OrderItem-level.
  // Effective commission = gross − refunded (research §3.2 — Discount transaction'ı
  // ayrı komisyon iadesi getiriyor). DB-level CHECK constraint:
  // refunded_commission_amount_net <= gross_commission_amount_net (migration.sql'de
  // manual ALTER TABLE). default(0) backward-compat için (PR-6 sync worker
  // settlement Sale satırlarını işlerken doğru değerleri yazar).
  grossCommissionAmountNet    Decimal @default(0) @map("gross_commission_amount_net") @db.Decimal(12, 2)
  grossCommissionVatAmount    Decimal @default(0) @map("gross_commission_vat_amount") @db.Decimal(12, 2)
  refundedCommissionAmountNet Decimal @default(0) @map("refunded_commission_amount_net") @db.Decimal(12, 2)
  refundedCommissionVatAmount Decimal @default(0) @map("refunded_commission_vat_amount") @db.Decimal(12, 2)

  // Satıcı kaynaklı indirim (gerçek gelir azaltıcı, Discount transaction'tan).
  sellerDiscountNet       Decimal @default(0) @map("seller_discount_net") @db.Decimal(12, 2)
  sellerDiscountVatAmount Decimal @default(0) @map("seller_discount_vat_amount") @db.Decimal(12, 2)

  // Maliyet anlık kopyası — KDV ayrıştırma (mevcut unitCostSnapshot KDV-dahil).
  // Tümü nullable: maliyet snapshot eksik durumda kar hesabı null kalır (§12.2 #7).
  unitCostSnapshotNet       Decimal? @map("unit_cost_snapshot_net") @db.Decimal(12, 2)
  unitCostSnapshotVatRate   Decimal? @map("unit_cost_snapshot_vat_rate") @db.Decimal(5, 2)
  unitCostSnapshotVatAmount Decimal? @map("unit_cost_snapshot_vat_amount") @db.Decimal(12, 2)

  // Komisyon faturası referansı (design §3.8 iki aşamalı populate):
  // - serialNumber: Sale satırı T+~5'te direkt yazar (raw "DCF...").
  // - id: T+~7 Komisyon Faturası otherfinancials kaydı geldiğinde backfill FK.
  commissionInvoiceSerialNumber String? @map("commission_invoice_serial_number")
  commissionInvoiceId           String? @map("commission_invoice_id") @db.Uuid

  costSnapshotComponents OrderItemCostSnapshotComponent[]
  claimItems             OrderClaimItem[]

  order             Order              @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productVariant    ProductVariant?    @relation(fields: [productVariantId], references: [id], onDelete: SetNull)
  commissionInvoice CommissionInvoice? @relation(fields: [commissionInvoiceId], references: [id], onDelete: SetNull)

  @@index([organizationId, snapshotCapturedAt])
  @@index([commissionInvoiceId])
  @@map("order_items")
}

model Settlement {
  id                   String           @id @default(uuid()) @db.Uuid
  organizationId       String           @map("organization_id") @db.Uuid
  storeId              String           @map("store_id") @db.Uuid
  platformSettlementId String?          @map("platform_settlement_id")
  periodStart          DateTime         @map("period_start")
  periodEnd            DateTime         @map("period_end")
  grossAmount          Decimal          @map("gross_amount") @db.Decimal(12, 2)
  netAmount            Decimal          @map("net_amount") @db.Decimal(12, 2)
  status               SettlementStatus @default(PENDING)
  createdAt            DateTime         @default(now()) @map("created_at")
  updatedAt            DateTime         @updatedAt @map("updated_at")

  store Store            @relation(fields: [storeId], references: [id], onDelete: Cascade)
  items SettlementItem[]

  @@index([organizationId])
  @@map("settlements")
}

model SettlementItem {
  id           String             @id @default(uuid()) @db.Uuid
  settlementId String             @map("settlement_id") @db.Uuid
  orderId      String?            @map("order_id") @db.Uuid
  amount       Decimal            @db.Decimal(12, 2)
  type         SettlementItemType

  settlement Settlement @relation(fields: [settlementId], references: [id], onDelete: Cascade)

  @@map("settlement_items")
}

model CostProfile {
  id             String          @id @default(uuid()) @db.Uuid
  organizationId String          @map("organization_id") @db.Uuid
  name           String
  type           CostProfileType
  // `amount` KDV HARİÇ (NET) — convention'i empirik doğrulandı (design §12.1 #10,
  // 2026-05-19): profit-calculation.service.ts:11 yorumu + cost-profile.service.ts
  // pass-through + cost-snapshot.service.ts pass-through + i18n form label.
  amount         Decimal         @db.Decimal(12, 2)
  currency       Currency        @default(TRY)
  vatRate        Int             @default(0) @map("vat_rate")
  // PR-4: KDV tutarı denormalize. Backfill = ROUND(amount × vatRate / 100, 2).
  // Nullable çünkü yeni eklenen rows sync worker doldurana kadar boş kalabilir.
  // CHECK constraint: vat_amount IS NULL OR vat_amount >= 0 (check-constraints.sql).
  vatAmount      Decimal?        @map("vat_amount") @db.Decimal(12, 2)
  fxRateMode     FxRateMode      @default(AUTO) @map("fx_rate_mode")
  manualFxRate   Decimal?        @map("manual_fx_rate") @db.Decimal(14, 6)
  note           String?
  archivedAt     DateTime?       @map("archived_at")
  createdBy      String?         @map("created_by") @db.Uuid
  updatedBy      String?         @map("updated_by") @db.Uuid
  createdAt      DateTime        @default(now()) @map("created_at")
  updatedAt      DateTime        @updatedAt @map("updated_at")

  organization       Organization                     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  versions           CostProfileVersion[]
  variantLinks       ProductVariantCostProfile[]
  snapshotComponents OrderItemCostSnapshotComponent[]

  @@unique([organizationId, name])
  @@index([organizationId, archivedAt])
  @@index([organizationId, type])
  @@map("cost_profiles")
}

model CostProfileVersion {
  id             String          @id @default(uuid()) @db.Uuid
  profileId      String          @map("profile_id") @db.Uuid
  organizationId String          @map("organization_id") @db.Uuid
  version        Int
  name           String
  type           CostProfileType
  amount         Decimal         @db.Decimal(12, 2)
  currency       Currency
  vatRate        Int             @map("vat_rate")
  // PR-4: Version history KDV tutarı (CostProfile.vatAmount mirror). Cost profile
  // güncellendiğinde version row'una snapshot edilir; service code PR-6'da updates.
  vatAmount      Decimal?        @map("vat_amount") @db.Decimal(12, 2)
  fxRateMode     FxRateMode      @map("fx_rate_mode")
  manualFxRate   Decimal?        @map("manual_fx_rate") @db.Decimal(14, 6)
  note           String?
  archivedAt     DateTime?       @map("archived_at")
  changedFields  String[]        @map("changed_fields")
  changedBy      String?         @map("changed_by") @db.Uuid
  changedAt      DateTime        @default(now()) @map("changed_at")
  changeReason   String?         @map("change_reason")

  profile CostProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@unique([profileId, version])
  @@index([profileId, changedAt(sort: Desc)])
  @@index([organizationId])
  @@map("cost_profile_versions")
}

model ProductVariantCostProfile {
  id               String   @id @default(uuid()) @db.Uuid
  productVariantId String   @map("product_variant_id") @db.Uuid
  profileId        String   @map("profile_id") @db.Uuid
  organizationId   String   @map("organization_id") @db.Uuid
  attachedAt       DateTime @default(now()) @map("attached_at")
  attachedBy       String?  @map("attached_by") @db.Uuid

  productVariant ProductVariant @relation(fields: [productVariantId], references: [id], onDelete: Cascade)
  profile        CostProfile    @relation(fields: [profileId], references: [id], onDelete: Restrict)

  @@unique([productVariantId, profileId])
  @@index([profileId])
  @@index([organizationId, productVariantId], map: "idx_pvcp_org_product_variant")
  @@map("product_variant_cost_profiles")
}

model OrderItemCostSnapshotComponent {
  id             String          @id @default(uuid()) @db.Uuid
  orderItemId    String          @map("order_item_id") @db.Uuid
  organizationId String          @map("organization_id") @db.Uuid
  profileId      String          @map("profile_id") @db.Uuid
  profileName    String          @map("profile_name")
  profileType    CostProfileType @map("profile_type")
  // `amount` ve `amountInTry` KDV HARİÇ (NET) — CostProfile convention mirror.
  amount         Decimal         @db.Decimal(12, 2)
  currency       Currency
  vatRate        Int             @map("vat_rate")
  amountInTry    Decimal         @map("amount_in_try") @db.Decimal(12, 2)
  // PR-4: KDV tutarları snapshot. Backfill:
  //   vat_amount = ROUND(amount × vat_rate / 100, 2)               (native)
  //   vat_amount_in_try = ROUND(amount_in_try × vat_rate / 100, 2) (TRY)
  vatAmount      Decimal?        @map("vat_amount") @db.Decimal(12, 2)
  vatAmountInTry Decimal?        @map("vat_amount_in_try") @db.Decimal(12, 2)
  fxRateMode     FxRateMode      @map("fx_rate_mode")
  fxRateUsed     Decimal         @map("fx_rate_used") @db.Decimal(14, 6)
  fxRateSource   String          @map("fx_rate_source")

  orderItem OrderItem   @relation(fields: [orderItemId], references: [id], onDelete: Cascade)
  profile   CostProfile @relation(fields: [profileId], references: [id], onDelete: Restrict)

  @@index([orderItemId])
  @@index([organizationId, profileType], map: "idx_oi_cost_snapshot_org_profile_type")
  @@index([organizationId, profileId], map: "idx_oi_cost_snapshot_org_profile_id")
  @@map("order_item_cost_snapshot_components")
}

model FxRate {
  id        String   @id @default(uuid()) @db.Uuid
  currency  Currency
  rateDate  DateTime @map("rate_date") @db.Date
  rateToTry Decimal  @map("rate_to_try") @db.Decimal(14, 6)
  source    String
  fetchedAt DateTime @default(now()) @map("fetched_at")

  @@unique([currency, rateDate])
  // Note: no separate DESC index — Postgres B-tree is bidirectional; the unique
  // index above is used for "latest rate per currency" queries via backward scan.
  @@map("fx_rates")
}

model Expense {
  id             String          @id @default(uuid()) @db.Uuid
  organizationId String          @map("organization_id") @db.Uuid
  storeId        String?         @map("store_id") @db.Uuid
  category       ExpenseCategory
  description    String?
  amount         Decimal         @db.Decimal(12, 2)
  date           DateTime        @db.Date
  isRecurring    Boolean         @default(false) @map("is_recurring")
  createdAt      DateTime        @default(now()) @map("created_at")
  updatedAt      DateTime        @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@map("expenses")
}

model SyncLog {
  id               String         @id @default(uuid()) @db.Uuid
  organizationId   String         @map("organization_id") @db.Uuid
  storeId          String         @map("store_id") @db.Uuid
  syncType         SyncType       @map("sync_type")
  status           SyncStatus
  // Timestamp columns are @db.Timestamptz(3) so node-postgres reads
  // them as UTC instants (its default for plain TIMESTAMP is the
  // CLIENT'S local timezone, which silently shifted next_attempt_at
  // by the user's TZ offset and made the SyncCenter "Yeniden
  // denenecek" countdown lie by N hours). PG-internal SQL comparisons
  // worked either way (session TZ is UTC), but the wire shape is the
  // problem. timestamptz fixes both — see fix(sync) PR.
  startedAt        DateTime       @map("started_at") @db.Timestamptz(3)
  completedAt      DateTime?      @map("completed_at") @db.Timestamptz(3)
  recordsProcessed Int            @default(0) @map("records_processed")
  progressCurrent  Int            @default(0) @map("progress_current")
  progressTotal    Int?           @map("progress_total")
  progressStage    String?        @map("progress_stage")
  errorCode        SyncErrorCode? @map("error_code")
  errorMessage     String?        @map("error_message")
  // ─── New columns (PR 2) ────────────────────────────────────
  claimedAt        DateTime?      @map("claimed_at") @db.Timestamptz(3)
  claimedBy        String?        @map("claimed_by")
  lastTickAt       DateTime?      @map("last_tick_at") @db.Timestamptz(3)
  pageCursor       Json?          @map("page_cursor")
  attemptCount     Int            @default(0) @map("attempt_count")
  nextAttemptAt    DateTime?      @map("next_attempt_at") @db.Timestamptz(3)
  // Bozuk sayfalar (Trendyol upstream 5xx, MAX_ATTEMPTS dolan transient
  // hatalar). Worker bu durumda sync'i terminal FAIL etmek yerine cursor'u
  // bir ileri alır ve atlanan sayfayı buraya kaydeder. Şema:
  // Array<{ page, attemptedAt, errorCode, httpStatus, xRequestId?, responseBodySnippet? }>
  // UI bu array'i okuyup COMPLETED satırının yanında "X sayfa atlandı"
  // uyarısı gösterir.
  skippedPages     Json?          @map("skipped_pages")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  store        Store        @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([storeId, startedAt])
  @@index([status, nextAttemptAt])
  @@map("sync_logs")
}

// Marketplace komisyon tarifesi. Trendyol partner panel BFF'inden
// (apigw.trendyol.com /partner/seller-allowance-sfjdomestic-santral/commercial-rules/*)
// veya gelecekte Hepsiburada panelinden çekilen platform genelinde **paylaşımlı**
// kategori (+ marka) bazlı komisyon oranı ve vade. Trendyol tarifesi tüm satıcılar
// için aynıdır — segment override'lar kavramsal olarak var ama Trendyol satıcının
// segment bilgisini API üzerinden vermediği için kâr hesaplamasında her zaman
// `base_rate` kullanılır. Bu yüzden tablo tenant-private değil, platform-bazlı
// tek paylaşımlı reference data: bütün authenticated user'lar aynı satırları okur.
//
// Order.commissionAmount'tan FARKLI — bu **gelecek komisyon tahmini** içindir
// (yeni ürün fiyatlandırma), sipariş satırının fiili komisyonu değil.
//
// REPLACE semantiği: her refresh `(platform, rule_kind)` çiftindeki tüm satırlar
// transaction içinde silinir ve yeniden yazılır. Historik tarife saklanmaz —
// geçmiş siparişler için OrderItem.commissionAmount/Rate authoritative.
model MarketplaceCommissionRate {
  id       String             @id @default(uuid()) @db.Uuid
  platform Platform
  ruleKind CommissionRuleKind @map("rule_kind")

  // External marketplace identity. BigInt çünkü Trendyol categoryId/brandId
  // alanları int64 (örn. brandId 977855).
  categoryId BigInt  @map("category_id")
  brandId    BigInt? @map("brand_id") // CATEGORY kuralları için NULL

  // Denormalize display alanları — reference tablo eklemeden import edebilelim
  // diye (CLAUDE.md WET+1 promotion trigger: ikinci feature isteyince normalize
  // ederiz). parentCategoryName sadece CATEGORY kurallarında dolu olur;
  // brandName sadece CATEGORY_BRAND'de.
  categoryName       String  @map("category_name")
  parentCategoryName String? @map("parent_category_name")
  brandName          String? @map("brand_name")

  // Tarife. Decimal(5,2) — stage'de 99.50, prod'da ≤30; (5,2) sınırı 999.99
  // ile güvenli pay bırakıyor. OrderItem.commissionRate ile aynı precision.
  baseRate        Decimal @map("base_rate") @db.Decimal(5, 2)
  paymentTermDays Int     @map("payment_term_days")

  // Platform-spesifik segment override'lar. Trendyol için key'ler:
  // {"ka1": "4.00", "ka2": "5.00", "na1": "...", "microSegment": "..."}.
  // Hepsiburada gelirse farklı key seti — JSONB sabit kolonu zorlamadığı için
  // şema migration'sız yeni platform kabul ediyor. Şu an üretim kâr hesabında
  // kullanılmıyor (Trendyol seller segment'i API'den dönmüyor), ama veriyi
  // import sırasında atıyoruz — Trendyol ileride segment paylaşırsa hazır.
  segmentOverrides Json @default("{}") @map("segment_overrides")

  // Audit
  fetchedAt    DateTime @map("fetched_at")
  sourceScreen String   @map("source_screen") // x-system-screen header değeri

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // NULL brandId (CATEGORY kuralları) durumunda PostgreSQL'in default
  // NULLS DISTINCT davranışı bu unique'i kısmen etkisiz bırakır — yani aynı
  // (platform, CATEGORY, categoryId) için teorik olarak birden fazla satır olabilir.
  // Defense-in-depth: import servisi her zaman transactional REPLACE yapar
  // (DELETE WHERE platform=$1 AND rule_kind=$2; sonra INSERT-many), bu yüzden
  // import path üzerinden duplicate giremez. Resolver findFirst kullanır.
  @@unique([platform, ruleKind, categoryId, brandId], map: "marketplace_commission_rate_dedup")
  @@index([platform, ruleKind, categoryId])
  @@map("marketplace_commission_rate")
}

model ShippingCarrier {
  id                               String   @id @default(uuid()) @db.Uuid
  platform                         Platform
  externalId                       Int      @map("external_id")
  code                             String
  displayName                      String   @map("display_name")
  taxNumber                        String?  @map("tax_number")
  supportsBaremDestek              Boolean  @default(true) @map("supports_barem_destek")
  maxBaremDesi                     Int      @default(10) @map("max_barem_desi")
  maxBaremEligibleDeliveryDuration Int      @default(1) @map("max_barem_eligible_delivery_duration")
  sortOrder                        Int      @default(0) @map("sort_order")
  active                           Boolean  @default(true)
  createdAt                        DateTime @default(now()) @map("created_at")
  updatedAt                        DateTime @updatedAt @map("updated_at")

  desiTariffs  ShippingDesiTariff[]
  baremTariffs ShippingBaremTariff[]
  stores       Store[]

  @@unique([platform, externalId])
  @@unique([platform, code])
  @@index([platform, active])
  @@map("shipping_carriers")
}

model ShippingDesiTariff {
  id            String   @id @default(uuid()) @db.Uuid
  carrierId     String   @map("carrier_id") @db.Uuid
  desi          Int
  priceNet      Decimal  @map("price_net") @db.Decimal(10, 2)
  effectiveFrom DateTime @default(now()) @map("effective_from") @db.Date
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  carrier ShippingCarrier @relation(fields: [carrierId], references: [id], onDelete: Cascade)

  @@unique([carrierId, desi])
  @@index([carrierId, desi])
  @@map("shipping_desi_tariffs")
}

model ShippingBaremTariff {
  id             String   @id @default(uuid()) @db.Uuid
  carrierId      String   @map("carrier_id") @db.Uuid
  minOrderAmount Decimal  @map("min_order_amount") @db.Decimal(12, 2)
  maxOrderAmount Decimal  @map("max_order_amount") @db.Decimal(12, 2)
  priceNet       Decimal  @map("price_net") @db.Decimal(10, 2)
  effectiveFrom  DateTime @default(now()) @map("effective_from") @db.Date
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  carrier ShippingCarrier @relation(fields: [carrierId], references: [id], onDelete: Cascade)

  @@unique([carrierId, minOrderAmount, maxOrderAmount])
  @@index([carrierId])
  @@map("shipping_barem_tariffs")
}

model OwnShippingTariff {
  id             String   @id @default(uuid()) @db.Uuid
  organizationId String   @map("organization_id") @db.Uuid
  storeId        String   @map("store_id") @db.Uuid
  desi           Int
  priceNet       Decimal  @map("price_net") @db.Decimal(10, 2)
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")
  createdBy      String?  @map("created_by") @db.Uuid

  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@unique([storeId, desi])
  @@index([organizationId])
  @@map("own_shipping_tariffs")
}

// ─── Profit Calculation V1 — Schema Foundation (PR-1) ──────────────────
// design: docs/plans/2026-05-18-profit-calculation-design.md
// guide:  docs/plans/2026-05-19-profit-calc-implementation-guide.md

// Sistem-düzeyi ücret tanımı — pazaryeri × ücret tipi başına 1 satır,
// effectiveFrom ile zaman bazlı sürümleme (design §3.4). V1'de organizasyon
// override'ı yok; tüm seller'lara aynı kural. Read-only global tablo:
// RLS authenticated SELECT açık (USING true), yazma postgres rolünde.
// Seed PR-2'de Trendyol için 4 satır: PSF 10.99 / PSF_FAST 6.99 / Stopaj %1 /
// Return shipping. effectiveFrom: 2026-05-18 (Trendyol PSF doc okuma tarihi).
model FeeDefinition {
  id          String       @id @default(uuid()) @db.Uuid
  platform    Platform
  feeType     OrderFeeType @map("fee_type")
  displayName String       @map("display_name")

  calculationKind FeeCalculationKind @map("calculation_kind")
  fixedAmountNet  Decimal?           @map("fixed_amount_net") @db.Decimal(12, 2)
  rateOfSale      Decimal?           @map("rate_of_sale") @db.Decimal(7, 4)

  defaultVatRate Decimal @map("default_vat_rate") @db.Decimal(5, 2)

  effectiveFrom DateTime  @map("effective_from")
  effectiveTo   DateTime? @map("effective_to")
  isRequired    Boolean   @default(false) @map("is_required")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  fees OrderFee[]

  @@unique([platform, feeType, effectiveFrom])
  @@index([platform, effectiveFrom])
  @@map("fee_definitions")
}

// Sipariş paket-düzeyi ücret satırı — tüm pazaryeri ücretleri (komisyon hariç,
// o OrderItem'da) burada (design §3.3). source ESTIMATE/SETTLEMENT/CARGO_INVOICE
// karışık yaşar, recomputeSettledProfit filtreyle toplar. PSF/Stopaj ESTIMATE
// satırları PaymentOrder geldiğinde SETTLEMENT'a confirm edilir (§3.7 — confirmedAt
// + confirmedBy bunu izler). organizationId denormalize: insert sırasında stamp.
model OrderFee {
  id              String  @id @default(uuid()) @db.Uuid
  orderId         String  @map("order_id") @db.Uuid
  organizationId  String  @map("organization_id") @db.Uuid
  feeDefinitionId String? @map("fee_definition_id") @db.Uuid

  feeType   OrderFeeType      @map("fee_type")
  source    OrderFeeSource
  direction OrderFeeDirection

  amountNet Decimal @map("amount_net") @db.Decimal(12, 2)
  vatRate   Decimal @map("vat_rate") @db.Decimal(5, 2)
  vatAmount Decimal @map("vat_amount") @db.Decimal(12, 2)

  displayName String? @map("display_name")
  externalRef Json?   @map("external_ref")

  capturedAt  DateTime  @default(now()) @map("captured_at")
  // confirmedAt + confirmedBy: PSF/Stopaj ESTIMATE → SETTLEMENT confirmation
  // PaymentOrder ('Ödeme') entry geldiğinde set'lenir (§3.7). Amount comparison
  // yapılmaz — presence check yeterli (deterministic Trendyol kuralı T+0'da
  // hesaplandı).
  confirmedAt DateTime? @map("confirmed_at")
  confirmedBy String?   @map("confirmed_by")

  order      Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)
  definition FeeDefinition? @relation(fields: [feeDefinitionId], references: [id], onDelete: SetNull)

  @@index([organizationId, feeType])
  @@index([orderId, feeType, source])
  @@map("order_fees")
}

// İade talep görünürlüğü — Trendyol getclaims endpoint Settlement Return'den
// ÖNCE iade talebini gösteriyor (design §3.6). Kar hesabını DOĞRUDAN etkilemez;
// UI'da "iade riski" badge için kullanılır. Settlement Return geldiğinde resolved
// set edilir + REFUND_DEDUCTION / COMMISSION_REFUND / RETURN_SHIPPING OrderFee
// satırları yazılır. trendyolClaimId order başına unique.
model OrderClaim {
  id                  String   @id @default(uuid()) @db.Uuid
  organizationId      String   @map("organization_id") @db.Uuid
  orderId             String   @map("order_id") @db.Uuid
  trendyolClaimId     String   @map("trendyol_claim_id")
  claimDate           DateTime @map("claim_date")
  cargoProviderName   String?  @map("cargo_provider_name")
  cargoTrackingNumber BigInt?  @map("cargo_tracking_number")
  resolved            Boolean
  externalRef         Json?    @map("external_ref")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  order Order            @relation(fields: [orderId], references: [id], onDelete: Cascade)
  items OrderClaimItem[]

  @@unique([orderId, trendyolClaimId])
  @@index([organizationId, resolved])
  @@map("order_claims")
}

// OrderClaim satırlarındaki ürün-bazlı iade sebebi (design §3.6).
// organizationId YOK — RLS parent OrderClaim üzerinden EXISTS walk (order_items
// pattern). reasonCode "DAMAGEDITEM" / "WRONGITEM" gibi enum-benzeri string;
// reasonName Türkçe label (Trendyol'dan direkt). orderItemId nullable çünkü
// match her zaman olmayabilir (item-level eşleme PR-13 sync worker'ında).
model OrderClaimItem {
  id                  String    @id @default(uuid()) @db.Uuid
  claimId             String    @map("claim_id") @db.Uuid
  orderItemId         String?   @map("order_item_id") @db.Uuid
  trendyolClaimItemId String    @map("trendyol_claim_item_id")
  reasonCode          String    @map("reason_code")
  reasonName          String    @map("reason_name")
  status              String
  acceptedBySeller    Boolean   @map("accepted_by_seller")
  autoApproveDate     DateTime? @map("auto_approve_date")
  resolved            Boolean

  claim     OrderClaim @relation(fields: [claimId], references: [id], onDelete: Cascade)
  orderItem OrderItem? @relation(fields: [orderItemId], references: [id], onDelete: SetNull)

  @@index([claimId])
  @@index([orderItemId])
  @@map("order_claim_items")
}

// Organizasyon-düzeyi ücretler — sipariş'e attribute EDİLEMEYEN faturalar
// (design §3.7). Reklam Bedeli (org-wide Roboost), Penalty/Notification fee'leri
// (KDV=0), PSF/Stopaj audit kayıtları (period-level invoice scope ≠ cycle scope).
// Kar hesabını ETKİLEMEZ — yalnız audit/transparency için. paymentOrderId hangi
// PaymentOrder cycle'ında basıldığını tutar (V2 monthly aggregate variance audit
// bu kayıtları kullanır).
model OrgPeriodFee {
  id             String   @id @default(uuid()) @db.Uuid
  organizationId String   @map("organization_id") @db.Uuid
  storeId        String   @map("store_id") @db.Uuid
  paymentOrderId BigInt   @map("payment_order_id")
  paymentDate    DateTime @map("payment_date")

  feeType OrderFeeType   @map("fee_type")
  source  OrderFeeSource

  amountNet Decimal @map("amount_net") @db.Decimal(12, 2)
  vatRate   Decimal @map("vat_rate") @db.Decimal(5, 2)
  vatAmount Decimal @map("vat_amount") @db.Decimal(12, 2)

  invoiceSerialNumber String? @map("invoice_serial_number")
  description         String?
  externalRef         Json?   @map("external_ref")

  capturedAt DateTime @default(now()) @map("captured_at")

  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@index([organizationId, paymentOrderId])
  @@index([organizationId, feeType, paymentDate])
  @@index([storeId, paymentDate])
  @@map("org_period_fees")
}

// Haftalık komisyon faturası aggregate (design §3.8). Trendyol Sale satırlarındaki
// commissionInvoiceSerialNumber (DCF...) bu tabloya bağlanır. İki aşamalı populate:
// (1) T+~5 Sale satırı OrderItem.commissionInvoiceSerialNumber'a string yazar,
// (2) T+~7 'Komisyon Faturası' otherfinancials kaydı geldiğinde CommissionInvoice
// row'u upsert edilir + OrderItem.commissionInvoiceId backfill (PR-3'te).
// orderItems back-relation PR-3'te eklenir (OrderItem.commissionInvoiceId FK
// ile birlikte).
model CommissionInvoice {
  id                   String    @id @default(uuid()) @db.Uuid
  organizationId       String    @map("organization_id") @db.Uuid
  storeId              String    @map("store_id") @db.Uuid
  trendyolSerialNumber String    @map("trendyol_serial_number")
  periodStart          DateTime  @map("period_start")
  periodEnd            DateTime  @map("period_end")
  totalNet             Decimal   @map("total_net") @db.Decimal(14, 2)
  totalVat             Decimal   @map("total_vat") @db.Decimal(14, 2)
  paymentOrderId       BigInt?   @map("payment_order_id")
  paymentDate          DateTime? @map("payment_date")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  store      Store       @relation(fields: [storeId], references: [id], onDelete: Cascade)
  // PR-3'te eklendi: OrderItem.commissionInvoiceId FK ile birlikte iki yönlü relation.
  orderItems OrderItem[]

  @@unique([storeId, trendyolSerialNumber])
  @@index([organizationId, periodStart])
  @@map("commission_invoices")
}

// PR-C1: Trendyol webhook event idempotency log + raw audit trail.
//
// Trendyol payload'da explicit event ID yok (webhook-model.md). Idempotency key
// = composite (storeId, platformOrderId, platformStatus, platformLastModifiedDate).
// Re-delivery (5dk Trendyol retry) aynı timestamp ile gelir; INSERT P2002 →
// 200 OK return, no downstream call.
//
// `rawPayload` jsonb full audit trail — Trendyol payload yapısı değişirse veya
// edge case debugging gerekirse log'tan inceleyebiliriz. 90 gün retention
// (env-configurable WEBHOOK_EVENT_RETENTION_DAYS) — PR-F cleanup cron.
//
// RLS: org-scoped SELECT (admin/owner debugging için). INSERT/UPDATE/DELETE
// yalnız service role (webhook handler postgres role kullanır).
model WebhookEvent {
  id                       String    @id @default(uuid()) @db.Uuid
  organizationId           String    @map("organization_id") @db.Uuid
  storeId                  String    @map("store_id") @db.Uuid
  platform                 Platform
  // Composite idempotency components
  platformOrderId          String    @map("platform_order_id")
  platformStatus           String    @map("platform_status") // raw Trendyol status (mapping öncesi)
  platformLastModifiedDate DateTime  @map("platform_last_modified_date")
  // Processing meta
  receivedAt               DateTime  @default(now()) @map("received_at")
  processedAt              DateTime? @map("processed_at")
  processingError          String?   @map("processing_error")
  // Full payload (jsonb) — debugging + forward-compat
  rawPayload               Json      @map("raw_payload")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  store        Store        @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@unique([storeId, platformOrderId, platformStatus, platformLastModifiedDate], name: "webhook_event_idempotency_key")
  @@index([organizationId, receivedAt(sort: Desc)])
  @@index([storeId, receivedAt(sort: Desc)])
  @@map("webhook_events")
}
