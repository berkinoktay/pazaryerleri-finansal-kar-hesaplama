  attachedBy       String?  @map("attached_by") @db.Uuid

  productVariant ProductVariant @relation(fields: [productVariantId], references: [id], onDelete: Cascade)
  profile        CostProfile    @relation(fields: [profileId], references: [id], onDelete: Restrict)

  @@unique([productVariantId, profileId])
  @@index([profileId])
  @@index([organizationId, productVariantId], map: "idx_pvcp_org_product_variant")
  @@map("product_variant_cost_profiles")
}

model OrderItemCostSnapshotComponent {
  id             String          @id @default(uuid()) @db.Uuid
  orderItemId    String          @map("order_item_id") @db.Uuid
  organizationId String          @map("organization_id") @db.Uuid
  profileId      String          @map("profile_id") @db.Uuid
  profileName    String          @map("profile_name")
  profileType    CostProfileType @map("profile_type")
  // GROSS konvansiyon (2026-06-16): amount(net)+vatAmount вҶ’ amountGross+vatRate.
  // FX: amountInTryGross replaces amountInTry+vatAmountInTry.
  // Net tГјretilir: amountGross Г— 100/(100+vatRate).
  // @default(0): dev truncate+re-sync iГ§in (pre-launch); snapshot sync yazar.
  amountGross      Decimal    @default(0) @map("amount_gross") @db.Decimal(12, 2)
  currency         Currency
  vatRate          Decimal    @default(0) @map("vat_rate") @db.Decimal(5, 2)
  amountInTryGross Decimal    @default(0) @map("amount_in_try_gross") @db.Decimal(12, 2)
  fxRateMode       FxRateMode @map("fx_rate_mode")
  fxRateUsed     Decimal         @map("fx_rate_used") @db.Decimal(14, 6)
  fxRateSource   String          @map("fx_rate_source")

  orderItem OrderItem   @relation(fields: [orderItemId], references: [id], onDelete: Cascade)
  profile   CostProfile @relation(fields: [profileId], references: [id], onDelete: Restrict)

  @@index([orderItemId])
  @@index([organizationId, profileType], map: "idx_oi_cost_snapshot_org_profile_type")
  @@index([organizationId, profileId], map: "idx_oi_cost_snapshot_org_profile_id")
  @@map("order_item_cost_snapshot_components")
}

model FxRate {
