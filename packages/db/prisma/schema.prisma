// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// в”Җв”Җв”Җ Enums в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ

enum MemberRole {
  OWNER
  ADMIN
  MEMBER
  VIEWER
}

enum Platform {
  TRENDYOL
  HEPSIBURADA
}

// FeeDefinition kapsamДұ вҖ” `Platform`'tan AYRI tutulur (denetim A, 2026-06-14).
// Stores/Orders gerГ§ek bir pazaryerine baДҹlДұdДұr (TRENDYOL | HEPSIBURADA) ve bu
// alanlarДұ `z.enum(Platform)` doДҹrular. Гңcret tanДұmlarДұ ise pazaryeri-baДҹДұmsДұz
// olabilir: e-ticaret stopajДұ ve komisyon KDV oranДұ TГңM pazaryerlerinde aynДұdДұr
// вҶ’ `ALL`. `ALL`'Дұ `Platform`'a eklemek stores/orders/adapter/UI switcher'a
// sДұzar (platform='ALL' bir maДҹaza kabul edilirdi). Bu yГјzden ayrДұ enum.
enum FeeScope {
  TRENDYOL
  HEPSIBURADA
  ALL
}

enum StoreEnvironment {
  PRODUCTION
  SANDBOX
}

enum StoreStatus {
  ACTIVE
  CONNECTION_ERROR
  DISABLED
}

enum OrderStatus {
  PENDING
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
  RETURNED
}

enum SettlementStatus {
  PENDING
  VERIFIED
  DISCREPANCY
}

enum SettlementItemType {
  SALE
  RETURN
  COMMISSION
  SHIPPING
  SERVICE_FEE
  PROMOTION
  OTHER
}

enum ExpenseCategory {
  PRODUCT_COST
  ADVERTISING
  PACKAGING
  SHIPPING_SUPPLY
  SOFTWARE
  PERSONNEL
  RENT
  OTHER
}

enum SyncType {
  ORDERS
  PRODUCTS
  SETTLEMENTS
  CLAIMS
}

enum SyncStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
  FAILED_RETRYABLE
}

enum SyncErrorCode {
  MARKETPLACE_AUTH_FAILED
  MARKETPLACE_ACCESS_DENIED
  MARKETPLACE_UNREACHABLE
  SYNC_IN_PROGRESS
  RATE_LIMITED
  VALIDATION_ERROR
  INTERNAL_ERROR
}

enum CostProfileType {
  COGS
  PACKAGING
  SHIPPING
  SOFTWARE
  MARKETING
  OTHER
}

enum Currency {
  TRY
  USD
  EUR
}

enum FxRateMode {
  AUTO
  MANUAL
}

enum ShippingTariffSource {
  TRENDYOL_CONTRACT
  OWN_CONTRACT
}

// Marketplace komisyon tarifesi kuralДұ tГјrГј. CATEGORY yalnДұz kategori bazlДұ;
// CATEGORY_BRAND ek olarak marka kДұrДұlДұmДұ iГ§erir. Trendyol'un "matching rules
// вҶ’ en dГјЕҹГјДҹГј uygulanДұr" mantДұДҹДұ iГ§in iki tГјrГј tek tabloda toplayДұp app-layer'da
// MIN() Гјzerinden resolve ediyoruz.
enum CommissionRuleKind {
  CATEGORY
  CATEGORY_BRAND
}

// SipariЕҹ mutabakat durumu вҖ” kar hesaplama V1 (docs/plans/2026-05-18-profit-calculation-design.md В§3.1).
// NOT_SETTLED: ESTIMATE OrderFee'ler yazДұlДұ, henГјz SETTLEMENT yok.
// PARTIALLY_SETTLED: BazДұ SETTLEMENT/CARGO_INVOICE OrderFee'ler var, Sale.paymentOrderId henГјz null.
// FULLY_SETTLED: Sale paymentOrderId dolu, settledNetProfit yazДұldДұ.
enum ReconciliationStatus {
  NOT_SETTLED
  PARTIALLY_SETTLED
  FULLY_SETTLED
}

// KГўr-dДұЕҹДұ bДұrakma gerekГ§esi (spec 2026-06-12 cost-deadline-profit-freeze В§5).
// Order.profitExclusionReason ile birlikte yaЕҹar вҖ” bkz. Order modelindeki blok.
enum ProfitExclusionReason {
  COST_DEADLINE_MISSED // gece-yarДұsДұ flush'Дұ вҖ” pencere kaГ§tДұ
  LATE_UNCOSTED_ARRIVAL // geГ§miЕҹ-gГјn gelen maliyetsiz sipariЕҹ (karar K3)
  LEGACY_BACKFILL // spec Г¶ncesi null-kГўrla yazДұlmДұЕҹ mevcut satДұrlar (migration)
}

// OrderFee tipi вҖ” pazaryeri Гјcretlerinin tek kaynaДҹДұ (design В§3.3).
// Д°ki kategori: sipariЕҹ-dГјzeyi (OrderFee tablosuna yazДұlДұr) ve org-dГјzeyi
// (OrgPeriodFee tablosuna yazДұlДұr вҖ” Reklam, Penalty, Notification, COMMISSION_INVOICE).
// PLATFORM_SERVICE + PLATFORM_SERVICE_FAST ayrДұ FeeDefinition row'larДұyla seГ§ilir;
// FAST yalnДұzca fastDelivery=true + deliveredOnTime=true durumda uygulanДұr (В§3.4).
enum OrderFeeType {
  SHIPPING
  PLATFORM_SERVICE
  PLATFORM_SERVICE_FAST
  STOPPAGE
  RETURN_SHIPPING
  REFUND_DEDUCTION
  COMMISSION_REFUND
  COST_RETURN
  STOPPAGE_REFUND
  PROVISION_ADJUSTMENT
  MANUAL_REFUND
  REVENUE_ADJUSTMENT
  COMMISSION_ADJUSTMENT
  CUSTOM
  ADVERTISING
  PENALTY_DEFECTIVE
  PENALTY_WRONG_PRODUCT
  PENALTY_MISSING_PRODUCT
  PENALTY_LATE_DELIVERY
  PENALTY_SUPPLY_FAILURE
  NOTIFICATION_FEE
  COMMISSION_INVOICE
  // Mikro ihracat (Order.micro=true) вҖ” marketplace ihracat sipariЕҹlerine Г¶zgГј iki Гјcret:
  // INTERNATIONAL_SERVICE: ГјrГјn satДұЕҹДұ Гјzerinden %6 KDV-dahil "UluslararasДұ Hizmet Bedeli"
  //   (PSF mikro ihracatta uygulanmaz; bunun yerine bu Гјcret kesilir). Tahmin yolunda yazДұlДұr.
  // OVERSEAS_RETURN_OPERATION: iadede satДұЕҹ reverse edilmez, ayrДұca (satДұЕҹвҲ’komisyon)Г—%35/%30
  //   "Yurt DДұЕҹДұ Д°ade Operasyon Bedeli" kesilir (iade yolunda yazДұlДұr).
  INTERNATIONAL_SERVICE
  OVERSEAS_RETURN_OPERATION
}

// OrderFee'nin kaynaДҹДұ вҖ” audit + reconciliation algoritmasДұ iГ§in kritik (В§3.3).
// ESTIMATE: applyEstimateOnOrderCreate (T+0 deterministic).
// SETTLEMENT: settlements/otherfinancials API'sinden.
// CARGO_INVOICE: cargo-invoice/{serial}/items per-order match.
// USER_OVERRIDE: kullanДұcДұ dГјzeltti. MANUAL_ENTRY: kullanДұcДұ ekledi (reklam vs.).
enum OrderFeeSource {
  ESTIMATE
  SETTLEMENT
  CARGO_INVOICE
  USER_OVERRIDE
  MANUAL_ENTRY
}

enum OrderFeeDirection {
  DEBIT
  CREDIT
}

// FeeDefinition hesap tГјrГј вҖ” sistem-dГјzeyi Гјcret tanДұmlarДұ (В§3.4).
// FIXED: sabit tutar (PSF вӮә10.99). RATE_OF_SALE: satДұЕҹДұn yГјzdesi (Stopaj %1).
// FORMULA: V2'ye ertelendi (karmaЕҹДұk formГјller).
enum FeeCalculationKind {
  FIXED
  RATE_OF_SALE
  FORMULA
}

// Live Performance buffer entry durum makinesi (Spec 2 PR-A).
// PENDING (cost yok) вҶ’ PROMOTING (cost geldi, promote worker bekliyor) вҶ’
// orders'a yazДұlДұp buffer'dan DELETE (success) ya da FAILED вҶ’ PERMANENT_FAILED.
enum BufferEntryStatus {
  PENDING
  PROMOTING
  FAILED
  PERMANENT_FAILED

  @@map("buffer_entry_status")
}

// Trendyol fiyat yazma denetim kaydДұ durumu (Task 1 вҖ” trendyol-price-write).
// PENDING: istek gГ¶nderildi, batchId alДұndДұ, yoklama bekleniyor.
// SUCCESS: yoklama COMPLETED + item status SUCCESS вҶ’ DB write-back yapДұldДұ.
// FAILED: yoklama FAILED veya timeout вҶ’ DB write-back yapДұlmadДұ.
enum PriceChangeStatus {
  PENDING
  SUCCESS
  FAILED
}

// Flash Products (FlaЕҹ ГңrГјnler) join type per item. A row offers up to two
// windows вҖ” H24 (24-hour slot) and H3 (3-hour slot). The seller picks one, or
// sets a custom price instead (customPrice, mutually exclusive). Emitted as a
// domain enum for the frontend column language ("24 Saatlik" / "3 Saatlik").
enum FlashOfferType {
  H24
  H3
}

// в”Җв”Җв”Җ Models в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ

model UserProfile {
  id                String   @id @db.Uuid
  email             String   @unique
  fullName          String?  @map("full_name")
  avatarUrl         String?  @map("avatar_url")
  timezone          String   @default("Europe/Istanbul")
  preferredLanguage String   @default("tr") @map("preferred_language")
  preferences       Json     @default("{}") @map("preferences")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  memberships OrganizationMember[]

  @@map("user_profiles")
}

model Organization {
  id        String   @id @default(uuid()) @db.Uuid
  name      String
  slug      String   @unique
  currency  String   @default("TRY")
  timezone  String   @default("Europe/Istanbul")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  members               OrganizationMember[]
  stores                Store[]
  expenses              Expense[]
  syncLogs              SyncLog[]
  costProfiles          CostProfile[]
  webhookEvents         WebhookEvent[]
  memberStoreAccess     MemberStoreAccess[]
  livePerformanceBuffer LivePerformanceBuffer[]
  catalogBarcodeMisses  CatalogBarcodeMiss[]
  priceChangeLogs       PriceChangeLog[]

  @@map("organizations")
}

model OrganizationMember {
  id             String     @id @default(uuid()) @db.Uuid
  organizationId String     @map("organization_id") @db.Uuid
  userId         String     @map("user_id") @db.Uuid
  role           MemberRole @default(MEMBER)
  lastAccessedAt DateTime?  @map("last_accessed_at")
  createdAt      DateTime   @default(now()) @map("created_at")
  updatedAt      DateTime   @updatedAt @map("updated_at")

  organization Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         UserProfile         @relation(fields: [userId], references: [id], onDelete: Cascade)
  storeAccess  MemberStoreAccess[]

  @@unique([organizationId, userId])
  @@index([userId, lastAccessedAt(sort: Desc)], map: "idx_org_members_user_last_accessed")
  @@map("organization_members")
}

model Store {
  id                       String               @id @default(uuid()) @db.Uuid
  organizationId           String               @map("organization_id") @db.Uuid
  name                     String
  platform                 Platform
  environment              StoreEnvironment     @default(PRODUCTION)
  externalAccountId        String               @map("external_account_id")
  credentials              Json
  status                   StoreStatus          @default(ACTIVE)
  isActive                 Boolean              @default(true) @map("is_active")
  lastConnectedAt          DateTime?            @map("last_connected_at")
  lastSyncAt               DateTime?            @map("last_sync_at")
  shippingTariffSource     ShippingTariffSource @default(TRENDYOL_CONTRACT) @map("shipping_tariff_source")
  defaultShippingCarrierId String?              @map("default_shipping_carrier_id") @db.Uuid
  // MaДҹaza-bazlДұ kГўr formГјlГј ayarlarДұ (JSONB, geniЕҹletilebilir вҖ” UserProfile.preferences deseni).
  // Еһekil: { includeStopaj?: boolean, includeNegativeNetVat?: boolean }. BoЕҹ {} = varsayДұlanlar
  // (@pazarsync/utils resolveProfitSettings ile Г§Г¶zГјlГјr: includeStopaj=true, includeNegativeNetVat=false).
  // SNAPSHOT-AT-CREATE: bu CANLI ayardДұr; sipariЕҹ ilk hesaplanДұrken Order.snapshot* kolonlarДұna
  // snapshot'lanДұr, sonraki hesaplar snapshot'Дұ okur (bu kolonu DEДһД°L). GeГ§miЕҹ sipariЕҹ asla
  // yeniden hesaplanmaz вҖ” ayar deДҹiЕҹimi yalnДұz BUNDAN SONRA oluЕҹan sipariЕҹleri etkiler.
  profitSettings           Json                 @default("{}") @map("profit_settings")
  // в”Җв”Җв”Җ PR-C1: Trendyol webhook subscription в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
  // webhookId: Trendyol'un atadДұДҹДұ subscription UUID (POST /webhooks response.id).
  //   PUT/DELETE call'larДұnda kullanДұlДұr. Register fail'de null kalДұr.
  // webhookSecret: AES-256-GCM ciphertext (base64) of JSON.stringify({username, password}).
  //   Random generated at register; decrypt only inside verify middleware.
  // webhookActiveAt: son register/rotate timestamp. UI badge "webhook baДҹlДұ" gГ¶stergesi.
  // ГңГ§Гј de nullable: mevcut store'lar geriye dГ¶nГјk register zorunda deДҹil; failed
  // register transient olabilir; non-TRENDYOL platformlarda da null kalДұr.
  webhookId                String?              @map("webhook_id")
  webhookSecret            String?              @map("webhook_secret")
  webhookActiveAt          DateTime?            @map("webhook_active_at")
  createdAt                DateTime             @default(now()) @map("created_at")
  updatedAt                DateTime             @updatedAt @map("updated_at")

  organization           Organization            @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  products               Product[]
  productVariants        ProductVariant[]
  orders                 Order[]
  settlements            Settlement[]
  syncLogs               SyncLog[]
  webhookEvents          WebhookEvent[]
  defaultShippingCarrier ShippingCarrier?        @relation(fields: [defaultShippingCarrierId], references: [id], onDelete: SetNull)
  ownShippingTariffs     OwnShippingTariff[]
  commissionTariffs      CommissionTariff[]
  plusCommissionTariffs  PlusCommissionTariff[]
  advantageTariffs       AdvantageTariff[]
  flashProductLists      FlashProductList[]
  orgPeriodFees          OrgPeriodFee[]
  commissionInvoices     CommissionInvoice[]
  memberAccess           MemberStoreAccess[]
  livePerformanceBuffer  LivePerformanceBuffer[]
  orderClaims            OrderClaim[]
  catalogBarcodeMisses   CatalogBarcodeMiss[]
  priceChangeLogs        PriceChangeLog[]

  @@unique([organizationId, platform, externalAccountId])
  @@index([organizationId])
  @@map("stores")
}

// в”Җв”Җв”Җ Member вҶ” Store access grants в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
// Which stores a MEMBER/VIEWER may see. OWNER/ADMIN see every store in their
// org by role and need NO rows here (enforced in can_access_store + services).
// A grant is scoped to a membership: deleting the member cascades its grants.
// organization_id is denormalized for flat RLS + indexing (same pattern as
// products / sync_logs). granted_by is an audit pointer to the granting
// OrganizationMember.id (plain uuid, no FK вҖ” avoids a second self-relation).
model MemberStoreAccess {
  id             String   @id @default(uuid()) @db.Uuid
  organizationId String   @map("organization_id") @db.Uuid
  memberId       String   @map("member_id") @db.Uuid
  storeId        String   @map("store_id") @db.Uuid
  grantedBy      String?  @map("granted_by") @db.Uuid
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  member       OrganizationMember @relation(fields: [memberId], references: [id], onDelete: Cascade)
  store        Store              @relation(fields: [storeId], references: [id], onDelete: Cascade)
  organization Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([memberId, storeId])
  @@index([storeId])
  @@index([organizationId])
  @@map("member_store_access")
}

// Parent вҖ” one row per Trendyol contentId. Shared content fields
// (title, description, brand, category, color, images) live here. SKU-level
// fields (barcode, stockCode, price, stock, delivery, size) live on
// ProductVariant. The split mirrors how the marketplace itself models
// products and avoids lossy denormalization across N variants.
model Product {
  id                 String    @id @default(uuid()) @db.Uuid
  organizationId     String    @map("organization_id") @db.Uuid
  storeId            String    @map("store_id") @db.Uuid
  platformContentId  BigInt    @map("platform_content_id")
  productMainId      String    @map("product_main_id")
  title              String
  description        String?   @db.Text
  brandId            BigInt?   @map("brand_id")
  brandName          String?   @map("brand_name")
  categoryId         BigInt?   @map("category_id")
  categoryName       String?   @map("category_name")
  color              String?
  attributes         Json      @default("[]")
  approved           Boolean   @default(true)
  platformCreatedAt  DateTime? @map("platform_created_at")
  platformModifiedAt DateTime? @map("platform_modified_at")
  lastSyncedAt       DateTime  @default(now()) @map("last_synced_at")
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")

  // Denormalized SUM(variants[*].quantity) for the store. Updated
  // transactionally inside upsertBatch in the sync worker вҖ” see
  // apps/sync-worker/src/handlers/products.ts. Indexed for the
  // products-list sort=totalStock workflow (pricing + restock review).
  totalStock Int @default(0) @map("total_stock")

  // Denormalized MIN/MAX(variants[*].salePrice) for the store, updated in the
  // same upsertBatch transaction as totalStock (NOT a trigger вҖ” the sync worker
  // stays the single writer). Prisma 7 cannot MAX() over a Decimal child
  // relation in orderBy, so products-list sort=salePrice reads these columns,
  // and the salePrice range filter (PR-B2) tests overlap against both bounds.
  // NULL only for a product with zero variants. No @updatedAt (data columns).
  minSalePrice Decimal? @map("min_sale_price") @db.Decimal(12, 2)
  maxSalePrice Decimal? @map("max_sale_price") @db.Decimal(12, 2)

  store    Store            @relation(fields: [storeId], references: [id], onDelete: Cascade)
  variants ProductVariant[]
  images   ProductImage[]

  @@unique([storeId, platformContentId])
  @@index([organizationId])
  @@index([storeId, productMainId])
  @@index([storeId, brandId])
  @@index([storeId, totalStock])
  @@index([storeId, minSalePrice, maxSalePrice])
  @@index([storeId, categoryId])
  @@map("products")
}

// Child вҖ” one row per Trendyol variantId (SKU). organizationId is denormalized
// here so the RLS policy can be a flat `is_org_member(organization_id)` USING
// clause without recursing through Product (avoids the 42P17 trap, see
// supabase/sql/rls-policies.sql for the full rationale).
model ProductVariant {
  id                      String   @id @default(uuid()) @db.Uuid
  organizationId          String   @map("organization_id") @db.Uuid
  storeId                 String   @map("store_id") @db.Uuid
  productId               String   @map("product_id") @db.Uuid
  platformVariantId       BigInt   @map("platform_variant_id")
  barcode                 String
  stockCode               String   @map("stock_code")
  salePrice               Decimal  @map("sale_price") @db.Decimal(12, 2)
  listPrice               Decimal  @map("list_price") @db.Decimal(12, 2)
  vatRate                 Int?     @map("vat_rate")
  costPrice               Decimal? @map("cost_price") @db.Decimal(12, 2)
  // PSF muafiyet kuralДұ: tГјm OrderItem'larda isDigital=true вҶ’ PSF=0 (design В§3.7).
  // V1: kullanДұcДұ UI'dan iЕҹaretler (variant settings toggle). V2: Trendyol kategori
  // lookup ile otomatik tahmin.
  isDigital               Boolean  @default(false) @map("is_digital")
  // Two-column sync-protection pair (see docs/plans/archive/... for rationale):
  // syncedDimensionalWeight is the marketplace's value, refreshed every sync.
  // dimensionalWeight is the user's manual override; null = no override, fall
  // back to synced at read time. The sync worker writes ONLY to the synced
  // column вҖ” never to dimensionalWeight вҖ” so the "user value is sacred"
  // invariant is structural, not just enforced in code.
  //
  // Desi floor = 0: the synced column is NON-NULL with default 0. Trendyol
  // omits desi on most products; the mapper stores 0 (not null) so the
  // products page shows 0 and the data has no nulls. Desi 0 is a VALID tariff
  // tier вҖ” cargo fee is matched from the tariff table (carrier + ceil(desi)),
  // which covers desi 0 onward, so a 0-desi variant still gets a real cargo
  // cost. The override stays nullable (null = "no override"). A CHECK
  // constraint forbids any value below 0 on either column (see migration
  // dimensional_weight_zero_floor).
  syncedDimensionalWeight Decimal  @default(0) @map("synced_dimensional_weight") @db.Decimal(6, 2)
  dimensionalWeight       Decimal? @map("dimensional_weight") @db.Decimal(6, 2)
  quantity                Int      @default(0)
  deliveryDuration        Int?     @map("delivery_duration")
  isRushDelivery          Boolean  @default(false) @map("is_rush_delivery")
  fastDeliveryOptions     Json     @default("[]") @map("fast_delivery_options")
  productUrl              String?  @map("product_url") @db.Text
  locationBasedDelivery   String?  @map("location_based_delivery")
  onSale                  Boolean  @default(true) @map("on_sale")
  archived                Boolean  @default(false)
  blacklisted             Boolean  @default(false)
  locked                  Boolean  @default(false)
  size                    String?
  attributes              Json     @default("[]")
  lastSyncedAt            DateTime @default(now()) @map("last_synced_at")
  createdAt               DateTime @default(now()) @map("created_at")
  updatedAt               DateTime @updatedAt @map("updated_at")

  product          Product                     @relation(fields: [productId], references: [id], onDelete: Cascade)
  store            Store                       @relation(fields: [storeId], references: [id], onDelete: Cascade)
  orderItems       OrderItem[]
  costProfileLinks ProductVariantCostProfile[]
  priceChangeLogs  PriceChangeLog[]

  @@unique([storeId, platformVariantId])
  // Intentionally NOT unique on (storeId, barcode): marketplaces enforce
  // barcode uniqueness on their side at listing time, but their sandbox
  // and certain real-world catalogs ship variants with duplicate
  // barcodes (different platformVariantId, same printed barcode вҖ” e.g.
  // multi-pack vs single-unit variants of the same SKU). Treating
  // barcode as unique at our layer caused 3 product upserts to fail per
  // sync against the dev/sandbox account; the products were silently
  // dropped via skip-on-error in apps/sync-worker/src/handlers/products.ts.
  // Lookups by barcode (e.g. order item resolution) are non-unique in
  // principle anyway вҖ” we resolve via platformVariantId.
  @@index([storeId, barcode])
  @@index([organizationId])
  @@index([productId])
  @@index([storeId, stockCode])
  @@index([storeId, onSale, archived])
  @@map("product_variants")
}

model ProductImage {
  id             String   @id @default(uuid()) @db.Uuid
  organizationId String   @map("organization_id") @db.Uuid
  productId      String   @map("product_id") @db.Uuid
  url            String   @db.Text
  position       Int      @default(0)
  createdAt      DateTime @default(now()) @map("created_at")

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId, position])
  @@map("product_images")
}

model Order {
  id              String      @id @default(uuid()) @db.Uuid
  organizationId  String      @map("organization_id") @db.Uuid
  storeId         String      @map("store_id") @db.Uuid
  platformOrderId String      @map("platform_order_id")
  orderDate       DateTime    @map("order_date")
  status          OrderStatus
  // ESKД° ГңCRET KOLONLARI (totalAmount, commissionAmount, shippingCost, platformFee,
  // vatAmount, netProfit) PR-5c'de SД°LД°NDД° (2026-05-19). Yeni convention iГ§in:
  // - SatДұЕҹ: saleSubtotalNet + saleVatTotal (aЕҹaДҹДұda PR-5a)
  // - Komisyon: OrderItem.grossCommissionAmountNet/VatAmount (PR-3)
  // - Kargo/PSF/Stopaj: OrderFee tablosunda (PR-1)
  // - Kar: estimatedNetProfit / settledNetProfit (PR-5a, write-once + mutable)

  // Trendyol data-input alanlarДұ (sync handler PR-6'da set eder, design В§3.1).
  // agreedDeliveryDate: getShipmentPackages endpoint direkt field.
  // actualDeliveryDate: packageHistories[status='Delivered'].createdAt'den tГјretilir;
  //   Delivered status webhook'unda set'lenir. Order endpoint'te direkt field YOK.
  agreedDeliveryDate DateTime? @map("agreed_delivery_date")
  actualDeliveryDate DateTime? @map("actual_delivery_date")
  // actualShipDate: packageHistories[status='Shipped'].createdDate вҖ” "taЕҹДұma durumuna
  //   geГ§iЕҹ" anДұ (RAW GMT). SameDayShipping PSF kriterinin (aynДұ-gГјn sevk, 2026-06-14)
  //   tabanДұ. NOT: originShipmentDate = kargoya-hazДұr anДұ (вүҲ sipariЕҹ) вҶ’ gerГ§ek sevk DEДһД°L.
  actualShipDate     DateTime? @map("actual_ship_date")
  // estimatedDelivery{Start,End}Date: getShipmentPackages tahmini teslim penceresi.
  //   PROD'da dolu (2026-06-14 gГ¶zlem 11314118846); stage test sipariЕҹlerinde 0 вҶ’ null.
  estimatedDeliveryStartDate DateTime? @map("estimated_delivery_start_date")
  estimatedDeliveryEndDate   DateTime? @map("estimated_delivery_end_date")
  // fastDelivery: getShipmentPackages direkt boolean (BugГјn Kargoda indikatГ¶rГј).
  // fastDeliveryType: "TodayDelivery"|"SameDayShipping"|"FastDelivery" вҖ” sipariЕҹ
  //   seviyesinde yalnДұz PROD'da dolar (stage "" вҶ’ null). Per-tip kriterin kaynaДҹДұ
  //   (hibrit tasarДұm 2026-06-14): "fast mДұ + tip" sipariЕҹten, cutoff ГјrГјnden.
  // micro: getShipmentPackages direkt boolean (mikro ihracat) вҖ” PSF muafiyeti.
  fastDelivery       Boolean   @default(false) @map("fast_delivery")
  fastDeliveryType   String?   @map("fast_delivery_type")
  micro              Boolean   @default(false) @map("micro")

  // в”Җв”Җв”Җ GROSS konvansiyon: sipariЕҹ-seviyesi agregat alanlar (2026-06-16) в”Җв”Җв”Җв”Җв”Җв”Җ
  // Paket toplamlarДұ mapper'dan doДҹrudan gelir (Trendyol packageGrossAmount/
  // packageTotalPrice/packageSellerDiscount). saleVat satДұr-bazlДұ hesaplanДұr
  // (ОЈ lineSaleGross Г— saleVatRate / (100+rate)). sellerDiscountVat aynДұ pattern.
  // listGross = saleGross + sellerDiscountGross. Eski saleSubtotalNet/saleVatTotal
  // GROSS refactor kapsamДұnda kaldДұrДұldДұ (2026-06-16).
  saleGross              Decimal? @map("sale_gross") @db.Decimal(12, 2)
  saleVat                Decimal? @map("sale_vat") @db.Decimal(12, 2)
  listGross              Decimal? @map("list_gross") @db.Decimal(12, 2)
  sellerDiscountGross    Decimal? @map("seller_discount_gross") @db.Decimal(12, 2)
  sellerDiscountVat      Decimal? @map("seller_discount_vat") @db.Decimal(12, 2)

  // Marj yГјzdeleri вҖ” backend hesaplanДұp persist edilir (sДұralanabilir + kayДұtlДұ).
  // estimatedSaleMarginPct = estimatedNetProfit / saleGross Г— 100 (saleGross=0вҶ’null).
  // settledSaleMarginPct   = settledNetProfit  / saleGross Г— 100.
  // estimatedCostMarkupPct = estimatedNetProfit / ОЈ costGross Г— 100.
  // settledCostMarkupPct   = settledNetProfit  / ОЈ costGross Г— 100.
  estimatedSaleMarginPct Decimal? @map("estimated_sale_margin_pct") @db.Decimal(8, 4)
  settledSaleMarginPct   Decimal? @map("settled_sale_margin_pct") @db.Decimal(8, 4)
  estimatedCostMarkupPct Decimal? @map("estimated_cost_markup_pct") @db.Decimal(8, 4)
  settledCostMarkupPct   Decimal? @map("settled_cost_markup_pct") @db.Decimal(8, 4)

  // Promosyon gГ¶sterimi (YAGNI вҖ” spec ekleme #3). Opsiyonel JSON dizisi:
  // [{ "displayName": "SatДұcДұ Д°ndirimi", "amountGross": "48.01" }, ...].
  // Mapper null dГ¶ner indirim yoksa; upsert null'a dokunmaz.
  promotionDisplays      Json?    @map("promotion_displays")

  // Д°ki aЕҹamalДұ kar (design В§4.1):
  // - estimatedNetProfit: T+0 applyEstimateOnOrderCreate yazar, write-once (PR-9 trigger).
  // - settledNetProfit:   T+~5+ recomputeSettledProfit yazar, mutable (iade gГјncellemeleri).
  //
  // INVARIANT (2026-06-14 karar вҖ” HakediЕҹ KontrolГј temeli): Д°KД°SД° DE satДұcДұnДұn
  // HAK ETTД°ДһД° net kГўrdДұr (effectiveSale + Trendyol'un yetkili komisyon/kargosu,
  // doДҹru oranlarla). Trendyol'un GERГҮEKTE Г–DEDД°ДһД° tutar DEДһД°LDД°R. Bu kolonlar
  // ASLA underpaid bir actual-payout'a sessizce ГҮEKД°LMEZ. Beklenen (bu kolonlar)
  // vs gerГ§ek-yatan (Trendyol payout) farkДұ = gelecek "HakediЕҹ KontrolГј" epiДҹi;
  // farkДұ itiraz-edilebilir kalem olarak gГ¶sterir, satДұcДұ Д°tiraz/GГ¶z ardДұ seГ§er.
  // "ГҮek" kararДұ satДұcДұnДұndДұr, sistemin deДҹil. (OrderItem.settledSaleAmount =
  // mutabakatДұn actual-satДұЕҹ Г§ДұpasДұ.)
  estimatedNetProfit   Decimal?             @map("estimated_net_profit") @db.Decimal(12, 2)
  settledNetProfit     Decimal?             @map("settled_net_profit") @db.Decimal(12, 2)

  // Net KDV (output вҲ’ input KDV) вҖ” computeProfit'in ГјrettiДҹi netVat. estimatedNetProfit /
  // settledNetProfit ile AYNI yaЕҹam dГ¶ngГјsГј (estimate refinable, settled mutable; ikisi de
  // profit-excluded'da yazДұlmaz вҶ’ null kalДұr). Frontend kГўr dГ¶kГјmГјnde "Net KDV" satДұrДұnДұ
  // backend-hesaplДұ gГ¶sterir (frontend ASLA tГјretmez). Net KDV negatif olabilir вҶ’ CHECK yok.
  estimatedNetVat      Decimal?             @map("estimated_net_vat") @db.Decimal(12, 2)
  settledNetVat        Decimal?             @map("settled_net_vat") @db.Decimal(12, 2)

  // в”Җв”Җв”Җ KГўr formГјlГј ayar snapshot'Дұ (snapshot-at-create, forward-only) в”Җв”Җв”Җв”Җв”Җв”Җ
  // applyEstimateOnOrderCreate sipariЕҹ Д°LK hesaplanДұrken maДҹazanДұn o anki
  // Store.profitSettings'ini Г§Г¶zГјp buraya YAZAR (write-once). Sonraki TГңM hesaplar
  // (kargo rafinesi re-entry + settlement recompute) bu snapshot'Дұ okur, canlДұ ayarДұ
  // DEДһД°L. MaДҹaza ayarДұ deДҹiЕҹince yalnДұz BUNDAN SONRA yaratДұlan sipariЕҹler etkilenir;
  // geГ§miЕҹ sipariЕҹ asla yeniden hesaplanmaz (maliyet snapshot'Дұyla aynДұ felsefe).
  // Nullable: snapshot henГјz yazДұlmamДұЕҹ / kГўr-dДұЕҹДұ sipariЕҹ = null; okurken null вҶ’
  // @pazarsync/utils DEFAULT_PROFIT_SETTINGS (resolveSnapshotProfitSettings).
  snapshotIncludeStopaj         Boolean?            @map("snapshot_include_stopaj")
  snapshotIncludeNegativeNetVat Boolean?            @map("snapshot_include_negative_net_vat")

  // в”Җв”Җв”Җ KГўr dondurma (spec 2026-06-12 cost-deadline-profit-freeze) в”Җв”Җв”Җв”Җв”Җв”Җ
  // Maliyet penceresi (sipariЕҹ gГјnГјnГјn sonu, Д°stanbul) kaГ§ДұrДұldДұysa sipariЕҹ
  // KALICI olarak kГўr evreninin dДұЕҹДұnda: estimatedNetProfit sonsuza dek null,
  // settledNetProfit hesaplanmaz (karar K1); ciro raporlanДұr. Geri dГ¶nГјЕҹ yok вҖ”
  // reject_profit_freeze_breach trigger'Дұ + CHECK her yolu kapatДұr.
  profitExcludedAt      DateTime?              @map("profit_excluded_at")
  profitExclusionReason ProfitExclusionReason? @map("profit_exclusion_reason")

  // Durum makinesi: NOT_SETTLED вҶ’ PARTIALLY_SETTLED вҶ’ FULLY_SETTLED (design В§6.1).
  // Д°lk SETTLEMENT/CARGO_INVOICE OrderFee yazДұldДұДҹДұnda PARTIALLY_SETTLED, Sale
  // satДұrДұnДұn paymentOrderId'si dolu gГ¶rГјldГјДҹГјnde FULLY_SETTLED.
  reconciliationStatus ReconciliationStatus @default(NOT_SETTLED) @map("reconciliation_status")

  // PaymentOrder baДҹlantДұsДұ вҖ” mutabakat sinyali (В§3.7). Sale.paymentOrderId dolu
  // gГ¶rГјldГјДҹГјnde Order'a yansДұtДұlДұr вҶ’ handlePaymentOrderEntry tetiklenir вҶ’
  // cycle'daki PSF/Stopaj ESTIMATE'leri SETTLEMENT'a confirm + recomputeSettledProfit.
  paymentOrderId BigInt?   @map("payment_order_id")
  paymentDate    DateTime? @map("payment_date")

  // TГјretilmiЕҹ: actualDeliveryDate <= agreedDeliveryDate вҶ’ true (BugГјn Kargoda PSF).
  // applyEstimate hesaplamasДұ: inferDeliveredOnTime(order) вҖ” null = henГјz delivered deДҹil.
  deliveredOnTime Boolean? @map("delivered_on_time")

  // Trendyol orderNumber (Гјst sipariЕҹ, paket-ГјstГј). platformOrderId = shipmentPackageId
  // (paket-seviyesi); platformOrderNumber = orderNumber (split shipment'ta N pakete
  // referans verir). PR-5b veri taЕҹДұma mevcut yanlДұЕҹ dolu rows'u doДҹrultur (В§9 PR-5b).
  platformOrderNumber String? @map("platform_order_number")

  // в”Җв”Җв”Җ PR-8: Kargo alanlarДұ (research 2026-06-09) в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
  // cargoTrackingNumber: paket OLUЕһURKEN atanДұr (kargoya verilmeden); kargo
  //   faturasДұ satДұrДұndaki parcelUniqueId ile BД°REBД°R AYNI (prod kanДұtlДұ) вҖ”
  //   faturaвҶ’sipariЕҹ eЕҹleЕҹtirmesinin birincil anahtarДұ. Д°lk 3 hane kargocu
  //   Г¶nekidir (733 TEX, 725 YurtiГ§i, 734 PTT, 884 Horoz, 732 Alternatif).
  // cargoDeci: Trendyol'un Г–LГҮTГңДһГң desi вҖ” tahmin-vs-fatura karЕҹДұlaЕҹtДұrmasДұnДұn
  //   zemini. Stage'de hiГ§ gelmez, prod'da kargo Г¶lГ§ГјmГјnden sonra dolar вҶ’
  //   upsert UPDATE'i gelen null ile dolu deДҹeri EZMEZ.
  // usesSellerCargoAgreement: Trendyol whoPays==1 вҶ’ satДұcДұnДұn KENDД° kargo
  //   anlaЕҹmasДұ: Trendyol kargo faturasДұ KESMEZ, maliyet bizim satДұcДұ-anlaЕҹma
  //   tarifemizden gelir. Alan yoksa Trendyol anlaЕҹmasДұ (fatura bekleriz).
  // platformCreatedBy: paket kaynaДҹДұ ("order-creation" | "split" | "transfer"
  //   | ...) вҖ” split soy aДҹacДұ gГ¶rГјnГјrlГјДҹГј.
  // originShipmentDate: kargoya-hazДұr anДұ (true UTC, RAW) вҖ” ship-time KPI.
  cargoProviderName        String?   @map("cargo_provider_name")
  cargoTrackingNumber      BigInt?   @map("cargo_tracking_number")
  cargoDeci                Decimal?  @map("cargo_deci") @db.Decimal(8, 2)
  usesSellerCargoAgreement Boolean   @default(false) @map("uses_seller_cargo_agreement")
  platformCreatedBy        String?   @map("platform_created_by")
  originShipmentDate       DateTime? @map("origin_shipment_date")

  // Marketplace-side lastModifiedDate of the most recent event / sync page applied
  // to this row. Used by the order upsert as an out-of-order guard: a stale webhook
  // re-delivery or a racing hourly-sync page must never regress status/fields already
  // written by a newer event. Nullable: legacy rows and buffer-JSONB replays without
  // the field skip the guard.
  platformLastModifiedAt DateTime? @map("platform_last_modified_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  store  Store        @relation(fields: [storeId], references: [id], onDelete: Cascade)
  items  OrderItem[]
  fees   OrderFee[]
  claims OrderClaim[]

  @@unique([storeId, platformOrderId])
  @@index([organizationId])
  @@index([organizationId, reconciliationStatus])
  @@index([orderDate])
  @@index([platformOrderNumber])
  @@index([storeId, paymentOrderId])
  // Kargo faturasДұ eЕҹleЕҹtirmesi: parcelUniqueId == cargoTrackingNumber lookup.
  @@index([storeId, cargoTrackingNumber])
  @@map("orders")
}

model OrderItem {
  id               String    @id @default(uuid()) @db.Uuid
  orderId          String    @map("order_id") @db.Uuid
  productVariantId String?   @map("product_variant_id") @db.Uuid
  organizationId   String?   @map("organization_id") @db.Uuid
  quantity         Int
  // PR-8: Trendyol satДұr kimliДҹi (lines[].lineId) + ham barkod. platformLineId
  // platform-taraflДұ satДұr izi (aynДұ varianttan 2 ayrДұ satДұr ayrДұmДұ); barcode
  // variant eЕҹleЕҹmediДҹinde elde kalan tek ГјrГјn izi ("variant bulunamadДұ" UI'Дұ).
  platformLineId BigInt?   @map("platform_line_id")
  barcode        String?
  // Variant-resolution kuyruДҹu (spec 2026-06-11 В§5): productVariantId NULL
  // satДұrlar iГ§in deneme sayacДұ + backoff vadesi. Tick yalnДұz vadesi gelmiЕҹ
  // satДұrlarДұ tarar; baДҹlanДұnca alanlar anlamДұnДұ yitirir (sДұfДұrlanmaz).
  variantResolutionAttempts Int       @default(0) @map("variant_resolution_attempts")
  nextResolutionAt          DateTime? @map("next_resolution_at")

  // в”Җв”Җв”Җ GROSS konvansiyon (2026-06-16) в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
  // TГјm para deДҹerleri GROSS (KDV-dahil) olarak tutulur; net = gross Г— 100/(100+rate).
  // Trendyol paket toplamlarДұ gross olarak gelir вҶ’ mapper artДұk bГ¶lГјp Г§arpmaz.

  // SatДұЕҹ (gross + KDV oranДұ)
  // lineListGross: Trendyol lineListPrice Г— quantity вҖ” liste fiyatДұ toplamДұ.
  // lineSaleGross: Trendyol lineGrossAmount вҖ” satДұЕҹ toplamДұ (indirimler sonrasДұ).
  // lineSellerDiscountGross: Trendyol lineSellerDiscount вҖ” satДұcДұ indirimi (gross).
  // saleVatRate: ГјrГјn KDV oranДұ (varianttan veya kategori lookup'tan).
  lineListGross           Decimal @default(0) @map("line_list_gross") @db.Decimal(12, 2)
  lineSaleGross           Decimal @default(0) @map("line_sale_gross") @db.Decimal(12, 2)
  lineSellerDiscountGross Decimal @default(0) @map("line_seller_discount_gross") @db.Decimal(12, 2)
  saleVatRate             Decimal @default(0) @map("sale_vat_rate") @db.Decimal(5, 2)

  // Komisyon (gross + oran)
  // commissionRate: Trendyol per-line commission rate (%).
  // commissionGross: hesaplanan gross komisyon tutarДұ (effectiveSale Г— rate).
  // refundedCommissionGross: iade edilen komisyon (gross). default(0) = iade yok.
  // commissionVatRate: komisyon KDV oranДұ (DB-driven, default %20 вҖ” denetim A #331).
  // estimatedCommissionGross (write-once): T+0 tahmin вҖ” settlement gelince korunur.
  // settledCommissionGross (mutable): Trendyol'un Settlement'ta yazdДұДҹДұ gerГ§ek deДҹer.
  commissionRate           Decimal  @map("commission_rate") @db.Decimal(5, 2)
  commissionGross          Decimal  @default(0) @map("commission_gross") @db.Decimal(12, 2)
  refundedCommissionGross  Decimal  @default(0) @map("refunded_commission_gross") @db.Decimal(12, 2)
  commissionVatRate        Decimal  @default(20) @map("commission_vat_rate") @db.Decimal(5, 2)
  estimatedCommissionGross Decimal? @map("estimated_commission_gross") @db.Decimal(12, 2)
  settledCommissionGross   Decimal? @map("settled_commission_gross") @db.Decimal(12, 2)

  // Settlement ACTUAL Г§ДұpasДұ вҖ” Trendyol'un Sale settlement'ta kredilediДҹi GERГҮEK
  // satДұЕҹ tutarДұ (KDV-dahil ham `credit`; handleSale yazar, T+~5). KГӮRA GД°RMEZ:
  // estimated/settled kГўr HAK EDД°LEN'den (effectiveSale) hesaplanДұr, bu kolondan
  // DEДһД°L. YalnДұz gelecek "HakediЕҹ KontrolГј" mutabakatДұnДұn Г§ДұpasДұ вҖ” beklenen
  // (effectiveSale) vs gerГ§ek (bu kolon) karЕҹДұlaЕҹtДұrДұp "eksik satДұЕҹ bedeli"
  // tespit edecek. Null: settlement gelmeden Г¶nce (2026-06-14 temel atДұmДұ).
  settledSaleAmount Decimal? @map("settled_sale_amount") @db.Decimal(12, 2)

  // Maliyet anlДұk kopyasДұ (gross + KDV oranДұ).
  // TГјmГј nullable: maliyet snapshot eksik durumda kar hesabДұ null kalДұr.
  unitCostSnapshotGross   Decimal? @map("unit_cost_snapshot_gross") @db.Decimal(12, 2)
  unitCostSnapshotVatRate Decimal? @map("unit_cost_snapshot_vat_rate") @db.Decimal(5, 2)

  // Maliyet snapshot zamanДұ вҖ” write-once, variant baДҹlanДұnca set edilir.
  snapshotCapturedAt DateTime? @map("snapshot_captured_at")

  // Komisyon faturasДұ referansДұ (design В§3.8 iki aЕҹamalДұ populate):
  // - serialNumber: Sale satДұrДұ T+~5'te direkt yazar (raw "DCF...").
  // - id: T+~7 Komisyon FaturasДұ otherfinancials kaydДұ geldiДҹinde backfill FK.
  commissionInvoiceSerialNumber String? @map("commission_invoice_serial_number")
  commissionInvoiceId           String? @map("commission_invoice_id") @db.Uuid

  costSnapshotComponents OrderItemCostSnapshotComponent[]
  claimItems             OrderClaimItem[]

  order             Order              @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productVariant    ProductVariant?    @relation(fields: [productVariantId], references: [id], onDelete: SetNull)
  commissionInvoice CommissionInvoice? @relation(fields: [commissionInvoiceId], references: [id], onDelete: SetNull)

  @@index([organizationId, snapshotCapturedAt])
  @@index([commissionInvoiceId])
  // Resolution kuyruДҹu index'i PARTIAL (WHERE product_variant_id IS NULL) вҖ”
  // Prisma kДұsmi index yazamadДұДҹДұ iГ§in check-constraints.sql + migration
  // aynasДұnda yaЕҹar (order_items_resolution_due_idx).
  @@map("order_items")
}

model Settlement {
  id                   String           @id @default(uuid()) @db.Uuid
  organizationId       String           @map("organization_id") @db.Uuid
  storeId              String           @map("store_id") @db.Uuid
  platformSettlementId String?          @map("platform_settlement_id")
  periodStart          DateTime         @map("period_start")
  periodEnd            DateTime         @map("period_end")
  grossAmount          Decimal          @map("gross_amount") @db.Decimal(12, 2)
  netAmount            Decimal          @map("net_amount") @db.Decimal(12, 2)
  status               SettlementStatus @default(PENDING)
  createdAt            DateTime         @default(now()) @map("created_at")
  updatedAt            DateTime         @updatedAt @map("updated_at")

  store Store            @relation(fields: [storeId], references: [id], onDelete: Cascade)
  items SettlementItem[]

  @@index([organizationId])
  @@map("settlements")
}

model SettlementItem {
  id           String             @id @default(uuid()) @db.Uuid
  settlementId String             @map("settlement_id") @db.Uuid
  orderId      String?            @map("order_id") @db.Uuid
  amount       Decimal            @db.Decimal(12, 2)
  type         SettlementItemType

  settlement Settlement @relation(fields: [settlementId], references: [id], onDelete: Cascade)

  @@map("settlement_items")
}

model CostProfile {
  id             String          @id @default(uuid()) @db.Uuid
  organizationId String          @map("organization_id") @db.Uuid
  name           String
  type           CostProfileType
  // GROSS konvansiyon (2026-06-16): maliyet artДұk GROSS (KDV-dahil) girilir ve saklanДұr.
  // Eski amount(net) + vatAmount вҶ’ amountGross + vatRate. Net = amountGross Г— 100/(100+vatRate).
  // KDV oranДұ satДұЕҹ KDV'sinden baДҹДұmsДұz olabilir (tedarikГ§i %20 / satДұЕҹ %10).
  // KDV'siz maliyet вҶ’ vatRate=0. @default(0): dev truncate+re-sync iГ§in (pre-launch).
  amountGross    Decimal         @default(0) @map("amount_gross") @db.Decimal(12, 2)
  currency       Currency        @default(TRY)
  vatRate        Decimal         @default(0) @map("vat_rate") @db.Decimal(5, 2)
  fxRateMode     FxRateMode      @default(AUTO) @map("fx_rate_mode")
  manualFxRate   Decimal?        @map("manual_fx_rate") @db.Decimal(14, 6)
  note           String?
  archivedAt     DateTime?       @map("archived_at")
  createdBy      String?         @map("created_by") @db.Uuid
  updatedBy      String?         @map("updated_by") @db.Uuid
  createdAt      DateTime        @default(now()) @map("created_at")
  updatedAt      DateTime        @updatedAt @map("updated_at")

  organization       Organization                     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  versions           CostProfileVersion[]
  variantLinks       ProductVariantCostProfile[]
  snapshotComponents OrderItemCostSnapshotComponent[]

  @@unique([organizationId, name])
  @@index([organizationId, archivedAt])
  @@index([organizationId, type])
  @@map("cost_profiles")
}

model CostProfileVersion {
  id             String          @id @default(uuid()) @db.Uuid
  profileId      String          @map("profile_id") @db.Uuid
  organizationId String          @map("organization_id") @db.Uuid
  version        Int
  name           String
  type           CostProfileType
  // GROSS konvansiyon (2026-06-16): CostProfile mirror вҖ” versiyonlar da GROSS saklar.
  // @default(0): dev truncate+re-sync iГ§in (pre-launch).
  amountGross    Decimal         @default(0) @map("amount_gross") @db.Decimal(12, 2)
  currency       Currency
  vatRate        Decimal         @map("vat_rate") @db.Decimal(5, 2)
  fxRateMode     FxRateMode      @map("fx_rate_mode")
  manualFxRate   Decimal?        @map("manual_fx_rate") @db.Decimal(14, 6)
  note           String?
  archivedAt     DateTime?       @map("archived_at")
  changedFields  String[]        @map("changed_fields")
  changedBy      String?         @map("changed_by") @db.Uuid
  changedAt      DateTime        @default(now()) @map("changed_at")
  changeReason   String?         @map("change_reason")

  profile CostProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@unique([profileId, version])
  @@index([profileId, changedAt(sort: Desc)])
  @@index([organizationId])
  @@map("cost_profile_versions")
}

model ProductVariantCostProfile {
  id               String   @id @default(uuid()) @db.Uuid
  productVariantId String   @map("product_variant_id") @db.Uuid
