model SyncLog {
  id               String         @id @default(uuid()) @db.Uuid
  organizationId   String         @map("organization_id") @db.Uuid
  storeId          String         @map("store_id") @db.Uuid
  syncType         SyncType       @map("sync_type")
  status           SyncStatus
  // Timestamp columns are @db.Timestamptz(3) so node-postgres reads
  // them as UTC instants (its default for plain TIMESTAMP is the
  // CLIENT'S local timezone, which silently shifted next_attempt_at
  // by the user's TZ offset and made the SyncCenter "Yeniden
  // denenecek" countdown lie by N hours). PG-internal SQL comparisons
  // worked either way (session TZ is UTC), but the wire shape is the
  // problem. timestamptz fixes both вҖ” see fix(sync) PR.
  startedAt        DateTime       @map("started_at") @db.Timestamptz(3)
  completedAt      DateTime?      @map("completed_at") @db.Timestamptz(3)
  recordsProcessed Int            @default(0) @map("records_processed")
  progressCurrent  Int            @default(0) @map("progress_current")
  progressTotal    Int?           @map("progress_total")
  progressStage    String?        @map("progress_stage")
  errorCode        SyncErrorCode? @map("error_code")
  errorMessage     String?        @map("error_message")
  // в”Җв”Җв”Җ New columns (PR 2) в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
  claimedAt        DateTime?      @map("claimed_at") @db.Timestamptz(3)
  claimedBy        String?        @map("claimed_by")
  lastTickAt       DateTime?      @map("last_tick_at") @db.Timestamptz(3)
  pageCursor       Json?          @map("page_cursor")
  attemptCount     Int            @default(0) @map("attempt_count")
  nextAttemptAt    DateTime?      @map("next_attempt_at") @db.Timestamptz(3)
  // Bozuk sayfalar (Trendyol upstream 5xx, MAX_ATTEMPTS dolan transient
  // hatalar). Worker bu durumda sync'i terminal FAIL etmek yerine cursor'u
  // bir ileri alДұr ve atlanan sayfayДұ buraya kaydeder. Еһema:
  // Array<{ page, attemptedAt, errorCode, httpStatus, xRequestId?, responseBodySnippet? }>
  // UI bu array'i okuyup COMPLETED satДұrДұnДұn yanДұnda "X sayfa atlandДұ"
  // uyarДұsДұ gГ¶sterir.
  skippedPages     Json?          @map("skipped_pages")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  store        Store        @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([storeId, startedAt])
  @@index([status, nextAttemptAt])
  @@map("sync_logs")
}

// Marketplace komisyon tarifesi. Trendyol partner panel BFF'inden
// (apigw.trendyol.com /partner/seller-allowance-sfjdomestic-santral/commercial-rules/*)
// veya gelecekte Hepsiburada panelinden Г§ekilen platform genelinde **paylaЕҹДұmlДұ**
// kategori (+ marka) bazlДұ komisyon oranДұ ve vade. Trendyol tarifesi tГјm satДұcДұlar
// iГ§in aynДұdДұr вҖ” segment override'lar kavramsal olarak var ama Trendyol satДұcДұnДұn
// segment bilgisini API Гјzerinden vermediДҹi iГ§in kГўr hesaplamasДұnda her zaman
// `base_rate` kullanДұlДұr. Bu yГјzden tablo tenant-private deДҹil, platform-bazlДұ
// tek paylaЕҹДұmlДұ reference data: bГјtГјn authenticated user'lar aynДұ satДұrlarДұ okur.
//
// Order.commissionAmount'tan FARKLI вҖ” bu **gelecek komisyon tahmini** iГ§indir
// (yeni ГјrГјn fiyatlandДұrma), sipariЕҹ satДұrДұnДұn fiili komisyonu deДҹil.
//
// REPLACE semantiДҹi: her refresh `(platform, rule_kind)` Г§iftindeki tГјm satДұrlar
// transaction iГ§inde silinir ve yeniden yazДұlДұr. Historik tarife saklanmaz вҖ”
// geГ§miЕҹ sipariЕҹler iГ§in OrderItem.commissionAmount/Rate authoritative.
model MarketplaceCommissionRate {
  id       String             @id @default(uuid()) @db.Uuid
  platform Platform
  ruleKind CommissionRuleKind @map("rule_kind")

  // External marketplace identity. BigInt Г§ГјnkГј Trendyol categoryId/brandId
  // alanlarДұ int64 (Г¶rn. brandId 977855).
  categoryId BigInt  @map("category_id")
  brandId    BigInt? @map("brand_id") // CATEGORY kurallarДұ iГ§in NULL

  // Denormalize display alanlarДұ вҖ” reference tablo eklemeden import edebilelim
  // diye (CLAUDE.md WET+1 promotion trigger: ikinci feature isteyince normalize
  // ederiz). parentCategoryName sadece CATEGORY kurallarДұnda dolu olur;
  // brandName sadece CATEGORY_BRAND'de.
  categoryName       String  @map("category_name")
  parentCategoryName String? @map("parent_category_name")
  brandName          String? @map("brand_name")

  // Tarife. Decimal(5,2) вҖ” stage'de 99.50, prod'da вүӨ30; (5,2) sДұnДұrДұ 999.99
  // ile gГјvenli pay bДұrakДұyor. OrderItem.commissionRate ile aynДұ precision.
  baseRate        Decimal @map("base_rate") @db.Decimal(5, 2)
  paymentTermDays Int     @map("payment_term_days")

  // Platform-spesifik segment override'lar. Trendyol iГ§in key'ler:
  // {"ka1": "4.00", "ka2": "5.00", "na1": "...", "microSegment": "..."}.
  // Hepsiburada gelirse farklДұ key seti вҖ” JSONB sabit kolonu zorlamadДұДҹДұ iГ§in
  // Еҹema migration'sДұz yeni platform kabul ediyor. Еһu an Гјretim kГўr hesabДұnda
  // kullanДұlmДұyor (Trendyol seller segment'i API'den dГ¶nmГјyor), ama veriyi
  // import sДұrasДұnda atДұyoruz вҖ” Trendyol ileride segment paylaЕҹДұrsa hazДұr.
  segmentOverrides Json @default("{}") @map("segment_overrides")

  // Audit
  fetchedAt    DateTime @map("fetched_at")
  sourceScreen String   @map("source_screen") // x-system-screen header deДҹeri

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // NULL brandId (CATEGORY kurallarДұ) durumunda PostgreSQL'in default
  // NULLS DISTINCT davranДұЕҹДұ bu unique'i kДұsmen etkisiz bДұrakДұr вҖ” yani aynДұ
  // (platform, CATEGORY, categoryId) iГ§in teorik olarak birden fazla satДұr olabilir.
  // Defense-in-depth: import servisi her zaman transactional REPLACE yapar
  // (DELETE WHERE platform=$1 AND rule_kind=$2; sonra INSERT-many), bu yГјzden
  // import path Гјzerinden duplicate giremez. Resolver findFirst kullanДұr.
  @@unique([platform, ruleKind, categoryId, brandId], map: "marketplace_commission_rate_dedup")
  @@index([platform, ruleKind, categoryId])
  @@map("marketplace_commission_rate")
}

model ShippingCarrier {
