{
  "name": "@pazarsync/db",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./enums": "./src/enums.ts",
    "./test-support": "./src/test-support.ts",
    "./test-env": "./src/test-env.ts"
  },
  "scripts": {
    "generate": "prisma generate",
    "migrate:dev": "prisma migrate dev && pnpm apply-policies",
    "push": "prisma db push && pnpm apply-policies",
    "deploy": "prisma migrate deploy && pnpm apply-policies",
    "apply-policies": "tsx --env-file-if-exists=../../.env scripts/apply-policies.ts",
    "test-db:setup": "tsx scripts/setup-test-db.ts",
    "cutover:v2": "tsx --env-file-if-exists=../../.env scripts/cutover-stale-running.ts",
    "purge-test-users": "tsx --env-file-if-exists=../../.env scripts/purge-test-users.ts",
    "reset-clean": "tsx --env-file-if-exists=../../.env scripts/reset-clean.ts",
    "seed": "tsx prisma/seed.ts",
    "seed:reference": "tsx scripts/seed-reference.ts",
    "studio": "prisma studio",
    "test": "vitest run",
    "test:unit": "vitest run --config vitest.unit.config.ts --passWithNoTests",
    "test:integration": "vitest run tests --passWithNoTests",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "clean": "rm -rf .turbo"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "@supabase/supabase-js": "catalog:",
    "pg": "^8.22.0"
  },
  "devDependencies": {
    "@pazarsync/crypto-core": "workspace:*",
    "@pazarsync/eslint-config": "workspace:*",
    "@prisma/client": "^7.8.0",
    "@types/pg": "^8.11.0",
    "decimal.js": "catalog:",
    "dotenv": "catalog:",
    "eslint": "catalog:",
    "prisma": "^7.8.0",
    "tsx": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
