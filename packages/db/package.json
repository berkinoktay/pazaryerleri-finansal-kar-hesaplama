{
  "name": "@pazarsync/db",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./enums": "./src/enums.ts"
  },
  "scripts": {
    "generate": "prisma generate",
    "migrate:dev": "prisma migrate dev",
    "push": "prisma db push && pnpm apply-policies",
    "deploy": "prisma migrate deploy && pnpm apply-policies",
    "apply-policies": "tsx --env-file-if-exists=../../.env scripts/apply-policies.ts",
    "cutover:v2": "tsx --env-file-if-exists=../../.env scripts/cutover-stale-running.ts",
    "purge-test-users": "tsx --env-file-if-exists=../../.env scripts/purge-test-users.ts",
    "reset-clean": "tsx --env-file-if-exists=../../.env scripts/reset-clean.ts",
    "seed": "tsx prisma/seed.ts",
    "studio": "prisma studio",
    "typecheck": "tsc --noEmit",
    "lint": "eslint ."
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "@supabase/supabase-js": "catalog:",
    "pg": "^8.13.0"
  },
  "devDependencies": {
    "@prisma/client": "^7.8.0",
    "@types/pg": "^8.11.0",
    "dotenv": "catalog:",
    "prisma": "^7.8.0",
    "tsx": "catalog:",
    "typescript": "catalog:",
    "@pazarsync/eslint-config": "workspace:*",
    "eslint": "catalog:"
  }
}
