!.vscode/settings.json
!.vscode/extensions.json
.idea/
*.swp
*.swo
.DS_Store

# debug
npm-debug.log*
pnpm-debug.log*
yarn-debug.log*
yarn-error.log*

# vercel
.vercel/

# supabase
supabase/.temp/
supabase/.branches/

# Claude Code — personal toolchain and MCP secrets (project rules live in CLAUDE.md files)
.claude/
.agents/
skills-lock.json
.mcp.json

# Prisma generated (alternate path)
packages/db/prisma/generated/

# Git worktrees
.worktrees/

# Superpowers brainstorm scratch (HTML mockups, server state)
.superpowers/

# scratch / one-off data captures (may contain commercially sensitive marketplace data)
tmp/

# docs/ personal knowledge base (research, plans, integration notes) — local-only
docs/
apps/sync-worker/scripts/

# design-sync (claude.ai/design) — staged converter scripts, build output, machine state
.ds-sync/
ds-bundle/
.design-sync/.cache/
.design-sync/learnings/
.design-sync/node_modules
# The build scaffolding under apps/web/.design-sync-build/ holds durable, hand-written
# inputs the config references (entry, provider, preview-icons, tw-entry, compile-css)
# plus the brand fonts — those ARE committed so a fresh clone can rebuild. Only the
# Tailwind-compiled stylesheet is regenerated each build:
apps/web/.design-sync-build/compiled.css
