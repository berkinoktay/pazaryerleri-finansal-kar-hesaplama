{
  "name": "@pazarsync/sync-worker",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "scripts": {
    "start": "tsx src/index.ts",
    "dev": "tsx watch --env-file=../../.env src/index.ts",
    "typecheck": "tsc --noEmit",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration",
    "lint": "eslint ."
  },
  "dependencies": {
    "@pazarsync/db": "workspace:*",
    "@pazarsync/marketplace": "workspace:*",
    "@pazarsync/order-sync": "workspace:*",
    "@pazarsync/profit": "workspace:*",
    "@pazarsync/sync-core": "workspace:*",
    "@pazarsync/utils": "workspace:*",
    "decimal.js": "^10.6.0"
  },
  "devDependencies": {
    "dotenv": "^16.4.0",
    "tsx": "^4.19.0",
    "typescript": "^6",
    "vitest": "^4",
    "@pazarsync/eslint-config": "workspace:*",
    "eslint": "^9"
  }
}
