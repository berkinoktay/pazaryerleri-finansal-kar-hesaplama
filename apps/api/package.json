{
  "name": "@pazarsync/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsup src/index.ts --format esm --dts",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --fix",
    "clean": "rm -rf dist .turbo",
    "test": "vitest run",
    "test:watch": "vitest",
    "openapi:dump": "tsx scripts/dump-openapi.ts"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.14",
    "@hono/zod-openapi": "0.19.10",
    "@hono/zod-validator": "^0.5.0",
    "@pazarsync/db": "workspace:*",
    "@pazarsync/types": "workspace:*",
    "@pazarsync/utils": "workspace:*",
    "@scalar/hono-api-reference": "^0.10.8",
    "@supabase/supabase-js": "^2.49.0",
    "decimal.js": "^10.5.0",
    "hono": "^4.12.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@vitest/ui": "^4.1.4",
    "dotenv": "^16.4.0",
    "tsup": "^8.4.0",
    "tsx": "^4.19.0",
    "typescript": "^5",
    "vitest": "^4.1.4"
  }
}
