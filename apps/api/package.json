{
  "name": "@pazarsync/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch --env-file=../../.env src/index.ts",
    "build": "tsup src/index.ts --format esm",
    "start": "tsx src/index.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "clean": "rm -rf dist .turbo",
    "test": "vitest run",
    "test:unit": "PAZARSYNC_SKIP_RESEED=1 vitest run tests/unit --passWithNoTests",
    "test:integration": "vitest run tests/integration --passWithNoTests",
    "test:watch": "vitest",
    "openapi:dump": "tsx scripts/dump-openapi.ts",
    "gen:encryption-key": "tsx scripts/gen-encryption-key.ts",
    "fx:seed": "tsx --env-file=../../.env scripts/seed-fx-rates.ts"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.14",
    "@hono/zod-openapi": "^1.4.0",
    "@hono/zod-validator": "^0.8.0",
    "@pazarsync/db": "workspace:*",
    "@pazarsync/marketplace": "workspace:*",
    "@pazarsync/order-sync": "workspace:*",
    "@pazarsync/profit": "workspace:*",
    "@pazarsync/sync-core": "workspace:*",
    "@pazarsync/utils": "workspace:*",
    "@scalar/hono-api-reference": "^0.10.14",
    "@supabase/supabase-js": "catalog:",
    "decimal.js": "catalog:",
    "hono": "^4.12.18",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@pazarsync/eslint-config": "workspace:*",
    "@types/node": "catalog:",
    "@vitest/ui": "catalog:",
    "dotenv": "catalog:",
    "eslint": "catalog:",
    "tsup": "^8.4.0",
    "tsx": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
