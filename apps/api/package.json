{
  "name": "@pazarsync/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch --env-file=../../.env src/index.ts",
    "build": "tsup src/index.ts --format esm --dts",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --fix",
    "clean": "rm -rf dist .turbo",
    "test": "vitest run",
    "test:unit": "PAZARSYNC_SKIP_RESEED=1 vitest run tests/unit --passWithNoTests",
    "test:integration": "vitest run tests/integration --passWithNoTests",
    "test:watch": "vitest",
    "openapi:dump": "tsx scripts/dump-openapi.ts",
    "gen:encryption-key": "tsx scripts/gen-encryption-key.ts"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.14",
    "@hono/zod-openapi": "^1.3.0",
    "@hono/zod-validator": "^0.7.6",
    "@pazarsync/db": "workspace:*",
    "@pazarsync/marketplace": "workspace:*",
    "@pazarsync/sync-core": "workspace:*",
    "@pazarsync/utils": "workspace:*",
    "@scalar/hono-api-reference": "^0.10.13",
    "@supabase/supabase-js": "^2.105.1",
    "decimal.js": "^10.5.0",
    "hono": "^4.12.16",
    "zod": "^4.4.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^22.0.0",
    "@vitest/ui": "^4.1.4",
    "dotenv": "^16.4.0",
    "eslint": "^9",
    "tsup": "^8.4.0",
    "tsx": "^4.19.0",
    "typescript": "^6",
    "typescript-eslint": "^8.58.2",
    "vitest": "^4.1.4"
  }
}
