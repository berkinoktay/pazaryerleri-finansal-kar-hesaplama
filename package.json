{
  "name": "pazarsync",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "typecheck": "turbo run typecheck",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "db:generate": "pnpm --filter @pazarsync/db generate",
    "db:migrate": "pnpm --filter @pazarsync/db migrate:dev",
    "db:push": "pnpm --filter @pazarsync/db push",
    "db:seed": "pnpm --filter @pazarsync/db seed",
    "db:studio": "pnpm --filter @pazarsync/db studio",
    "test": "turbo run test",
    "test:unit": "turbo run test:unit",
    "test:integration": "turbo run test:integration",
    "test:watch": "turbo run test:watch --parallel",
    "check:all": "turbo run typecheck lint test:unit && pnpm format:check",
    "check:full": "turbo run typecheck lint test && pnpm format:check",
    "clean": "turbo run clean",
    "api:openapi": "pnpm --filter @pazarsync/api openapi:dump",
    "api:codegen": "pnpm --filter @pazarsync/api-client codegen",
    "api:sync": "pnpm api:openapi && pnpm api:codegen",
    "prepare": "husky"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.5.0",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "turbo": "^2.5.0",
    "typescript": "^5.8.0"
  },
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=20.19.0"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,json,css,md}": "prettier --write"
  }
}
