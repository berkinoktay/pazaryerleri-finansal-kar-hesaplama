{
  "name": "pazarsync",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "typecheck": "turbo run typecheck",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "db:generate": "pnpm --filter @pazarsync/db generate",
    "db:migrate": "pnpm --filter @pazarsync/db migrate:dev",
    "db:push": "pnpm --filter @pazarsync/db push",
    "db:deploy": "pnpm --filter @pazarsync/db deploy",
    "db:apply-policies": "pnpm --filter @pazarsync/db apply-policies",
    "db:seed": "pnpm --filter @pazarsync/db seed",
    "db:seed-reference": "pnpm --filter @pazarsync/db seed:reference",
    "db:studio": "pnpm --filter @pazarsync/db studio",
    "db:purge-test-users": "pnpm --filter @pazarsync/db purge-test-users",
    "db:reset:clean": "pnpm --filter @pazarsync/db reset-clean",
    "test": "turbo run test",
    "test:unit": "turbo run test:unit",
    "test:component": "turbo run test:component",
    "test:integration": "turbo run test:integration",
    "test:watch": "turbo run test:watch --parallel",
    "check:all": "turbo run typecheck lint test:unit test:component && pnpm format:check && pnpm audit:boundaries && pnpm audit:errors && pnpm audit:lint && pnpm audit:money && pnpm audit:no-barrel",
    "check:full": "turbo run typecheck lint test:unit test:component && turbo run test:integration --concurrency=1 && pnpm format:check && pnpm audit:boundaries && pnpm audit:errors && pnpm audit:lint && pnpm audit:money && pnpm audit:no-barrel",
    "clean": "turbo run clean",
    "api:openapi": "pnpm --filter @pazarsync/api openapi:dump",
    "api:codegen": "pnpm --filter @pazarsync/api-client codegen",
    "api:sync": "pnpm api:openapi && pnpm api:codegen",
    "gen:encryption-key": "pnpm --filter @pazarsync/api gen:encryption-key",
    "audit:boundaries": "tsx scripts/audit-feature-boundaries.ts",
    "audit:errors": "tsx scripts/audit-error-codes.ts",
    "audit:lint": "tsx scripts/audit-lint-coverage.ts",
    "audit:money": "tsx scripts/audit-money.ts",
    "audit:no-barrel": "tsx scripts/audit-barrels.ts",
    "emit:components-manifest": "tsx scripts/emit-component-manifest.ts",
    "postinstall": "pnpm --filter @pazarsync/db generate",
    "prepare": "husky"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.3",
    "@commitlint/config-conventional": "^20.5.3",
    "@types/node": "catalog:",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.5.0",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "tsx": "catalog:",
    "turbo": "^2.9.12",
    "typescript": "catalog:"
  },
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=20.19.0"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,json,css,md}": "prettier --write"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "prisma"
    ]
  }
}
