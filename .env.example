# ─── apps/web ─────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
# Public API key — safe to expose client-side, RLS policies enforce access.
# Supabase's current recommended format (opaque, `sb_publishable_*`).
# Legacy JWT-format `anon` keys still work but are being phased out.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
NEXT_PUBLIC_API_URL=http://localhost:3001

# Mirrors apps/api's ALLOW_SANDBOX_CONNECTIONS — hides the Sandbox
# environment tab in the connect-store UI. Cosmetic only; the backend
# is the real gate. Production deployments MUST set this to "false"
# or omit it entirely.
NEXT_PUBLIC_ALLOW_SANDBOX_CONNECTIONS=true

# ─── apps/api ─────────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres
DIRECT_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres
SUPABASE_URL=http://127.0.0.1:54321
# Server-only key — bypasses RLS. Never expose client-side.
# Supabase's current recommended format (opaque, `sb_secret_*`).
# Legacy JWT-format `service_role` keys still work but are being phased out.
SUPABASE_SECRET_KEY=

# ─── Trendyol integration ─────────────────────────
# Prod + sandbox endpoints per docs/integrations/trendyol/3-canli-test-ortam-bilgileri.md.
# Never commit real API credentials — those live per-store in
# stores.credentials (encrypted with AES-256-GCM).
TRENDYOL_PROD_BASE_URL=https://apigw.trendyol.com
TRENDYOL_SANDBOX_BASE_URL=https://stageapigw.trendyol.com
# User-Agent suffix per docs/integrations/trendyol/2-authorization.md.
# Header format: "{supplierId} - {suffix}". Missing UA → 403 from Trendyol.
TRENDYOL_INTEGRATOR_UA_SUFFIX=SelfIntegration

# Sandbox gate (design doc §3 decision D4). The server accepts
# `environment: SANDBOX` on POST /v1/.../stores only when this is
# exactly "true". Production deployments MUST set it to "false" or
# omit it entirely — the adapter never reaches the sandbox URL
# without this flag.
ALLOW_SANDBOX_CONNECTIONS=true

HEPSIBURADA_BASE_URL=https://mpop-sit.hepsiburada.com

# 32-byte AES-256-GCM key for encrypting marketplace credentials at rest.
# Generate with: pnpm gen:encryption-key
# WARNING: rotating this key invalidates every stored credential — plan a
# re-encryption migration before changing it in a live environment.
ENCRYPTION_KEY=

# ─── supabase/functions ──────────────────────────
# These are auto-injected by Supabase runtime
# SUPABASE_URL=
# SUPABASE_SECRET_KEY=
