# ─── apps/web ─────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
# Public API key — safe to expose client-side, RLS policies enforce access.
# Supabase's current recommended format (opaque, `sb_publishable_*`).
# Legacy JWT-format `anon` keys still work but are being phased out.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
NEXT_PUBLIC_API_URL=http://localhost:3001

# Mirrors apps/api's ALLOW_SANDBOX_CONNECTIONS — hides the Sandbox
# environment tab in the connect-store UI. Cosmetic only; the backend
# is the real gate. Production deployments MUST set this to "false"
# or omit it entirely.
NEXT_PUBLIC_ALLOW_SANDBOX_CONNECTIONS=true

# ─── apps/api ─────────────────────────────────────
# Validated at boot by apps/api/src/lib/env.ts::validateRequiredEnv.
# Allowed values: production | staging | development | test.
# Production deployments MUST set NODE_ENV=production explicitly so the
# OpenAPI docs gate (apps/api/src/app.ts) stays closed.
NODE_ENV=development
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres
DIRECT_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres
SUPABASE_URL=http://127.0.0.1:54321
# Server-only key — bypasses RLS. Never expose client-side.
# Supabase's current recommended format (opaque, `sb_secret_*`).
# Legacy JWT-format `service_role` keys still work but are being phased out.
SUPABASE_SECRET_KEY=

# OPTIONAL — fx-rates pg_cron job target, consumed by apply-policies.ts.
# Hosted environments derive it from SUPABASE_URL (https → <url>/functions/v1);
# set explicitly only for local dev, where pg_net runs INSIDE the Postgres
# container and the host's 127.0.0.1:54321 is unreachable
# (e.g. http://host.docker.internal:54321/functions/v1).
# Unset → the fx cron job is scheduled but no-ops; queue fan-out jobs unaffected.
PG_CRON_FUNCTIONS_URL=

# ─── Trendyol integration ─────────────────────────
# Prod + sandbox endpoints per docs/integrations/trendyol/3-canli-test-ortam-bilgileri.md.
# Never commit real API credentials — those live per-store in
# stores.credentials (encrypted with AES-256-GCM).
TRENDYOL_PROD_BASE_URL=https://apigw.trendyol.com
TRENDYOL_SANDBOX_BASE_URL=https://stageapigw.trendyol.com
# User-Agent suffix per docs/integrations/trendyol/2-authorization.md.
# Header format: "{supplierId} - {suffix}". Missing UA → 403 from Trendyol.
TRENDYOL_INTEGRATOR_UA_SUFFIX=SelfIntegration

# ─── Public API base URL (webhook callback) ─────────
# Trendyol webhook register sends this URL + /api/v1/webhooks/orders/<storeId>
# as the callback. Trendyol rejects http://, localhost, 127.0.0.1 — local dev
# must use a tunnel (ngrok / Cloudflare Tunnel) per
# docs/plans/2026-05-20-trendyol-webhook-receiver-design.md §13.
# Production: https://api.pazarsync.com
# Staging:    https://api-staging.pazarsync.com
# Local dev:  https://<ngrok-id>.ngrok-free.app
PUBLIC_API_BASE_URL=

# Sandbox gate (design doc §3 decision D4). The server accepts
# `environment: SANDBOX` on POST /v1/.../stores only when this is
# exactly "true". Production deployments MUST set it to "false" or
# omit it entirely — the adapter never reaches the sandbox URL
# without this flag.
ALLOW_SANDBOX_CONNECTIONS=true

HEPSIBURADA_BASE_URL=https://mpop-sit.hepsiburada.com

# 32-byte AES-256-GCM key for encrypting marketplace credentials at rest.
# Generate with: pnpm gen:encryption-key
# WARNING: rotating this key invalidates every stored credential — plan a
# re-encryption migration before changing it in a live environment.
ENCRYPTION_KEY=

# ─── apps/sync-worker ─────────────────────────────────────
# Days of historical backfill on initial sync. Production = 0 (strict
# forward-only — only orders after store.createdAt). Dev = 90 for
# settlement testing against past orders. Clamped by store.createdAt
# regardless of value.
SYNC_HISTORICAL_BACKFILL_DAYS=0
# Cron per-tick lookback window in hours. Webhook is primary; cron
# safety-net catches webhook misses.
SYNC_SAFETY_NET_HOURS=8
# Days of webhook_events (idempotency + raw audit log) to retain. Optional;
# defaults to 90. The daily webhook-event-cleanup tick prunes older rows.
WEBHOOK_EVENT_RETENTION_DAYS=90

# ─── supabase/functions ──────────────────────────
# These are auto-injected by Supabase runtime
# SUPABASE_URL=
# SUPABASE_SECRET_KEY=
